<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8" />
    <title>新增/编辑调度配置</title>
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/Style_chart.css" rel="stylesheet" />
    <link href="~/Styles/public.css" rel="stylesheet" />
    <script src="~/Scripts/public.js"></script>
    <style type="text/css">
        body {
            font-family: tahoma, arial, sans-serif;
            font-size: 12px;
            margin: 5px;
        }
        .form-container {
            width: 600px;
            margin: 0 auto;
            padding: 20px;
            border: 1px solid #ccc;
            border-radius: 5px;
            background-color: #f9f9f9;
        }
        .form-item {
            margin-bottom: 15px;
        }
        .form-label {
            display: inline-block;
            width: 100px;
            text-align: right;
            margin-right: 10px;
            font-weight: bold;
        }
        .mini-textbox, .mini-combobox, .mini-textarea, .mini-datepicker, .mini-timepicker, .mini-spinner {
            width: 400px;
            border: 1px solid #b3d9ff;
            border-radius: 3px;
        }
        .mini-textbox, .mini-timepicker, .mini-spinner {
            height: 35px;
        }
        .mini-textarea {
            height: 80px;
        }
        .button-container {
            display: flex;
            justify-content: flex-end;
            margin-top: 20px;
            width: 510px;
        }
        .mini-button {
            width: 100px;
            margin-left: 10px;
            text-align: center;
            padding: 8px 0;
        }
    </style>
    <script type="text/javascript">
        var form;
        
        // 加载任务模板列表
        function loadTaskTemplates() {
            $.ajax({
                url: "/Task/GetTaskTemplateList",
                type: "post",
                success: function (text) {
                    var result = mini.decode(text);
                    var templates = result && result.data ? result.data : (result && result.length > 0 ? result : []);
                    // 添加请选择选项
                    templates.unshift({ TemplateID: "", TemplateName: "请选择" });
                    mini.get("TemplateID").setData(templates);
                },
                error: function (xhr, status, error) {
                    mini.alert("网络错误");
                }
            });
        }
        
        // 获取调度配置详情
        function getTaskTemplateScheduleById(scheduleId, successCallback) {
            $.ajax({
                url: "/Task/GetTaskTemplateScheduleById",
                type: "get",
                data: { id: scheduleId },
                success: function (text) {
                    if (successCallback) {
                        successCallback(text);
                    }
                },
                error: function (xhr, status, error) {
                    mini.alert("网络错误");
                }
            });
        }
        
        // 保存调度配置
        function saveTaskTemplateSchedule(data, successCallback, errorCallback) {
            var json = mini.encode(data);
            $.ajax({
                url: "/Task/SaveTaskTemplateSchedule",
                type: "post",
                data: { send: json },
                success: function (text) {
                    if (successCallback) {
                        successCallback(text);
                    }
                },
                error: function (xhr, status, error) {
                    if (errorCallback) {
                        errorCallback(xhr, status, error);
                    } else {
                        mini.alert("网络错误");
                    }
                }
            });
        }
        
        // 获取URL参数
        function getUrlParam(name) {
            var reg = new RegExp("(^|&)" + name + "=([^&]*)(&|$)");
            var r = window.location.search.substr(1).match(reg);
            if (r != null) return unescape(r[2]);
            return null;
        }
        
        $(function () {
            // 确保mini框架已加载
            if (typeof mini === 'undefined') {
                return;
            }
            
            // 解析mini控件
            mini.parse();
            
            // 初始化表单
            form = new mini.Form("form1");
            
            // 重置表单
            resetForm();
            
            // 加载任务模板列表
            loadTaskTemplates();
            
            // 绑定调度类型变化事件
            var scheduleTypeCombo = mini.get("ScheduleType");
            if (scheduleTypeCombo) {
                // 使用miniUI的on方法绑定事件
                scheduleTypeCombo.on("valuechanged", function (e) {
                    var value = e.value;
                    updateScheduleTypeUI(value);
                });
                
                // 同时使用jQuery事件绑定作为备用
                $("#ScheduleType").on("change", function () {
                    var value = $(this).val();
                    updateScheduleTypeUI(parseInt(value));
                });
            }
            
            // 检查URL参数，获取scheduleId
            var scheduleId = getUrlParam("id");
            if (scheduleId) {
                // 通过AJAX获取调度配置数据
                getTaskTemplateScheduleById(scheduleId, function (text) {
                    if (text == "") {
                        mini.alert("调度不存在");
                    } else {
                        try {
                            var result = mini.decode(text);
                            
                            // 检查数据格式并适配
                            var scheduleData = null;
                            if (result) {
                                if (result.length > 0) {
                                    // 数组格式
                                    scheduleData = result[0];
                                } else if (result.ScheduleID) {
                                    // 对象格式
                                    scheduleData = result;
                                } else if (result.data && result.data.length > 0) {
                                    // 包含data属性的格式
                                    scheduleData = result.data[0];
                                }
                            }
                            
                            if (scheduleData) {
                                // 设置表单数据
                                $("#ScheduleID").val(scheduleData.ScheduleID);
                                
                                // 安全地设置TemplateID
                                var templateCombo = mini.get("TemplateID");
                                if (templateCombo) {
                                    templateCombo.setValue(scheduleData.TemplateID);
                                }
                                
                                // 安全地设置其他值
                                var scheduleTypeCombo = mini.get("ScheduleType");
                                if (scheduleTypeCombo) {
                                    scheduleTypeCombo.setValue(scheduleData.ScheduleType);
                                }
                                
                                var dayOfWeekCombo = mini.get("DayOfWeek");
                                if (dayOfWeekCombo) {
                                    dayOfWeekCombo.setValue(scheduleData.DayOfWeek);
                                }
                                
                                var dayOfMonthSpinner = mini.get("DayOfMonth");
                                if (dayOfMonthSpinner) {
                                    dayOfMonthSpinner.setValue(scheduleData.DayOfMonth);
                                }
                                
                                var executeTimePicker = mini.get("ExecuteTime");
                                if (executeTimePicker) {
                                    executeTimePicker.setValue(scheduleData.ExecuteTime);
                                } else {
                                    // 备用方案：直接操作DOM元素
                                    var executeTimeInput = document.getElementById('ExecuteTime');
                                    if (executeTimeInput) {
                                        executeTimeInput.value = scheduleData.ExecuteTime;
                                    }
                                }
                                
                                // 处理单选按钮
                                var isActiveValue = scheduleData.IsActive != null ? scheduleData.IsActive : true;
                                var shouldBeActive = false;
                                if (typeof isActiveValue === 'boolean') {
                                    shouldBeActive = isActiveValue;
                                } else if (typeof isActiveValue === 'string') {
                                    shouldBeActive = (isActiveValue.toLowerCase() === 'true' || isActiveValue === '1');
                                } else if (typeof isActiveValue === 'number') {
                                    shouldBeActive = (isActiveValue === 1);
                                }
                                
                                var radioButtons = document.getElementsByName('IsActive');
                                for (var i = 0; i < radioButtons.length; i++) {
                                    radioButtons[i].checked = (radioButtons[i].value === (shouldBeActive ? "1" : "0"));
                                }
                                
                                // 更新UI
                                updateScheduleTypeUI(scheduleData.ScheduleType);
                            } else {
                                mini.alert("数据格式错误");
                            }
                        } catch (e) {
                            mini.alert("数据处理错误");
                        }
                    }
                });
            }
        });
        
        // 重置表单
        function resetForm() {
            // 安全地重置TemplateID
            var templateCombo = mini.get("TemplateID");
            if (templateCombo) {
                templateCombo.setValue("");
            }
            
            // 安全地重置ScheduleType
            var scheduleTypeCombo = mini.get("ScheduleType");
            if (scheduleTypeCombo) {
                scheduleTypeCombo.setValue(1);
            }
            
            // 安全地重置DayOfWeek
            var dayOfWeekCombo = mini.get("DayOfWeek");
            if (dayOfWeekCombo) {
                dayOfWeekCombo.setValue(1);
            }
            
            // 安全地重置DayOfMonth
            var dayOfMonthSpinner = mini.get("DayOfMonth");
            if (dayOfMonthSpinner) {
                dayOfMonthSpinner.setValue(1);
            }
            
            // 安全地重置ExecuteTime
            var executeTimePicker = mini.get("ExecuteTime");
            if (executeTimePicker) {
                executeTimePicker.setValue("09:00:00");
            }
            
            // 默认选中启用
            var radioButtons = document.getElementsByName('IsActive');
            for (var i = 0; i < radioButtons.length; i++) {
                radioButtons[i].checked = (radioButtons[i].value === "1");
            }
            
            // 更新UI
            updateScheduleTypeUI(1);
        }
        

        
        // 更新调度类型UI
        function updateScheduleTypeUI(scheduleType) {
            // 转换为数字类型
            var type = parseInt(scheduleType);
            // 隐藏所有日期相关的控件
            $("#DayOfWeekDiv").hide();
            $("#DayOfMonthDiv").hide();

            // 根据调度类型显示相应的控件
            switch (type) {
                case 1:
                    // 每天 - 隐藏所有日期控件
                    break;
                case 2: // 每周
                    $("#DayOfWeekDiv").show();
                    break;
                case 3: // 每月
                    $("#DayOfMonthDiv").show();
                    break;
            }
        }
        
        // 保存调度配置
        function saveSchedule() {
            form.validate();
            if (form.isValid() === false) {
                return;
            }
            
            var data = form.getData();
            
            // 添加ScheduleID到数据中
            data.ScheduleID = $("#ScheduleID").val();
            
            // 获取mini-combobox的值
            var templateCombo = mini.get("TemplateID");
            if (templateCombo) {
                data.TemplateID = templateCombo.getValue();
            }
            
            var scheduleTypeCombo = mini.get("ScheduleType");
            if (scheduleTypeCombo) {
                data.ScheduleType = scheduleTypeCombo.getValue();
            }
            
            var dayOfWeekCombo = mini.get("DayOfWeek");
            if (dayOfWeekCombo) {
                data.DayOfWeek = dayOfWeekCombo.getValue();
            }
            
            var dayOfMonthSpinner = mini.get("DayOfMonth");
            if (dayOfMonthSpinner) {
                data.DayOfMonth = dayOfMonthSpinner.getValue();
            }
            
            var executeTimePicker = mini.get("ExecuteTime");
            if (executeTimePicker) {
                data.ExecuteTime = executeTimePicker.getValue();
            } 
            
            // 确保ExecuteTime不为空
            if (!data.ExecuteTime || data.ExecuteTime === '') {
                // 尝试从表单直接获取
                var executeTimeInput = document.getElementById('ExecuteTime');
                if (executeTimeInput) {
                    data.ExecuteTime = executeTimeInput.value;
                }
                
                // 如果仍然为空，设置默认值
                if (!data.ExecuteTime || data.ExecuteTime === '') {
                    data.ExecuteTime = '09:00:00';
                }
            }
            
            // 处理可选字段
            if (data.ScheduleType != 2) {
                data.DayOfWeek = "";
            }
            if (data.ScheduleType != 3) {
                data.DayOfMonth = "";
            }
            
            // 获取单选按钮的值
            var isActiveValue = "1";
            $("input[name='IsActive']").each(function() {
                if ($(this).prop("checked")) {
                    isActiveValue = $(this).val();
                }
            });
            data.IsActive = isActiveValue;
            
            try {
                saveTaskTemplateSchedule(data, function (text) {
                    try {
                        var result = mini.decode(text);
                        if (result.state == "1" || result.state == 1) {
                            mini.alert("保存成功");
                            CloseWindow("ok");
                        } else {
                            mini.alert(result.msg || "保存失败");
                        }
                    } catch (e) {
                        mini.alert("处理响应时出错");
                    }
                }, function (xhr, status, error) {
                    mini.alert("网络错误");
                });
            } catch (e) {
                mini.alert("保存过程中出错");
            }
        }
        
        function cancel() {
            CloseWindow();
        }
        
        function CloseWindow(action) {
            if (window.CloseOwnerWindow) {
                window.CloseOwnerWindow(action);
            } else {
                window.parent.CloseWindow(action);
            }
        }
    </script>
</head>
<body>
    <div class="form-container">
        <h2 style="text-align: center; margin-bottom: 20px;">新增/编辑调度配置</h2>
        <form id="form1">
            <input type="hidden" id="ScheduleID" name="ScheduleID" />
            
            <div class="form-item">
                <label class="form-label">任务模板：</label>
                <select id="TemplateID" name="TemplateID" class="mini-combobox" displayField="TemplateName" valueField="TemplateID" required="true"></select>
            </div>
            
            <div class="form-item">
                <label class="form-label">调度类型：</label>
                <select id="ScheduleType" name="ScheduleType" class="mini-combobox" required="true">
                    <option value="1">每天</option>
                    <option value="2">每周</option>
                    <option value="3">每月</option>
                </select>
            </div>
            
            <div class="form-item" id="DayOfWeekDiv" style="display:none;">
                <label class="form-label">星期：</label>
                <select id="DayOfWeek" name="DayOfWeek" class="mini-combobox">
                    <option value="1">周一</option>
                    <option value="2">周二</option>
                    <option value="3">周三</option>
                    <option value="4">周四</option>
                    <option value="5">周五</option>
                    <option value="6">周六</option>
                    <option value="7">周日</option>
                </select>
            </div>
            
            <div class="form-item" id="DayOfMonthDiv" style="display:none;">
                <label class="form-label">日期：</label>
                <input id="DayOfMonth" name="DayOfMonth" class="mini-spinner" min="1" max="31" />
            </div>
            
            <div class="form-item">
                <label class="form-label">执行时间：</label>
                <input id="ExecuteTime" name="ExecuteTime" class="mini-timepicker" format="HH:mm:ss" required="true" />
            </div>
            
            <div class="form-item">
                <label class="form-label">状态：</label>
                <div style="display: inline-block; width: 400px;">
                    <label style="margin-right: 20px;">
                        <input type="radio" id="IsActive1" name="IsActive" value="1" checked /> 启用
                    </label>
                    <label>
                        <input type="radio" id="IsActive0" name="IsActive" value="0" /> 禁用
                    </label>
                </div>
            </div>
            
            <div class="button-container">
                <a class="mini-button" onclick="saveSchedule()">保存</a>
                <a class="mini-button" onclick="cancel()">取消</a>
            </div>
        </form>
    </div>
</body>
</html>