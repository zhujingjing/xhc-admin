<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8" />
    <title>新增/编辑任务分类</title>
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/Style_chart.css" rel="stylesheet" />
    <link href="~/Styles/public.css" rel="stylesheet" />
    <script src="~/Scripts/public.js"></script>
    <style type="text/css">
        body {
            font-family: tahoma, arial, sans-serif;
            font-size: 12px;
            margin: 5px;
        }
        .form-container {
            width: 600px;
            margin: 0 auto;
            padding: 20px;
            border: 1px solid #ccc;
            border-radius: 5px;
            background-color: #f9f9f9;
        }
        .form-item {
            margin-bottom: 15px;
        }
        .form-label {
            display: inline-block;
            width: 100px;
            text-align: right;
            margin-right: 10px;
            font-weight: bold;
        }
        .mini-textbox, .mini-combobox, .mini-textarea, .mini-datepicker {
            width: 400px;
            border: 1px solid #b3d9ff;
            border-radius: 3px;
        }
        .mini-textbox {
            height: 35px;
        }
        .mini-textarea {
            height: 80px;
        }
        .button-container {
            display: flex;
            justify-content: flex-end;
            margin-top: 20px;
            width: 510px;
        }
        .mini-button {
            width: 100px;
            margin-left: 10px;
            text-align: center;
            padding: 8px 0;
        }
    </style>
    <script type="text/javascript">
        var form;
        var action = "new";
        var categoryData = null;
        
        $(function () {
            mini.parse();
            form = new mini.Form("form1");
            
            // 加载父分类列表
            loadParentCategories();
        });
        
        // 设置数据
        function SetData(data) {
            if (data) {
                action = data.action || "new";
                categoryData = data.category;
                var categoryId = data.categoryId;
                
                if (action == "edit" && (categoryData || categoryId)) {
                    if (categoryData) {
                        $("#CategoryID").val(categoryData.CategoryID);
                        mini.get("CategoryName").setValue(categoryData.CategoryName);
                        mini.get("ParentID").setValue(categoryData.ParentID);
                        mini.get("Description").setValue(categoryData.Description || "");
                    } else if (categoryId) {
                        // 通过AJAX获取分类数据
                        $.ajax({
                            url: "/Task/GetTaskCategoryById",
                            type: "post",
                            data: { id: categoryId },
                            success: function (text) {
                                var result = mini.decode(text);
                                
                                // 检查数据格式并适配
                                if (result) {
                                    if (result.length > 0) {
                                        // 数组格式
                                        categoryData = result[0];
                                    } else if (result.CategoryID) {
                                        // 对象格式
                                        categoryData = result;
                                    } else if (result.data && result.data.length > 0) {
                                        // 包含data属性的格式
                                        categoryData = result.data[0];
                                    }
                                    
                                    if (categoryData) {
                                        // 确保mini框架已初始化
                                        if (mini && mini.get) {
                                            // 设置CategoryID（使用jQuery直接设置）
                                            $("#CategoryID").val(categoryData.CategoryID);
                                            mini.get("CategoryName").setValue(categoryData.CategoryName);
                                            mini.get("ParentID").setValue(categoryData.ParentID);
                                            mini.get("Description").setValue(categoryData.Description || "");
                                        }
                                    }
                                }
                            }
                        });
                    }
                }
            }
        }
        
        // 加载父分类列表
        function loadParentCategories() {
            $.ajax({
                url: "/Task/GetTaskCategoryList",
                type: "post",
                success: function (text) {
                    var result = mini.decode(text);
                    var categories = result && result.data ? result.data : (result && result.length > 0 ? result : []);
                    // 添加请选择选项
                    categories.unshift({ CategoryID: "", CategoryName: "无父分类" });
                    mini.get("ParentID").setData(categories);
                    
                    // 如果是编辑模式，重新设置选中值
                    if (action == "edit" && categoryData && categoryData.ParentID) {
                        mini.get("ParentID").setValue(categoryData.ParentID);
                    }
                }
            });
        }
        
        // 保存分类
        function saveCategory() {
            form.validate();
            if (form.isValid() === false) return;
            
            var data = form.getData();
            
            // 添加CategoryID到数据中
            data.CategoryID = $("#CategoryID").val();
            // 获取mini-combobox的值
            data.ParentID = mini.get("ParentID").getValue();

            var json = mini.encode(data);
            
            $.ajax({
                url: "/Task/SaveTaskCategory",
                type: "post",
                data: { send: json },
                success: function (text) {
                    var result = mini.decode(text);
                    if (result.state == "1" || result.state == 1) {
                        mini.alert("保存成功");
                        CloseWindow("ok");
                    } else {
                        mini.alert(result.msg || "保存失败");
                    }
                },
                error: function () {
                    mini.alert("网络错误");
                }
            });
        }
        
        function cancel() {
            CloseWindow();
        }
        
        function CloseWindow(action) {
            if (window.CloseOwnerWindow) {
                window.CloseOwnerWindow(action);
            } else {
                window.parent.CloseWindow(action);
            }
        }
    </script>
</head>
<body>
    <div class="form-container">
        <h2 style="text-align: center; margin-bottom: 20px;">新增/编辑任务分类</h2>
        <form id="form1">
            <input type="hidden" id="CategoryID" name="CategoryID" />
            
            <div class="form-item">
                <label class="form-label">分类名称：</label>
                <input id="CategoryName" name="CategoryName" class="mini-textbox" required="true" />
            </div>
            
            <div class="form-item">
                <label class="form-label">父分类：</label>
                <select id="ParentID" name="ParentID" class="mini-combobox" displayField="CategoryName" valueField="CategoryID"></select>
            </div>
            
            <div class="form-item">
                <label class="form-label">分类描述：</label>
                <textarea id="Description" name="Description" class="mini-textarea" rows="3"></textarea>
            </div>
            
            <div class="button-container">
                <a class="mini-button" onclick="saveCategory()">保存</a>
                <a class="mini-button" onclick="cancel()">取消</a>
            </div>
        </form>
    </div>
</body>
</html>