<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8" />
    <title>新增/编辑时间段设置</title>
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/Style_chart.css" rel="stylesheet" />
    <link href="~/Styles/public.css" rel="stylesheet" />
    <script src="~/Scripts/public.js"></script>
    <style type="text/css">
        body {
            font-family: tahoma, arial, sans-serif;
            font-size: 12px;
            margin: 5px;
        }
        .form-container {
            width: 600px;
            margin: 0 auto;
            padding: 20px;
            border: 1px solid #ccc;
            border-radius: 5px;
            background-color: #f9f9f9;
        }
        .form-item {
            margin-bottom: 15px;
        }
        .form-label {
            display: inline-block;
            width: 100px;
            text-align: right;
            margin-right: 10px;
            font-weight: bold;
        }
        .mini-textbox, .mini-combobox, .mini-textarea, .mini-datepicker {
            width: 400px;
            border: 1px solid #b3d9ff;
            border-radius: 3px;
        }
        .mini-textbox {
            height: 35px;
        }
        .mini-textarea {
            height: 80px;
        }
        .button-container {
            display: flex;
            justify-content: flex-end;
            margin-top: 20px;
            width: 510px;
        }
        .mini-button {
            width: 100px;
            margin-left: 10px;
            text-align: center;
            padding: 8px 0;
        }
    </style>
    <script type="text/javascript">
        var form;
        var action = "new";
        var timeSettingData = null;
        
        $(function () {
            mini.parse();
            form = new mini.Form("form1");
            
            // 加载任务分类列表
            loadCategories();
        });
        
        // 设置数据
        function SetData(data) {
            if (data) {
                action = data.action || "new";
                timeSettingData = data.timeSetting;
                var settingId = data.settingId;
                
                if (action == "edit" && (timeSettingData || settingId)) {
                    if (timeSettingData) {
                        $("#SettingID").val(timeSettingData.SettingID);
                        mini.get("CategoryID").setValue(timeSettingData.CategoryID);
                        mini.get("StartTime").setValue(timeSettingData.StartTime);
                        mini.get("EndTime").setValue(timeSettingData.EndTime);
                        
                        // 处理单选按钮
                        var isActiveValue = timeSettingData.IsActive != null ? timeSettingData.IsActive : true;
                        // 确保正确处理各种数据类型
                        var shouldBeActive = false;
                        if (typeof isActiveValue === 'boolean') {
                            shouldBeActive = isActiveValue;
                        } else if (typeof isActiveValue === 'string') {
                            shouldBeActive = (isActiveValue.toLowerCase() === 'true' || isActiveValue === '1');
                        } else if (typeof isActiveValue === 'number') {
                            shouldBeActive = (isActiveValue === 1);
                        }
                        console.log('Setting IsActive value:', isActiveValue, 'should be active:', shouldBeActive);
                        // 使用原生JavaScript设置选中状态
                        var radioButtons = document.getElementsByName('IsActive');
                        for (var i = 0; i < radioButtons.length; i++) {
                            var radio = radioButtons[i];
                            var shouldCheck = (radio.value === (shouldBeActive ? "1" : "0"));
                            console.log('Radio button value:', radio.value, 'should be checked:', shouldCheck);
                            radio.checked = shouldCheck;
                        }
                    } else if (settingId) {
                        // 通过AJAX获取时间段设置数据
                        $.ajax({
                            url: "/Task/GetTaskTimeById",
                            type: "post",
                            data: { id: settingId },
                            success: function (text) {
                                var result = mini.decode(text);
                                
                                // 检查数据格式并适配
                                if (result) {
                                    if (result.length > 0) {
                                        // 数组格式
                                        timeSettingData = result[0];
                                    } else if (result.SettingID) {
                                        // 对象格式
                                        timeSettingData = result;
                                    } else if (result.data && result.data.length > 0) {
                                        // 包含data属性的格式
                                        timeSettingData = result.data[0];
                                    }
                                    
                                    if (timeSettingData) {
                                        // 确保mini框架已初始化
                                        if (mini && mini.get) {
                                            // 设置SettingID（使用jQuery直接设置）
                                            $("#SettingID").val(timeSettingData.SettingID);
                                            mini.get("CategoryID").setValue(timeSettingData.CategoryID);
                                            mini.get("StartTime").setValue(timeSettingData.StartTime);
                                            mini.get("EndTime").setValue(timeSettingData.EndTime);
                                            
                                            // 处理单选按钮
                                            var isActiveValue = timeSettingData.IsActive != null ? timeSettingData.IsActive : true;
                                            // 确保正确处理各种数据类型
                                            var shouldBeActive = false;
                                            if (typeof isActiveValue === 'boolean') {
                                                shouldBeActive = isActiveValue;
                                            } else if (typeof isActiveValue === 'string') {
                                                shouldBeActive = (isActiveValue.toLowerCase() === 'true' || isActiveValue === '1');
                                            } else if (typeof isActiveValue === 'number') {
                                                shouldBeActive = (isActiveValue === 1);
                                            }
                                            console.log('Setting IsActive value (AJAX):', isActiveValue, 'should be active:', shouldBeActive);
                                            // 使用原生JavaScript设置选中状态
                                            var radioButtons = document.getElementsByName('IsActive');
                                            for (var i = 0; i < radioButtons.length; i++) {
                                                var radio = radioButtons[i];
                                                var shouldCheck = (radio.value === (shouldBeActive ? "1" : "0"));
                                                console.log('Radio button value (AJAX):', radio.value, 'should be checked:', shouldCheck);
                                                radio.checked = shouldCheck;
                                            }
                                        }
                                    }
                                }
                            }
                        });
                    }
                }
            }
        }
        
        // 加载任务分类列表
        function loadCategories() {
            $.ajax({
                url: "/Task/GetTaskCategoryList",
                type: "post",
                success: function (text) {
                    var result = mini.decode(text);
                    var categories = result && result.data ? result.data : (result && result.length > 0 ? result : []);
                    // 添加请选择选项
                    categories.unshift({ CategoryID: "", CategoryName: "请选择" });
                    mini.get("CategoryID").setData(categories);
                    
                    // 如果是编辑模式，重新设置选中值
                    if (action == "edit" && timeSettingData && timeSettingData.CategoryID) {
                        mini.get("CategoryID").setValue(timeSettingData.CategoryID);
                    }
                }
            });
        }
        
        // 保存时间段设置
        function saveTimeSetting() {
            form.validate();
            if (form.isValid() === false) return;
            
            var data = form.getData();
            
            // 添加SettingID到数据中
            data.SettingID = $("#SettingID").val();
            
            // 获取mini-combobox的值
            data.CategoryID = mini.get("CategoryID").getValue();
            
            // 获取单选按钮的值
            var isActiveValue = "0";
            console.log('Checking radio buttons:');
            $("input[name='IsActive']").each(function() {
                console.log('Radio button value:', $(this).val(), 'checked:', $(this).prop("checked"));
                if ($(this).prop("checked")) {
                    isActiveValue = $(this).val();
                    console.log('Selected value:', isActiveValue);
                }
            });
            data.IsActive = isActiveValue;
            console.log('Final IsActive value:', isActiveValue);
            
            var json = mini.encode(data);
            
            $.ajax({
                url: "/Task/SaveTaskTime",
                type: "post",
                data: { send: json },
                success: function (text) {
                    var result = mini.decode(text);
                    if (result.state == "1" || result.state == 1) {
                        mini.alert("保存成功");
                        CloseWindow("ok");
                    } else {
                        mini.alert(result.msg || "保存失败");
                    }
                },
                error: function () {
                    mini.alert("网络错误");
                }
            });
        }
        
        function cancel() {
            CloseWindow();
        }
        
        function CloseWindow(action) {
            if (window.CloseOwnerWindow) {
                window.CloseOwnerWindow(action);
            } else {
                window.parent.CloseWindow(action);
            }
        }
    </script>
</head>
<body>
    <div class="form-container">
        <h2 style="text-align: center; margin-bottom: 20px;">新增/编辑时间段设置</h2>
        <form id="form1">
            <input type="hidden" id="SettingID" name="SettingID" />
            
            <div class="form-item">
                <label class="form-label">任务分类：</label>
                <select id="CategoryID" name="CategoryID" class="mini-combobox" displayField="CategoryName" valueField="CategoryID"></select>
            </div>
            
            <div class="form-item">
                <label class="form-label">开始时间：</label>
                <input id="StartTime" name="StartTime" class="mini-textbox" placeholder="HH:MM" required="true" />
            </div>
            
            <div class="form-item">
                <label class="form-label">结束时间：</label>
                <input id="EndTime" name="EndTime" class="mini-textbox" placeholder="HH:MM" required="true" />
            </div>
            
            <div class="form-item">
                <label class="form-label">状态：</label>
                <div style="display: inline-block; width: 400px;">
                    <label style="margin-right: 20px;">
                        <input type="radio" id="IsActive1" name="IsActive" value="1" checked /> 启用
                    </label>
                    <label>
                        <input type="radio" id="IsActive0" name="IsActive" value="0" /> 禁用
                    </label>
                </div>
            </div>
            
            <div class="button-container">
                <a class="mini-button" onclick="saveTimeSetting()">保存</a>
                <a class="mini-button" onclick="cancel()">取消</a>
            </div>
        </form>
    </div>
</body>
</html>