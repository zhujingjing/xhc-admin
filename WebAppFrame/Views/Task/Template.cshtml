

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8" />
    <title>任务模板管理</title>
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=100"></script>
    <style type="text/css">
        body {
            font-family: tahoma, arial, sans-serif;
            font-size: 12px;
        }
        .font-bold {
            font-weight: bold;
        }
        .right {
            display: flex;
            justify-content: flex-end;
            align-items: center;
        }
        .left {
            display: flex;
            justify-content: flex-start;
            align-items: center;
        }
    </style>
    <script type="text/javascript">
        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent).height();
            $("#grid1").height(parentHeight - 120);

            mini.parse();

            grid = mini.get("grid1");

            init();

            // 加载任务分类
            loadCategories();
            // 加载模板数据
            loadData();
        })

        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#grid1").height(parentHeight - 110);
        }



        // 渲染优先级
        function renderPriority(e) {
            var value = e.value;
            if (value == 0) return "低";
            if (value == 1) return "中";
            if (value == 2) return "高";
            return value;
        }

        // 渲染执行周期
        function renderExecutionCycle(e) {
            var value = e.value;
            if (value == 0) return "一次性";
            if (value == 1) return "每天";
            if (value == 2) return "每周";
            if (value == 3) return "每月";
            return value;
        }

        // 渲染状态
        function renderIsActive(e) {
            var value = e.value;
            return value ? "启用" : "禁用";
        }

        // 渲染操作按钮
        function renderAction(e) {
            var record = e.record;
            var templateId = record.TemplateID;
            return '<a href="javascript:editTemplate(\'' + templateId + '\')" style="color:green;">编辑</a> | <a href="javascript:deleteTemplate(\'' + templateId + '\')" style="color:red;">删除</a>';
        }

        // 加载任务分类
        function loadCategories() {
            $.ajax({
                url: "/Task/GetTaskCategoryList",
                type: "post",
                success: function (text) {
                    var result = mini.decode(text);
                    mini.get("categoryId").setData(result.data);
                }
            });
        }

        // 加载数据
        function loadData() {
            var templateNameValue = mini.get("templateName").getValue();
            var categoryIdValue = mini.get("categoryId").getValue();
            
            grid.load({
                url: "/Task/GetTaskTemplateList",
                params: {
                    templateName: templateNameValue,
                    categoryId: categoryIdValue
                }
            });
        }

        // 搜索
        function search() {
            loadData();
        }

        // 新增模板
        function addTemplate() {
            var win = mini.open({
                url: "/Task/TemplateAdd",
                title: "新增任务模板",
                width: 800,
                height: 650,
                onload: function () {
                    var iframe = this.getIFrameEl();
                    var data = { action: "new", operator: getCurrentOperator() };
                    iframe.contentWindow.SetData(data);
                },
                ondestroy: function (action) {
                    if (action == "ok") {
                        loadData();
                    }
                }
            });
        }

        // 编辑模板
        function editTemplate(templateId) {
            var win = mini.open({
                url: "/Task/TemplateAdd?id=" + templateId,
                title: "编辑任务模板",
                width: 800,
                height: 650,
                onload: function () {
                    var iframe = this.getIFrameEl();
                    var data = { action: "edit", templateId: templateId, operator: getCurrentOperator() };
                    iframe.contentWindow.SetData(data);
                },
                ondestroy: function (action) {
                    if (action == "ok") {
                        loadData();
                    }
                }
            });
        }

        // 删除模板
        function deleteTemplate(templateId) {
            mini.confirm("确定要删除该模板吗？", "提示", function (action) {
                if (action == "ok") {
                    $.ajax({
                        url: "/Task/DeleteTaskTemplate",
                        type: "post",
                        data: { id: templateId },
                        success: function (text) {
                            var result = mini.decode(text);
                            if (result.state == "1" || result.state == 1) {
                                mini.alert("删除成功");
                                loadData();
                            } else {
                                mini.alert(result.msg || "删除失败");
                            }
                        },
                        error: function () {
                            mini.alert("网络错误");
                        }
                    });
                }
            });
        }
    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">任务管理</a></li>
            <li><a href="#">任务模板管理</a></li>
        </ul>
    </div>
    <form id="form1">
        <div class="sys-content-border" style="padding:8px 3px;">
            模板名称: 
            <input id="templateName" class="mini-textbox" style="width:200px;" placeholder="模板名称" />
            &nbsp;&nbsp;&nbsp;&nbsp;
            任务分类: 
            <select id="categoryId" class="mini-combobox" style="width:150px;" placeholder="任务分类"></select>
            &nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_search" type="button" class="sys-btn" value="搜索" onclick="search()" style="background-color: #E3F2FD; color: #1976D2;" />
            &nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_add" type="button" class="sys-btn" value="新增模板" onclick="addTemplate()" style="background-color: #E8F5E9; color: #388E3C;" />
        </div>
        <div id="grid1" class="mini-datagrid" style="width:100%; margin-top:5px;" url="/Task/GetTaskTemplateList" idfield="TemplateID" allowresize="true"
             sizelist="[50,100,200]" pagesize="50">
            <div property="columns">
                <div type="checkcolumn" width="30"></div>
                <div field="TemplateID" width="0" visible="false"></div>
                <div field="TemplateName" width="200" header="模板名称" allowSort="true"></div>
                <div field="CategoryName" width="150" header="分类" allowSort="true"></div>
                <div field="Description" width="300" header="模板描述"></div>
                <div field="Priority" width="80" header="优先级" allowSort="true" renderer="renderPriority"></div>
                <div field="StandardScore" width="100" header="标准分" allowSort="true"></div>
                <div field="ExecutionCycle" width="100" header="执行周期" allowSort="true" renderer="renderExecutionCycle"></div>
                <div field="IsActive" width="80" header="状态" allowSort="true" renderer="renderIsActive"></div>
                <div field="CreateTime" width="180" header="创建时间" allowSort="true" dateFormat="yyyy-MM-dd HH:mm:ss"></div>
                <div field="action" width="150" header="操作" align="center" renderer="renderAction"></div>
            </div>
        </div>
    </form>
</body>
</html>