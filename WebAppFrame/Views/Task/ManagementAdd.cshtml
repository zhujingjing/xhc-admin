

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8" />
    <title>新增/编辑任务</title>
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/Style_chart.css" rel="stylesheet" />
    <link href="~/Styles/public.css" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=100"></script>
    <style type="text/css">
        body {
            font-family: tahoma, arial, sans-serif;
            font-size: 12px;
            margin: 5px;
        }
        .form-container {
            width: 600px;
            margin: 0 auto;
            padding: 20px;
            border: 1px solid #ccc;
            border-radius: 5px;
            background-color: #f9f9f9;
        }
        .form-item {
            margin-bottom: 15px;
        }
        .form-label {
            display: inline-block;
            width: 100px;
            text-align: right;
            margin-right: 10px;
            font-weight: bold;
        }
        .mini-textbox, .mini-combobox, .mini-textarea, .mini-datepicker {
            width: 400px;
            border: 1px solid #b3d9ff;
            border-radius: 3px;
        }
        .mini-textbox {
            height: 35px;
        }
        .mini-textarea {
            height: 80px;
        }
        .button-container {
            display: flex;
            justify-content: flex-end;
            margin-top: 20px;
            width: 510px;
        }
        .mini-button {
            width: 100px;
            margin-left: 10px;
            text-align: center;
            padding: 8px 0;
        }
    </style>
    <script type="text/javascript">
        var form;
        var action = "new";
        var taskData = null;
        var taskId = null;

        $(function () {
            mini.parse();
            form = new mini.Form("taskForm");
            
            // 初始化加载
            loadCategories();
            loadTemplates();
        });



        // 设置数据
        function SetData(data) {
            if (data) {
                action = data.action || "new";
                taskData = data.task;
                window.taskId = data.taskId;
                
                // 更新页面标题
                if (action == "edit") {
                    document.getElementById("pageTitle").innerHTML = "编辑任务";
                } else {
                    document.getElementById("pageTitle").innerHTML = "新增任务";
                }
                
                if (action == "edit" && (taskData || window.taskId)) {
                    if (taskData) {
                        mini.get("TaskID").setValue(taskData.TaskID);
                        mini.get("TaskName").setValue(taskData.TaskName);
                        mini.get("CategoryID").setValue(taskData.CategoryID);
                        mini.get("TemplateID").setValue(taskData.TemplateID || "");
                        mini.get("Description").setValue(taskData.Description || "");
                        mini.get("AssignedTo").setValue(taskData.AssignedTo);
                        mini.get("Priority").setValue(taskData.Priority);
                        mini.get("StandardScore").setValue(taskData.StandardScore);
                        if (taskData.Deadline) {
                            mini.get("Deadline").setValue(new Date(taskData.Deadline));
                        }
                        mini.get("Creator").setValue(taskData.Creator);
                    } else if (window.taskId) {
                        // 通过AJAX获取任务数据
                        $.ajax({
                            url: "/Task/GetTaskById",
                            type: "post",
                            data: { id: window.taskId },
                            success: function (text) {
                                var result = mini.decode(text);
                                
                                // 检查数据格式并适配
                                if (result) {
                                    if (result.length > 0) {
                                        // 数组格式
                                        taskData = result[0];
                                    } else if (result.TaskID) {
                                        // 对象格式
                                        taskData = result;
                                    } else if (result.data && result.data.length > 0) {
                                        // 包含data属性的格式
                                        taskData = result.data[0];
                                    }
                                    
                                    if (taskData) {
                                        // 确保mini框架已初始化
                                        if (mini && mini.get) {
                                            // 检查每个控件是否存在
                                            var taskIDControl = mini.get("TaskID");
                                            var taskNameControl = mini.get("TaskName");
                                            var categoryIDControl = mini.get("CategoryID");
                                            var templateIDControl = mini.get("TemplateID");
                                            var descriptionControl = mini.get("Description");
                                            var assignedToControl = mini.get("AssignedTo");
                                            var priorityControl = mini.get("Priority");
                                            var standardScoreControl = mini.get("StandardScore");
                                            var deadlineControl = mini.get("Deadline");
                                            var creatorControl = mini.get("Creator");
                                            
                                            // 只有当控件存在时才设置值
                                            if (taskIDControl) taskIDControl.setValue(taskData.TaskID);
                                            if (taskNameControl) taskNameControl.setValue(taskData.TaskName);
                                            if (categoryIDControl) categoryIDControl.setValue(taskData.CategoryID);
                                            if (templateIDControl) templateIDControl.setValue(taskData.TemplateID || "");
                                            if (descriptionControl) descriptionControl.setValue(taskData.Description || "");
                                            if (assignedToControl) assignedToControl.setValue(taskData.AssignedTo);
                                            if (priorityControl) priorityControl.setValue(taskData.Priority);
                                            if (standardScoreControl) standardScoreControl.setValue(taskData.StandardScore);
                                            if (deadlineControl && taskData.Deadline) deadlineControl.setValue(new Date(taskData.Deadline));
                                            if (creatorControl) creatorControl.setValue(taskData.Creator);
                                            

                                        }
                                    } else {
                                    }
                                }
                            },
                            error: function (xhr, status, error) {
                            }
                        });
                    }
                } else {
                    // 新增
                    mini.get("Creator").setValue(getCurrentOperator());
                }
            }
        }

        // 加载任务分类
        function loadCategories() {
            $.ajax({
                url: "/Task/GetTaskCategoryList",
                type: "post",
                success: function (text) {
                    var result = mini.decode(text);
                    var categories = result && result.data ? result.data : (result && result.length > 0 ? result : []);
                    mini.get("CategoryID").setData(categories);
                }
            });
        }

        // 加载任务模板
        function loadTemplates() {
            $.ajax({
                url: "/Task/GetTaskTemplateList",
                type: "post",
                success: function (text) {
                    var result = mini.decode(text);
                    var templates = result && result.data ? result.data : (result && result.length > 0 ? result : []);
                    // 添加请选择选项
                    templates.unshift({ TemplateID: "", TemplateName: "请选择" });
                    mini.get("TemplateID").setData(templates);
                }
            });
        }

        // 保存任务


        function saveTask() {
            form.validate();
            if (form.isValid() === false) return;

            var formData = form.getData();
            
            // 确保编辑时TaskID正确传递
            if (action == "edit" && window.taskId) {
                formData.TaskID = window.taskId;
            }
            
            // 处理日期字段
            var deadline = mini.get("Deadline").getValue();
            if (deadline) {
                formData.Deadline = deadline.toISOString().slice(0, 19).replace('T', ' ');
            } else {
                formData.Deadline = null;
            }
            
            // 添加操作人信息
            formData.Operator = getCurrentOperator();

            $.ajax({
                url: "/Task/SaveTask",
                type: "post",
                data: { send: JSON.stringify(formData) },
                success: function (text) {
                    var result = mini.decode(text);
                    if (result.state == "1" || result.state == 1) {
                        mini.alert("保存成功");
                        window.CloseOwnerWindow("ok");
                    } else {
                        mini.alert(result.msg || "保存失败");
                    }
                },
                error: function () {
                    mini.alert("网络错误");
                }
            });
        }

        // 取消
        function cancel() {
            window.CloseOwnerWindow("cancel");
        }

        function CloseWindow(action) {
            if (window.CloseOwnerWindow) {
                window.CloseOwnerWindow(action);
            } else {
                window.parent.CloseWindow(action);
            }
        }
    </script>
</head>
<body>
    <div class="form-container">
        <h2 style="text-align: center; margin-bottom: 20px;"><span id="pageTitle">新增任务</span></h2>
        <form id="taskForm">
            <input type="hidden" id="TaskID" name="TaskID" />
            
            <div class="form-item">
                <label class="form-label">任务名称:</label>
                <input id="TaskName" name="TaskName" class="mini-textbox" required="true" />
            </div>
            
            <div class="form-item">
                <label class="form-label">任务分类:</label>
                <select id="CategoryID" name="CategoryID" class="mini-combobox" required="true" displayField="CategoryName" valueField="CategoryID"></select>
            </div>
            
            <div class="form-item">
                <label class="form-label">任务模板:</label>
                <select id="TemplateID" name="TemplateID" class="mini-combobox" displayField="TemplateName" valueField="TemplateID"></select>
            </div>
            
            <div class="form-item">
                <label class="form-label">任务描述:</label>
                <textarea id="Description" name="Description" class="mini-textarea" rows="3"></textarea>
            </div>
            
            <div class="form-item">
                <label class="form-label">分配人:</label>
                <input id="AssignedTo" name="AssignedTo" class="mini-textbox" required="true" />
            </div>
            
            <div class="form-item">
                <label class="form-label">优先级:</label>
                <select id="Priority" name="Priority" class="mini-combobox">
                    <option value="0">低</option>
                    <option value="1">中</option>
                    <option value="2">高</option>
                </select>
            </div>
            
            <div class="form-item">
                <label class="form-label">标准分:</label>
                <input id="StandardScore" name="StandardScore" class="mini-textbox" value="100" min="0" step="0.01" />
            </div>
            
            <div class="form-item">
                <label class="form-label">截止时间:</label>
                <input id="Deadline" name="Deadline" class="mini-datepicker" format="yyyy-MM-dd HH:mm:ss" />
            </div>
            
            <div class="form-item">
                <label class="form-label">创建人:</label>
                <input id="Creator" name="Creator" class="mini-textbox" readonly="true" />
            </div>
            
            <div class="button-container">
                <a class="mini-button" onclick="saveTask()">保存</a>
                <a class="mini-button" onclick="cancel()">取消</a>
            </div>
        </form>
    </div>
</body>
</html>