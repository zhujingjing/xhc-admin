<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8" />
    <title>任务审核</title>
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/Style_chart.css" rel="stylesheet" />
    <link href="~/Styles/public.css" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=100"></script>
    <style type="text/css">
        body {
            font-family: tahoma, arial, sans-serif;
            font-size: 12px;
            margin: 5px;
        }
        .form-container {
            width: 700px;
            margin: 0 auto;
            padding: 20px;
            border: 1px solid #ccc;
            border-radius: 5px;
            background-color: #f9f9f9;
        }
        .form-item {
            margin-bottom: 15px;
        }
        .form-label {
            display: inline-block;
            width: 100px;
            text-align: right;
            margin-right: 10px;
            font-weight: bold;
        }
        .form-value {
            display: inline-block;
            width: 550px;
            word-break: break-word;
        }
        .mini-textbox, .mini-combobox, .mini-textarea, .mini-datepicker {
            width: 550px;
            border: 1px solid #b3d9ff;
            border-radius: 3px;
        }
        .mini-textbox {
            height: 35px;
        }
        .mini-textarea {
            height: 100px;
        }
        .button-container {
            display: flex;
            justify-content: flex-end;
            margin-top: 20px;
            width: 660px;
        }
        .mini-button {
            width: 100px;
            margin-left: 10px;
            text-align: center;
            padding: 8px 0;
        }
        .audit-section {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #ddd;
        }
        .audit-section h3 {
            margin-bottom: 20px;
            color: #333;
        }
    </style>
    <script type="text/javascript">
        var taskId;
        
        // 获取URL参数
        function getUrlParam() {
            var params = {};
            var url = window.location.href;
            var index = url.indexOf('?');
            if (index > -1) {
                var paramStr = url.substring(index + 1);
                var paramArr = paramStr.split('&');
                for (var i = 0; i < paramArr.length; i++) {
                    var item = paramArr[i].split('=');
                    params[item[0]] = unescape(item[1]);
                }
            }
            return params;
        }
        

        
        $(function () {
            mini.parse();
            
            // 获取任务ID
            var urlParams = getUrlParam();
            taskId = urlParams.id || "";
            
            if (taskId) {
                // 加载任务信息
                loadTaskInfo();
            }
        });
        
        // 设置数据
        function SetData(data) {
            if (data && data.taskId) {
                taskId = data.taskId;
                loadTaskInfo();
            }
        }
        
        // 加载任务信息
        function loadTaskInfo() {
            if (!taskId) return;
            
            $.ajax({
                url: "/Task/GetTaskById",
                type: "post",
                data: { id: taskId },
                success: function (text) {
                    var result = mini.decode(text);
                    
                    // 检查数据格式并适配
                    var taskData = null;
                    if (result && result.data && result.data.length > 0) {
                        // 包含data属性的格式
                        taskData = result.data[0];
                    } else if (result && result.length > 0) {
                        // 直接返回数组格式
                        taskData = result[0];
                    } else if (result && result.TaskID) {
                        // 直接返回对象格式
                        taskData = result;
                    }
                    
                    if (taskData) {
                        // 填充任务信息
                        $("#TaskName").text(taskData.TaskName || "");
                        $("#CategoryName").text(taskData.CategoryName || "");
                        $("#TemplateName").text(taskData.TemplateName || "");
                        $("#AssignedTo").text(taskData.AssignedTo || "");
                        $("#Priority").text(taskData.Priority === "0" ? "低" : (taskData.Priority === "1" ? "中" : "高"));
                        $("#StandardScore").text(taskData.StandardScore || "");
                        $("#Description").text(taskData.Description || "");
                        $("#StartTime").text(formatDate(taskData.StartTime));
                        $("#EndTime").text(formatDate(taskData.EndTime));
                        $("#Deadline").text(formatDate(taskData.Deadline));
                        $("#CreateTime").text(formatDate(taskData.CreateTime));
                    } else {
                        mini.alert("未找到任务信息");
                    }
                },
                error: function () {
                    mini.alert("网络错误");
                }
            });
        }
        
        // 保存审核结果
        function saveAudit() {
            if (!taskId) {
                mini.alert("任务ID不能为空");
                return;
            }
            
            // 获取审核结果
            var auditResult = $(".audit-result:checked").val() === "true";
            
            // 获取审核意见
            var auditOpinion = mini.get("AuditOpinion").getValue();
            
            // 获取审核得分
            var auditScore = mini.get("AuditScore").getValue() || 0;
            
            // 获取审核人
            var auditor = getCurrentOperator();
            
            $.ajax({
                url: "/Task/SaveTaskAudit",
                type: "post",
                data: {
                    taskId: taskId,
                    auditor: auditor,
                    auditResult: auditResult,
                    auditOpinion: auditOpinion,
                    auditScore: auditScore
                },
                success: function (text) {
                    var result = mini.decode(text);
                    if (result.state == "1" || result.state == 1) {
                        mini.alert("审核成功");
                        CloseWindow("ok");
                    } else {
                        mini.alert(result.msg || "审核失败");
                    }
                },
                error: function () {
                    mini.alert("网络错误");
                }
            });
        }
        
        function cancel() {
            CloseWindow();
        }
        
        function CloseWindow(action) {
            if (window.CloseOwnerWindow) {
                window.CloseOwnerWindow(action);
            } else {
                window.parent.CloseWindow(action);
            }
        }
    </script>
</head>
<body>
    <div class="form-container">
        <h2 style="text-align: center; margin-bottom: 20px;">任务审核</h2>
        
        <!-- 任务信息 -->
        <div class="form-item">
            <span class="form-label">任务名称：</span>
            <span class="form-value" id="TaskName"></span>
        </div>
        
        <div class="form-item">
            <span class="form-label">任务分类：</span>
            <span class="form-value" id="CategoryName"></span>
        </div>
        
        <div class="form-item">
            <span class="form-label">任务模板：</span>
            <span class="form-value" id="TemplateName"></span>
        </div>
        
        <div class="form-item">
            <span class="form-label">分配人：</span>
            <span class="form-value" id="AssignedTo"></span>
        </div>
        
        <div class="form-item">
            <span class="form-label">优先级：</span>
            <span class="form-value" id="Priority"></span>
        </div>
        
        <div class="form-item">
            <span class="form-label">标准分：</span>
            <span class="form-value" id="StandardScore"></span>
        </div>
        
        <div class="form-item">
            <span class="form-label">任务描述：</span>
            <span class="form-value" id="Description"></span>
        </div>
        
        <div class="form-item">
            <span class="form-label">开始时间：</span>
            <span class="form-value" id="StartTime"></span>
        </div>
        
        <div class="form-item">
            <span class="form-label">结束时间：</span>
            <span class="form-value" id="EndTime"></span>
        </div>
        
        <div class="form-item">
            <span class="form-label">截止时间：</span>
            <span class="form-value" id="Deadline"></span>
        </div>
        
        <div class="form-item">
            <span class="form-label">创建时间：</span>
            <span class="form-value" id="CreateTime"></span>
        </div>
        
        <!-- 审核部分 -->
        <div class="audit-section">
            <h3>审核信息</h3>
            
            <div class="form-item">
                <span class="form-label">审核结果：</span>
                <div style="display: inline-block; width: 550px;">
                    <label style="margin-right: 20px;">
                        <input type="radio" class="audit-result" name="AuditResult" value="true" checked /> 通过
                    </label>
                    <label>
                        <input type="radio" class="audit-result" name="AuditResult" value="false" /> 拒绝
                    </label>
                </div>
            </div>
            
            <div class="form-item">
                <span class="form-label">审核得分：</span>
                <input id="AuditScore" name="AuditScore" class="mini-textbox" placeholder="请输入审核得分，不输入则使用系统计算得分" />
            </div>
            
            <div class="form-item">
                <span class="form-label">审核意见：</span>
                <textarea id="AuditOpinion" name="AuditOpinion" class="mini-textarea" placeholder="请输入审核意见"></textarea>
            </div>
        </div>
        
        <div class="button-container">
            <a class="mini-button" onclick="saveAudit()">保存</a>
            <a class="mini-button" onclick="cancel()">取消</a>
        </div>
    </div>
</body>
</html>