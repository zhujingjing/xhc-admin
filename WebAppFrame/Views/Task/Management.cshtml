﻿
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8" />
    <title>任务管理</title>
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=100"></script>
    <style type="text/css">
        body {
            font-family: tahoma, arial, sans-serif;
            font-size: 12px;
        }
        .font-bold {
            font-weight: bold;
        }
        .right {
            display: flex;
            justify-content: flex-end;
            align-items: center;
        }
        .left {
            display: flex;
            justify-content: flex-start;
            align-items: center;
        }
    </style>
    <script type="text/javascript">
        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#grid1").height(parentHeight - 120);

            mini.parse();

            grid = mini.get("grid1");

            init();

            // 设置截止时间默认值为当天
            var today = new Date();
            var formattedDate = today.toISOString().split('T')[0];
            document.getElementById("timeFilter").value = formattedDate;

            // 加载任务分类
            loadCategories();
            // 加载任务数据
            loadData();
        })

        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#grid1").height(parentHeight - 120);
        }



        // 渲染优先级
        function renderPriority(e) {
            var value = e.value;
            if (value == 0) return '<span style="color: black;">低</span>';
            if (value == 1) return '<span style="color: orange;">中</span>';
            if (value == 2) return '<span style="color: red;">高</span>';
            return value;
        }

        // 渲染状态
        function renderStatus(e) {
            var value = e.value;
            if (value == 0) return '<span style="color: red;">待处理</span>';
            if (value == 1) return '<span style="color: orange;">处理中</span>';
            if (value == 2) return '<span style="color: blue;">已完成</span>';
            if (value == 3) return '<span style="color: green;">已审核</span>';
            return value;
        }

        // 渲染任务名称，添加点击事件
        function renderTaskName(e) {
            var record = e.record;
            var taskId = record.TaskID;
            var taskName = record.TaskName;
            return '<a href="javascript:viewTask(\'' + taskId + '\')" style="color: blue; text-decoration: underline; cursor: pointer;">' + taskName + '</a>';
        }

        // 渲染操作按钮
        function renderAction(e) {
            var record = e.record;
            var taskId = record.TaskID;
            return '<a href="javascript:editTask(\'' + taskId + '\')" style="color:green;">编辑</a> | <a href="javascript:deleteTask(\'' + taskId + '\')" style="color:red;">删除</a> | <a href="javascript:viewTask(\'' + taskId + '\')" style="color:black;">详情</a>';
        }

        // 渲染序号
        function renderIndex(e) {
            return e.rowIndex + 1;
        }

        // 渲染状态（带进度条）
        function renderStatus(e) {
            var value = e.value;
            var statusText = '';
            if (value == 0) statusText = '<span style="color: red;">待处理</span>';
            else if (value == 1) statusText = '<span style="color: orange;">处理中</span>';
            else if (value == 2) statusText = '<span style="color: blue;">已完成</span>';
            else if (value == 3) statusText = '<span style="color: green;">已审核</span>';
            else statusText = value;
            
            // 只有待处理和处理中的任务显示剩余时间和进度条
            if (value == 0 || value == 1) {
                var record = e.record;
                var deadline = record.Deadline;
                if (deadline) {
                    var now = new Date();
                    var deadlineDate = new Date(deadline);
                    var totalTime = deadlineDate.getTime() - now.getTime();
                    
                    // 计算剩余时间（分钟）
                    var minutes = Math.round(totalTime / (1000 * 60));
                    var timeText = '';
                    if (minutes <= 0) {
                        timeText = '<span style="font-size: 10px; color: red; float: right;">超' + Math.abs(minutes) + '分钟</span>';
                    } else {
                        timeText = '<span style="font-size: 10px; color: green; float: right;">剩' + minutes + '分钟</span>';
                    }
                    
                    // 只有待处理和处理中的任务显示进度条
                    var progressBar = '';
                    if (totalTime <= 0) {
                        progressBar = '<div style="width: 100%; height: 8px; background-color: #f0f0f0;  margin-top: 4px;">' +
                                   '<div style="width: 100%; height: 100%; background-color: #ff4d4f;  text-align: center; line-height: 8px; font-size: 6px; color: white;">100%</div>' +
                                   '</div>';
                    } else {
                        var createTime = record.CreateTime;
                        var createDate = new Date(createTime);
                        var totalDuration = deadlineDate.getTime() - createDate.getTime();
                        var passedTime = now.getTime() - createDate.getTime();
                        var passedPercentage = Math.min(100, Math.max(0, (passedTime / totalDuration) * 100));
                        var remainingPercentage = 100 - passedPercentage;
                        
                        progressBar = '<div style="width: 100%; height: 8px; background-color: #f0f0f0;  position: relative; margin-top: 4px;">' +
                                   '<div style="width: ' + passedPercentage + '%; height: 100%; background-color: #ff4d4f;  position: absolute; left: 0; top: 0;"></div>' +
                                   '<div style="width: ' + remainingPercentage + '%; height: 100%; background-color: #52c41a;  position: absolute; right: 0; top: 0;"></div>' +
                                   '<div style="position: absolute; left: 0; right: 0; top: 0; bottom: 0; text-align: center; line-height: 8px; font-size: 6px; color: white; text-shadow: 1px 1px 1px rgba(0,0,0,0.5);">' + Math.round(passedPercentage) + '%</div>' +
                                   '</div>';
                    }
                    return '<div>' + statusText + timeText + progressBar + '</div>';
                }
            }
            
            return statusText;
        }

        // 渲染创建时间（分两行显示）
        function renderCreateTime(e) {
            var value = e.value;
            if (!value) return '';
            var date = new Date(value);
            var dateStr = date.toLocaleDateString('zh-CN');
            var timeStr = date.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
            return '<div style="text-align: center;"><div>' + dateStr + '</div><div>' + timeStr + '</div></div>';
        }

        // 渲染截止时间（分两行显示）
        function renderDeadline(e) {
            var value = e.value;
            if (!value) return '';
            var date = new Date(value);
            var dateStr = date.toLocaleDateString('zh-CN');
            var timeStr = date.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
            return '<div style="text-align: center;"><div>' + dateStr + '</div><div>' + timeStr + '</div></div>';
        }

        // 渲染开始时间（分两行显示）
        function renderStartTime(e) {
            var value = e.value;
            if (!value) return '';
            var date = new Date(value);
            var dateStr = date.toLocaleDateString('zh-CN');
            var timeStr = date.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
            return '<div style="text-align: center;"><div>' + dateStr + '</div><div>' + timeStr + '</div></div>';
        }

        // 渲染完成时间（分两行显示）
        function renderCompleteTime(e) {
            var value = e.value;
            if (!value) return '';
            var date = new Date(value);
            var dateStr = date.toLocaleDateString('zh-CN');
            var timeStr = date.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
            
            // 检查是否超时
            var record = e.record;
            var deadline = record.Deadline;
            var isOverdue = false;
            if (deadline) {
                var deadlineDate = new Date(deadline);
                isOverdue = date > deadlineDate;
            }
            
            var color = isOverdue ? 'red' : 'black';
            return '<div style="text-align: center; color: ' + color + ';"><div>' + dateStr + '</div><div>' + timeStr + '</div></div>';
        }

        // 渲染外部链接
        function renderExternalUrl(e) {
            var record = e.record;
            var fullExternalUrl = record.FullExternalUrl;
            if (fullExternalUrl) {
                return '<a href="' + fullExternalUrl + '" target="_blank" style="color: #409eff; text-decoration: underline; cursor: pointer;">访问链接</a>';
            }
            return '';
        }

        // 渲染实际得分，根据与标准得分的关系显示不同颜色
        function renderActualScore(e) {
            var actualScore = e.value || 0;
            var standardScore = e.record.StandardScore || 0;
            var color = actualScore >= standardScore ? 'green' : 'red';
            return '<span style="color: ' + color + '; font-weight: bold;">' + actualScore + '</span>';
        }

        // 汇总行渲染函数
        function summaryRenderer(e) {
            var field = e.field;
            var value = e.value;
            return value.toFixed(2);
        }

        // 加载任务分类
        function loadCategories() {
            $.ajax({
                url: "/Task/GetTaskCategoryList",
                type: "post",
                success: function (text) {
                    var result = mini.decode(text);
                    if (result.data) {
                        var categories = mini.decode(result.data);
                        
                        // 加载到分类下拉框
                        var categorySelect = document.getElementById("categoryFilter");
                        categorySelect.innerHTML = '<option value="">全部分类</option>';
                        for (var i = 0; i < categories.length; i++) {
                            var option = document.createElement("option");
                            option.value = categories[i].CategoryID;
                            option.text = categories[i].CategoryName;
                            categorySelect.appendChild(option);
                        }
                    }
                }
            });
        }

        // 加载数据
        function loadData() {
            var status = document.getElementById("statusFilter").value || "";
            var priority = document.getElementById("priorityFilter").value || "";
            var categoryId = document.getElementById("categoryFilter").value || "";
            var assignedTo = document.getElementById("assignedToFilter").value || "";
            var timeFilter = document.getElementById("timeFilter").value || "";
            
            grid.load({
                status: status,
                priority: priority,
                categoryId: categoryId,
                assignedTo: assignedTo,
                timeFilter: timeFilter
            });
        }

        // 搜索
        function search() {
            loadData();
        }

        // 新增任务
        function addTask() {
            var win = mini.open({
                url: "/Task/ManagementAdd",
                title: "新增任务",
                width: 800,
                height: 650,
                onload: function () {
                    var iframe = this.getIFrameEl();
                    var data = { action: "new" };
                    iframe.contentWindow.SetData(data);
                },
                ondestroy: function (action) {
                    if (action == "ok") {
                        loadData();
                    }
                }
            });
        }

        // 编辑任务
        function editTask(taskId) {
            var win = mini.open({
                url: "/Task/ManagementAdd?id=" + taskId,
                title: "编辑任务",
                width: 800,
                height: 650,
                onload: function () {
                    var iframe = this.getIFrameEl();
                    var data = { action: "edit", taskId: taskId };
                    iframe.contentWindow.SetData(data);
                },
                ondestroy: function (action) {
                    if (action == "ok") {
                        loadData();
                    }
                }
            });
        }

        // 删除任务
        function deleteTask(taskId) {
            mini.confirm("确定要删除该任务吗？", "提示", function (action) {
                if (action == "ok") {
                    $.ajax({
                        url: "/Task/DeleteTask",
                        type: "post",
                        data: { id: taskId },
                        success: function (text) {
                            var result = mini.decode(text);
                            if (result.state == "1" || result.state == 1) {
                                mini.alert("删除成功");
                                loadData();
                            } else {
                                mini.alert(result.msg || "删除失败");
                            }
                        },
                        error: function () {
                            mini.alert("网络错误");
                        }
                    });
                }
            });
        }

        // 查看任务
        function viewTask(taskId) {
            var win = mini.open({
                url: "/Task/Detail?id=" + taskId,
                title: "任务详情",
                width: window.innerWidth - 40,
                height: window.innerHeight - 40,
                showMaxButton: true,
                showMinButton: true,
                showCloseButton: true,
                ondestroy: function (action) {
                    if (action == "ok") {
                        loadData();
                    }
                }
            });
        }

        // 批量操作
        function batchOperation() {
            var rows = grid.getSelecteds();
            if (rows.length == 0) {
                mini.alert("请选择要操作的任务");
                return;
            }

            // 创建自定义弹窗
            var html = '<div style="padding: 20px;">' +
                '<h4 style="margin-bottom: 15px;">请选择操作类型：</h4>' +
                '<div style="margin-bottom: 10px;">' +
                '<input type="radio" name="operationType" value="1" checked> 开始任务<br/>' +
                '<input type="radio" name="operationType" value="2"> 完成任务' +
                '</div>' +
                '<div style="text-align: right; margin-top: 20px;">' +
                '<button id="btnOk" style="margin-right: 10px; padding: 5px 15px; background-color: #E3F2FD; color: #1976D2; border: 1px solid #BBDEFB; cursor: pointer;">确定</button>' +
                '<button id="btnCancel" style="padding: 5px 15px; background-color: #FFF; color: #333; border: 1px solid #DDD; cursor: pointer;">取消</button>' +
                '</div>' +
                '</div>';

            var win = mini.open({
                title: "批量操作",
                width: 300,
                height: 250,
                showCloseButton: true,
                showMaxButton: false,
                showMinButton: false,
                url: "about:blank",
                onload: function () {
                    var iframe = this.getIFrameEl();
                    iframe.contentDocument.body.innerHTML = html;
                    
                    // 绑定事件
                    iframe.contentDocument.getElementById("btnOk").onclick = function() {
                        var operationType = iframe.contentDocument.querySelector('input[name="operationType"]:checked').value;
                        var status = operationType == "1" ? 1 : 2;
                        var ids = [];
                        for (var i = 0; i < rows.length; i++) {
                            ids.push(rows[i].TaskID);
                        }
                        var operatorName = getCurrentOperator();

                        $.ajax({
                            url: "/Task/BatchUpdateTaskStatus",
                            type: "post",
                            data: { ids: ids.join(","), status: status, operatorName: operatorName },
                            success: function (text) {
                                var result = mini.decode(text);
                                if (result.state == "1" || result.state == 1) {
                                    mini.alert("批量操作成功");
                                    loadData();
                                } else {
                                    mini.alert(result.msg || "操作失败");
                                }
                            },
                            error: function () {
                                mini.alert("网络错误");
                            }
                        });
                        win.destroy();
                    };
                    
                    iframe.contentDocument.getElementById("btnCancel").onclick = function() {
                        win.destroy();
                    };
                }
            });
        }
    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">任务管理</a></li>
            <li><a href="#">任务管理</a></li>
        </ul>
    </div>
    <form id="form1">
        <div class="sys-content-border" style="padding:8px 3px;">
            分类: 
            <select id="categoryFilter" style="width:150px; padding: 5px; border: 1px solid #ddd; border-radius: 3px; height: 28px;" onchange="loadData()">
                <option value="">全部分类</option>
            </select>
            &nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_batch" type="button" class="sys-btn" value="批量操作" onclick="batchOperation()" style="background-color: #FFF3E0; color: #EF6C00;" />
            &nbsp;&nbsp;&nbsp;&nbsp;
            状态: 
            <select id="statusFilter" style="width:150px; padding: 5px; border: 1px solid #ddd; border-radius: 3px; height: 28px;">
                <option value="">全部状态</option>
                <option value="0">待处理</option>
                <option value="1">处理中</option>
                <option value="2">已完成</option>
                <option value="3">已审核</option>
            </select>
            &nbsp;&nbsp;&nbsp;&nbsp;
            优先级: 
            <select id="priorityFilter" style="width:100px; padding: 5px; border: 1px solid #ddd; border-radius: 3px; height: 28px;">
                <option value="">全部优先级</option>
                <option value="0">低</option>
                <option value="1">中</option>
                <option value="2">高</option>
            </select>
            &nbsp;&nbsp;&nbsp;&nbsp;
            分配人: 
            <select id="assignedToFilter" style="width:150px; padding: 5px; border: 1px solid #ddd; border-radius: 3px; height: 28px;">
                <option value="">全部分配人</option>
                <option value="zheng">zheng</option>
                <option value="xhc_zjj">xhc_zjj</option>
                <option value="wu">wu</option>
            </select>
            &nbsp;&nbsp;&nbsp;&nbsp;
            截止时间: 
            <input id="timeFilter" type="date" style="width:120px; padding: 5px; border: 1px solid #ddd; border-radius: 3px; height: 20px;" />
            &nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_refresh" type="button" class="sys-btn" value="刷新" onclick="loadData()" style="background-color: #E3F2FD; color: #1976D2;" />
            &nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_add" type="button" class="sys-btn" value="新增任务" onclick="addTask()" style="background-color: #E8F5E9; color: #388E3C;" />
        </div>
        <div id="grid1" class="mini-datagrid" style="width:100%; margin-top:5px;" url="/Task/GetTaskList" idfield="TaskID" allowresize="true" multiselect="true"
             sizelist="[50,100,500]" pagesize="50" showSummaryRow="true">
            <div property="columns">
                <div type="checkcolumn" width="30"></div>
                <div field="TaskID" width="0" visible="false"></div>
                <div field="Index" width="30" header="序号" align="center" renderer="renderIndex"></div>
                <div field="Status" width="120" header="状态" allowSort="true" renderer="renderStatus"></div>
                <div field="CategoryName" width="80" header="分类" allowSort="true"></div>
                <div field="TaskName" width="200" header="任务名称" allowSort="true" renderer="renderTaskName"></div>
                <div field="FullExternalUrl" width="60" header="外部链接" renderer="renderExternalUrl"></div>
                <div field="Result" width="100" header="结果" allowSort="true"></div>
                <div field="Description" width="200" header="任务描述"></div>
                <div field="Priority" width="60" header="优先级" allowSort="true" renderer="renderPriority"></div>
                <div field="AssignedTo" width="60" header="分配人" allowSort="true"></div>
                <div field="StandardScore" width="50" header="标准分" allowSort="true" summaryType="sum" summaryRenderer="summaryRenderer"></div>
                <div field="ActualScore" width="50" header="实际分" allowSort="true" renderer="renderActualScore" summaryType="sum" summaryRenderer="summaryRenderer"></div>
                <div field="FinalScore" width="50" header="最终分" allowSort="true" summaryType="sum" summaryRenderer="summaryRenderer"></div>
                <div field="StartTime" width="80" header="开始时间" allowSort="true" renderer="renderStartTime"></div>
                <div field="EndTime" width="80" header="完成时间" allowsort="true" renderer="renderCompleteTime"></div>
                <div field="Deadline" width="80" header="截止时间" allowSort="true" renderer="renderDeadline"></div>
                <div field="CreateTime" width="80" header="创建时间" allowSort="true" renderer="renderCreateTime"></div>
                <div field="Creator" width="80" header="创建人" allowSort="true"></div>
                <div field="action" width="80" header="操作" align="center" renderer="renderAction"></div>
            </div>
        </div>
    </form>
</body>
</html>