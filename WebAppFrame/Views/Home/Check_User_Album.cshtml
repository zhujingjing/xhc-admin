@using System.Data
@model DataTable

@{
    Layout = null;
    DataTable dt = ViewBag.dt as DataTable;
}

<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>相册审核</title>


    <script src="~/Scripts/jquery-1.8.2.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <style>
        .ub {
            display: flex;
        }

        .ub-ver {
            flex-direction: column;
        }

        .ub-as {
            justify-content: flex-start;
        }

        .ub-ac {
            justify-content: center;
        }

        .ub-ac1 {
            justify-content: space-around;
        }

        .ub-ac2 {
            justify-content: space-between;
        }

        .ub-ac3 {
            justify-content: space-evenly;
        }

        .ub-ae {
            justify-content: flex-end;
        }

        .ub-ps {
            align-items: flex-start;
        }

        .ub-pc {
            align-items: center;
        }

        .state {
            font-size: 15px;
            font-weight: bold;
        }

        .time-txt {
            color: #777;
            font-size: 14px;
        }



        .red {
            color: red;
        }

        .blue {
            color: #32cd32;
        }

        .blue1 {
            color: blue;
        }

        .top2 {
            background-color: #e92162;
            padding: 0 6px;
            height: 50px;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1;
        }

            .top2 #return {
                width: 2em;
                height: 2em;
                padding: 1em 3em 1em 0;
            }

            .top2 #refresh {
                width: 2.7em;
                height: 2.7em;
                padding: 1em 1em 1em 3em;
            }

        body {
            margin: 0;
            font-family: PingFangSC-Regular, tahoma, arial, sans-serif;
        }

        body {
            margin: 0;
            font-family: PingFangSC-Regular, tahoma, arial, sans-serif;
            background-color: #F0F0F0;
        }

        #form1 {
            padding: 8px;
        }

        .line {
            border-top: 1px dashed #F0F0F0;
            margin: 3px 0;
        }

        .operate {
            margin-top: 10px;
        }

        .operate-a {
            border-radius: .3em;
            background-color: #e92162;
            color: #fff;
            width: 70px;
            text-align: center;
            font-size: 15px;
            text-decoration: none;
            padding: 5px 0;
            margin-left: 20px;
        }

        .operate2 {
            margin-top: 10px;
        }

            .operate2 a {
                border-radius: .3em;
                background-color: #dfdfdf;
                color: #fff;
                width: 70px;
                text-align: center;
                font-size: 15px;
                text-decoration: none;
                padding: 5px 0;
                margin-left: 20px;
            }

        .popup {
            display: none;
            position: fixed;
            top: 0;
            right: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.9);
            z-index: 99;
        }

        .img-album {
            width: 100%;
            height: auto;
        }

        .operate-c {
            border-radius: .3em;
            background-color: #dcdcdc;
            color: #fff;
            width: 70px;
            text-align: center;
            font-size: 15px;
            text-decoration: none;
            padding: 5px 0;
            margin-left: 20px;
        }

        #image {
            width: 120px;
            height: 120px;
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
        }
    </style>
    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        $(function () {
            //返回
            $("#return").bind("click", function () {
                location.href = '/Home/Check_Survey';
            });

            //刷新页面
            $("#refresh").bind("click", function () {
                location.reload();
            });
        });

        //操作
        function check(id, state) {
            $.ajax({
                type: "get",
                url: "/Admin1/Check_Album",
                data: { "id": id, "state": state },
                success: function (data) {
                    var data = JSON.parse(data);
                    if (data.state == '1') {
                        var stateText = getStateText(state);
                        var stateClass = getStateClass(state);
                        $("#" + id).html(stateText);
                        $("#" + id).removeClass();
                        $("#" + id).addClass(stateClass);
                        $("#" + id + "111,#" + id + "222").removeClass();
                        $("#" + id + "111,#" + id + "222").addClass("operate-c");

                    }
                }
            });
        }

        function showAll() {
            location.href = '/Home/Check_User_Album';
        }

        //审核的状态
        function getStateText(state) {
            if (state == '1') {
                return '通过';
            }
            if (state == '2') {
                return '不通过';
            }
            if (state == '0')
            {
                return '待审核';
            }
        }
        //审核的状态对应的颜色
        function getStateClass(state) {
            if (state == '1') {
                return 'blue1';
            }
            if (state == '2') {
                return 'red';
            }
        }

        //查看图片
        function showPopup(url) {
            document.getElementById("img-album").src = url;
            document.getElementById("popup").style.display = 'flex';
            document.getElementById("popup").style.justifyContent = 'center';
            document.getElementById("popup").style.alignItems = 'center';
        }

        //关闭
        function closePopup() {
            document.getElementById("popup").style.display = 'none';
        }

    </script>
</head>
<body>
    <div class="main">
        <div id="popup" class="popup ub ub-pc ub-ac" onclick="closePopup()">
            <img id="img-album" class="img-album" src="" />
        </div>
        <div class="top2 ub ub-pc ub-ac2">
            <img id="return" src="http://wx2.xhchat.cn/img/%E8%BF%94%E5%9B%9E%E7%AE%AD%E5%A4%B4.93b021b8.png" />
            <span onclick="showAll()">显示全部</span>
            <img id="refresh" src="~/Images/刷新.png" />
        </div>
        <div style="height:58px;"></div>
        <form id="form1">

            @foreach (DataRow item in dt.Rows)
            {
                <div class="box" style="background-color:#fff;border-radius:.5em; padding: 5px 10px;margin-bottom:15px;">
                <div class="ub ub-ac2">
                    <span class="time-txt">@item["create_time"] </span>
                    @if (item["check_state"].ToString() == "0")
                    {
                        <span name="state_0" id="@item["id"]" class="">待审核</span>
                    }
                    @if (item["check_state"].ToString() == "1")
{
    <span name="state_x" id="@item["id"]" class="blue1">通过</span>
}
                    @if (item["check_state"].ToString() == "2")
{
    <span name="state_x" id="@item["id"]" class="red">不通过</span>
}
                    
                </div>

                <div class="line" style="margin-bottom:10px;"></div>
                <div>
                    <div style="background-image: url(@ViewData["servUrl_AppData"].ToString()/photo/@item["url"].ToString())" id="image" onclick="showPopup('@ViewData["servUrl_AppData"].ToString()/photo/@item["url"].ToString()')"></div>
                    @if (item["check_state"].ToString() == "0")
{
                    <div class="operate ub ub-pc ub-ae">
                        <a id="@item["id"]111" class="operate-a " href="javascript:check('@item["id"]', 1)">通过</a>
                        <a id="@item["id"]222" class="operate-a " href="javascript:check('@item["id"]', 2)">不通过</a>
                    </div>
}
                    else
                    {
                        <div class="operate ub ub-pc ub-ae">
                        <a id="@item["id"]111" class="operate-c " href="javascript:check('@item["id"]', 1)">通过</a>
                        <a id="@item["id"]222" class="operate-c " href="javascript:check('@item["id"]', 2)">不通过</a>
                    </div>
                    }
                    
                </div>
            </div>
            }
        </form>
    </div>
</body>
</html>
