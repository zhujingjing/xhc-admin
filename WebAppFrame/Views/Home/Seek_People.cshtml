<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>寻人区</title>


    <script src="~/Scripts/jquery-1.8.2.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <style>
        .ub {
            display: flex;
        }

        .ub-ver {
            flex-direction: column;
        }

        .ub-as {
            justify-content: flex-start;
        }

        .ub-ac {
            justify-content: center;
        }

        .ub-ac1 {
            justify-content: space-around;
        }

        .ub-ac2 {
            justify-content: space-between;
        }

        .ub-ac3 {
            justify-content: space-evenly;
        }

        .ub-ae {
            justify-content: flex-end;
        }

        .ub-ps {
            align-items: flex-start;
        }

        .ub-pc {
            align-items: center;
        }

        .ub-f1 {
            flex-grow: 1;
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        tr {
            text-align: center;
        }

        th {
            background-color: #f9fafd;
            color: #333;
            font-size: 2em;
            padding: 11px;
        }

        table, th, td {
            border: 1px solid #ebeef8;
            padding: 11px 5px;
            font-size: 12px;
            color: #666;
        }

        .width {
            max-width: 80px;
        }

        .photo {
            width: 4em;
            height: 4em;
            border-radius: 50%;
        }

        .red {
            color: red;
            font-weight: bold;
            font-size: 15px;
        }

        .blue {
            color: #32cd32;
            font-weight: bold;
        }

        .backlog {
            color: #dcdcdc;
        }

        .backlog2 {
            color: #777;
            font-size: 15px;
        }

        .orange {
            color: #fc5531;
            font-size: 15px;
        }

        .top {
            font-size: 15px;
        }

        .info {
            border: .5px solid #dcdcdc;
            padding: 12px 10px 12px 10px;
            margin-bottom: 15px;
            border-radius: .3em;
            background-color: #fff;
        }

        img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
        }

        .state {
            font-size: 15px;
        }

        .time-txt {
            color: #777;
            font-size: 13px;
        }

        .arrow {
            width: 10em;
            height: 0.8em;
        }

        .gift-img {
            width: 40px;
            height: 40px;
        }

        textarea {
            padding: 6px 6px;
            line-height: 25px;
            border: solid 1px #dcdcdc;
            resize: none;
            outline: none;
            width: 100%;
        }

        .text1 {
            padding: 6px 6px;
            font-size: 12px;
            color: #666;
            border-left: solid 1px #dcdcdc;
            border-right: solid 1px #dcdcdc;
        }

        .text2 {
            color: #333;
        }

        .check-btn {
            width: 100%;
            background-color: #48befa;
            border-radius: 5px;
            color: #fff;
            height: 35px;
            font-size: 17px;
            margin-top: 5px;
        }

        .operate {
            margin-top: 10px;
        }

            .operate a {
                border-radius: .3em;
                background-color: #e92162;
                color: #fff;
                text-align: center;
                font-size: 15px;
                text-decoration: none;
                padding: 5px 10px;
            }

        .operate2 {
            margin-top: 10px;
        }

            .operate2 a {
                border-radius: .3em;
                background-color: #dfdfdf;
                color: #fff;
                width: 70px;
                text-align: center;
                font-size: 15px;
                text-decoration: none;
                padding: 5px 0;
            }

        .top2 {
            background-color: #e92162;
            padding: 0 6px;
            height: 50px;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1;
        }

            .top2 #return {
                width: 2em;
                height: 2em;
                padding: 1em 3em 1em 0;
            }

            .top2 #refresh {
                width: 2.7em;
                height: 2.7em;
                padding: 1em 1em 1em 3em;
            }

        body {
            margin: 0;
            font-family: PingFangSC-Regular, tahoma, arial, sans-serif;
            background-color: #F0F0F0;
        }

        .rst_check {
            font-size: 15px;
            font-weight: bold;
        }

        #form1 {
            padding: 8px;
        }

        .line {
            border-top: 1px dashed #F0F0F0;
            margin: 3px 0;
        }
    </style>
    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        $(function () {

            $.ajax({
                type: "get",
                url: "/Admin1/GetSeekpeopleData_movie",
                // data: { "id": id, "state": state },
                success: function (data) {
                    //console.log(data);
                    var data = JSON.parse(data);
                    var id, uid, photo, nick, sex, wx, create_time, title, content, state, refurbish_time, refurbish_count, comment, dtm_check, wxcheck, dtm_wxcheck;
                    var h = '';
                    for (var i = 0; i < data.length; i++) {
                        id = data[i]["id"];
                        uid = data[i]["uid"];
                        photo = data[i]["photo"];
                        nick = data[i]["nick"];
                        sex = data[i]["sex"];
                        wx = data[i]["wx"];
                        create_time = data[i]["create_time"];
                        title = data[i]["title"];
                        content = data[i]["content"];
                        state = data[i]["state"];
                        refurbish_time = data[i]["refurbish_time"];
                        refurbish_count = data[i]["refurbish_count"];
                        comment = data[i]["comment"];
                        dtm_check = data[i]["dtm_check"];
                        wxcheck = data[i]["wxcheck"];
                        dtm_wxcheck = data[i]["dtm_wxcheck"];

                        var photo = servUrl_AppData + '/photo/' + photo;
                        if (comment == "") {
                            comment = '待审核';
                        }
                        if (state == "通过") {
                            state = '<label style="color:blue;margin-left:5px">' + state + '</label>';
                        }
                        if (state == "失败") {
                            state = '<label style="color:red;margin-left:5px">' + state + '</label>';
                        }
                        if (wxcheck == "正确") {
                            wxcheck = '<label style="color:blue;font-size:1.25em;margin-left:5px">' + wxcheck + '</label>';
                            wx = '<span style="font-size:1.25em;color:blue;">'+wx+'</span>';
                        }
                        if (wxcheck == "错误") {
                            wxcheck = '<label style="color:red;font-size:1.25em;margin-left:5px">' + wxcheck + '</label>';
                            wx = '<span style="font-size:1.25em;color:red;">' + wx + '</span>';
                        }
                        if (wxcheck != "错误" && wxcheck != "正确") {
                            wx = '<span style="font-size:1.25em;color: #e92162;">' + wx + '</span>';
                        }
                        if (nick.length > 6) {
                            nick = nick.substr(0, 4) + "...";
                        }
                        if (sex == "男生") {
                            var sex = '<span style="color:blue">(' + sex + ')</span>';
                        }
                        if (sex == "女生") {
                            var sex = '<span style="color:red">(' + sex + ')</span>';
                        }

                        var check_btn = '<div class="ub ub-pc ub-ac2" style="width:40%;">\
                                            <a href="javascript:Check(\'' + id + '\',\'通过\')">通过</a>\
                                            <a href="javascript:Check(\'' + id + '\',\'失败\')">失败</a>\
                                         </div>';

                        var wxcheck_btn = '<div class="ub ub-pc ub-ac2" style="width:40%;">\
                                              <a href="javascript:WxCheck(\'' + id + '\',\'正确\')">正确</a>\
                                              <a href="javascript:WxCheck(\'' + id + '\',\'错误\')">错误</a>\
                                           </div>';


                        h += '<div class="info">\
                                <div class="ub ub-pc ub-ac2">\
                                    <span class="time-txt">' + create_time + '</span>\
                                </div>\
                                <div class="line" style="margin:5px 0;"></div>\
                                <div class="operate ub ub-pc ub-ac2">\
                                    <span>审核状态:<label>' + state + '</label></span>\
                                    <div style="color:orangered;font-size:1.25em;">' + comment + '</div>\
                                    '+check_btn+'\
                                </div>\
                                <div class="line" style="margin:5px 0;"></div>\
                                <div class="ub ub-pc">\
                                    <div class="ub ub-ver ub-ac ub-pc" style="width:13em;border-right:1px dashed #F0F0F0;">\
                                        <img src="' + photo + '" />\
                                        <span class="ub">\
                                            <label>'+nick+'</label>\
                                            <label>'+sex+'</label>\
                                        </span>\
                                        <span style="font-size:1.3em;color:blue;">'+wx+'</span>\
                                    </div>\
                                    <div>\
                                        <div style="color:#686868;padding-left:10px;">' + title + '</div>\
                                        <div class="line" style="margin:5px 0;"></div>\
                                        <div class="ub" style="color:#333;padding-left:10px; word-break: break-all; ">' + content + '</div>\
                                    </div>\
                                </div>\
                                <div class="line" style="margin:5px 0;"></div>\
                                <div class="operate ub ub-pc ub-ac2">\
                                    <span>微信状态:<label>' + wxcheck + '</label></span>\
                                    ' + wxcheck_btn + '\
                                </div>\
                            </div>';
                    }
                    $("#form1").html(h);


                }
            });

            $("#return").bind("click", function () {
                location.href = '/Home/Check_Survey';
            });

            $("#refresh").bind("click", function () {
                location.reload();
            });
        });
        function Check(id, state) {
            $.ajax({
                type: "get",
                url: "/Admin1/Check_Seek_people",
                data: { "id": id, "state": state },
                success: function (data) {
                    var data = JSON.parse(data);
                    if (data.state == '1') {
                        location.reload();
                    }

                }
            });
        }

        function WxCheck(id, wxcheck) {
            $.ajax({
                type: "get",
                url: "/Admin1/WxCheck_Seek_people",
                data: { "id": id, "wxcheck": wxcheck },
                success: function (data) {
                    var data = JSON.parse(data);
                    if (data.state == '1') {
                        location.reload();
                    }

                }
            });
        }

    </script>
</head>
<body>
    <div class="main">
        <div class="top2 ub ub-pc ub-ac2">
            <img id="return" src="http://wx2.xhchat.cn/img/%E8%BF%94%E5%9B%9E%E7%AE%AD%E5%A4%B4.93b021b8.png" />
            <img id="refresh" src="~/Images/刷新.png" />
        </div>
        <div style="height:58px;"></div>
        <form id="form1">
            <div class="info">
                <div class="ub ub-pc ub-ac2">
                    <span class="time-txt">2021-03-06 00:00:00</span>
                </div>

                <div class="line" style="margin:5px 0;"></div>

                <div class="ub ub-pc">
                    <div class="ub ub-ver ub-ac ub-pc" style="width:13em;border-right:1px dashed #F0F0F0;">
                        <img src="http://xhcapp_i.zhuochuangzb.com/photo/photo_girl/3265.jpg" />
                        <span class="ub">
                            <label>东方不败</label>
                            <label>(女生)</label>
                        </span>
                        <span style="font-size:1.3em;color:blue;">Harryoil</span>
                    </div>
                    <div>
                        <div style="color:#686868;padding-left:10px;">找个小哥哥</div>
                        <div class="line" style="margin:5px 0;"></div>
                        <div style="color:#333;padding-left:10px;">找个小哥哥找个小哥哥找个小哥哥找个小哥哥找个小哥哥找个小哥哥</div>
                    </div>
                </div>

                <div class="line" style="margin:5px 0;"></div>

                <div class="operate ub ub-pc ub-ac2">
                    <span>审核状态:<label>通过</label></span>
                    <div style="color:orangered;font-size:1.3em;">通过</div>
                    <div class="ub ub-pc ub-ac2" style="width:40%;">
                        <a>通过</a>
                        <a>失败</a>
                    </div>

                </div>

                <div class="line" style="margin:5px 0;"></div>

                <div class="operate ub ub-pc ub-ac2">
                    <span>微信状态:<label>正确</label></span>
                    <div style="color:orangered;font-size:1.3em;">通过</div>
                    <div class="ub ub-pc ub-ac2" style="width:40%;">
                        <a>正确</a>
                        <a>错误</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</body>
</html>
