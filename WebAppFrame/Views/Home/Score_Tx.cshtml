<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>提现审核</title>

    <script src="~/Scripts/jquery-1.8.2.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>


    <style>
        .ub {
            display: flex;
        }

        .ub-ver {
            flex-direction: column;
        }

        .ub-as {
            justify-content: flex-start;
        }

        .ub-ac {
            justify-content: center;
        }

        .ub-ac1 {
            justify-content: space-around;
        }

        .ub-ac2 {
            justify-content: space-between;
        }

        .ub-ac3 {
            justify-content: space-evenly;
        }

        .ub-ae {
            justify-content: flex-end;
        }

        .ub-ps {
            align-items: flex-start;
        }

        .ub-pc {
            align-items: center;
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        tr {
            text-align: center;
        }

        th {
            background-color: #f9fafd;
            color: #333;
            font-size: 2em;
            padding: 11px;
        }

        table, th, td {
            border: 1px solid #ebeef8;
            padding: 11px 5px;
            font-size: 12px;
            color: #666;
            border-radius: 1em;
        }

        .width {
            max-width: 80px;
        }

        .photo {
            width: 4em;
            height: 4em;
            border-radius: 50%;
        }

        .red {
            color: red;
        }

        .blue {
            color: #32cd32;
        }

        .top {
            font-size: 15px;
        }

        .info {
            border-top: .5px solid #dcdcdc;
            border-left: .5px solid #dcdcdc;
            border-right: .5px solid #dcdcdc;
            padding: 5px 10px;
            border-top-left-radius: .5em;
            border-top-right-radius: .5em;
        }

        img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
        }

        .check_btn {
            color: #fff;
            font-size: 18px;
            border: 1px solid #e92162;
            padding: .2em .5em;
            border-radius: .3em;
            background-color: #e92162;
        }

        .check_btn2 {
            color: #fff;
            font-size: 18px;
            border: 1px solid #dfdfdf;
            padding: .2em .5em;
            border-radius: .3em;
            background-color: #dfdfdf;
        }

        .wechat {
            color: blue;
            font-size: 14px;
        }

        .tel {
            margin: 8.5px 0;
            font-size: 14px;
            color: #333;
        }

        .note {
            color: red;
            font-size: 14px;
        }

        .time-txt {
            color: #777;
            font-size: 14px;
        }

        .top2 {
            background-color: #e92162;
            padding: 0 6px;
            height: 50px;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1;
        }

            .top2 #return {
                width: 2em;
                height: 2em;
                padding: 1em 3em 1em 0;
            }

            .top2 #refresh {
                width: 2.7em;
                height: 2.7em;
                padding: 1em 1em 1em 3em;
            }

        .bottom {
            margin-bottom: 30px;
            background-color: #fff;
        }

        body {
            margin: 0;
            font-family: PingFangSC-Regular, tahoma, arial, sans-serif;
            background-color: #F0F0F0;
        }

        .col {
            color: #666;
            font-size: 14px;
        }

        #form1 {
            padding: 8px;
        }

        .account {
            width: 185px;
        }

        .line {
            border-top: 1px dashed #F0F0F0;
            margin: 3px 0;
        }

        .backlog {
            color: #dcdcdc;
        }
    </style>
    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        $(function () {
            $.ajax({
                type: "get",
                url: "/Admin1/GetScoreTxData",
                // data: { "id": id, "state": state },
                success: function (data) {
                    //console.log(data);
                    var data = JSON.parse(data);
                    var id, photo, nick, wx_account, tel, apply_date, tx_mny, fee, pay_mny_0, pay_mny, state, checkbtn;
                    var h = '';
                    for (var i = 0; i < data.length; i++) {
                        id = data[i]["id"];
                        photo = data[i]["photo"];
                        nick = data[i]["nick"];
                        wx_account = data[i]["wx_account"];
                        tel = data[i]["tel"];
                        apply_date = data[i]["apply_date"];
                        tx_mny = data[i]["tx_mny"];
                        fee = data[i]["fee"];
                        pay_mny_0 = tx_mny - fee;
                        pay_mny = data[i]["pay_mny"];
                        state = data[i]["state"];
                        remark = data[i]["remark"];

                        var photo = servUrl_AppData + '/photo/' + photo;


                        if (state == "失败") {
                            state = '<span class="red" style="font-size:15px; font-weight:bold;">' + state + '</span>'
                            checkbtn = '<span class="check_btn2" id="check"><a style="color:#fff; text-decoration: none;" href="javascript:update(\'' + id + '\')">审核</a></span>'
                        }
                        if (state == "成功") {
                            state = '<span class="blue" style="font-size:15px; font-weight:bold;">' + state + '</span>'
                            checkbtn = '<span class="check_btn2" id="check"><a style="color:#fff; text-decoration: none;" href="javascript:update(\'' + id + '\')">审核</a></span>'
                        }
                        if (state == "待审核") {
                            state = '<span class="backlog" style="font-size:15px; font-weight:bold;">' + state + '</span>'
                            checkbtn = '<span class="check_btn" id="check"><a style="color:#fff; text-decoration: none;" href="javascript:update(\'' + id + '\')">审核</a></span>'
                        }



                      
                        if (remark == "") {
                            remark = "";
                        }

                        h += '<div class="bottom">\
                                <div class="info">\
                                    <div class="ub ub-ac2">\
                                        <span class="time-txt">' + apply_date + '</span>\
                                        <span class="backlog">' + state + '</span>\
                                    </div>\
                                    <div class="line" style="margin-bottom:10px;"></div>\
                                    <div class="ub ub-ac2">\
                                        <div class="ub ub-ver ub-pc ub-ac">\
                                            <img src="' + photo + '" />\
                                            <span>' + nick + '</span>\
                                        </div>\
                                        <div class="account ub ub-ver ub-ac">\
                                            <span class="col">微信:<label class="wechat">&nbsp;' + wx_account + '</label></span>\
                                            <span class="col tel">手机:<label class="tel">&nbsp;' + tel + '</label></span>\
                                            <span class="col">备注:<label class="note">&nbsp;' + remark + '</label></span>\
                                        </div>\
                                        <div class="ub ub-pc">' + checkbtn + '</div>\
                                    </div>\
                                </div>\
                                <table border="1">\
                                    <thead>\
                                        <tr>\
                                            <th>申请金额</th>\
                                            <th>手续费</th>\
                                            <th>应发</th>\
                                            <th>实发</th>\
                                        </tr>\
                                    </thead>\
                                    <tbody id="con">\
                                        <tr>\
                                            <td style="text-align:right; color:#333; font-size:16px;">￥' + tx_mny + '</td>\
                                            <td style="text-align:right">￥' + fee + '</td>\
                                            <td style="text-align:right;color:#0000ff; font-size:16px;">￥' + pay_mny_0 + '</td>\
                                            <td style="text-align:right;color:#ff0000; font-size:16px;">￥' + pay_mny + '</td>\
                                        </tr>\
                                    </tbody>\
                                </table>\
                            </div>'
                    }
                    $("#form1").html(h);
                }
            });


            $("#return").bind("click", function () {
                location.href = '/Home/Check_Survey';
            });

            $("#refresh").bind("click", function () {
                location.reload();
            });
        });

        function update(id) {
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            var parentWidth = $(window.parent.document).find("#rightFrame").width();

            mini.open({
                url: "/Admin1/Score_Tx_Rst/" + id,
                showMaxButton: false,
                title: "审核",
                width: 350,
                height: 300,
                ondestroy: function (action) {
                    if (action == "ok") {
                        grid.reload();
                    }
                    else if (action == "cancel") {

                    }
                }
            });
        }

    </script>
</head>
<body>

    <div class="main">
        <div class="top2 ub ub-pc ub-ac2">
            <img id="return" src="http://wx2.xhchat.cn/img/%E8%BF%94%E5%9B%9E%E7%AE%AD%E5%A4%B4.93b021b8.png" />
            <img id="refresh" src="~/Images/刷新.png" />
        </div>
        <div style="height:58px;"></div>
        <form id="form1">
            <div>
                <div class="info">
                    <div class="ub ub-ae">
                        <span class="time-txt">2020-12-12 16:27:30</span>
                    </div>

                    <div class="ub ub-ac2">
                        <div class="ub ub-ver ub-pc ub-ac">
                            <img src="http://xhcapp.zhuochuangzb.com/photo/photo_girl/1001.jpg" />
                            <span>急急如律令</span>
                        </div>
                        <div class="ub ub-ver ub-ac">
                            <span class="wechat">Victory-lxq</span>
                            <span class="tel">13349635746</span>
                        </div>
                        <div class="ub ub-pc">
                            <span class="check_btn" id="check">审核</span>
                        </div>

                    </div>
                </div>
                <table border="1">
                    <thead>
                        <tr>
                            <th>申请金额</th>
                            <th>手续费</th>
                            <th>应发</th>
                            <th>实发</th>
                            <th>状态</th>
                        </tr>
                    </thead>
                    <tbody id="con">
                        <tr>
                            <td style="text-align:right">￥100</td>
                            <td style="text-align:right">￥20</td>
                            <td style="text-align:right">￥80</td>
                            <td style="text-align:right">￥80</td>
                            <td>成功</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </form>
    </div>
</body>
</html>
