<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>服务器时间</title>
    <link href="~/Styles/demo.css" rel="stylesheet" type="text/css" />
    <script src="~/Scripts/jquery-1.8.2.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <style>
        .time-block {
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            height: 99%;
            padding: 0;
            margin: 0;
        }

            .time-block div {
                font-size: 100px;
                color: red;
                cursor: pointer;
                
            }

            .time-block span {
                font-size: 40px;
                margin-top: 100px;
                cursor: pointer;
            }
    </style>
    <script type="text/javascript">
        var Time = 120;
        $(function () {
            //设置表格的高度
            get_time();
            reduceTime();
            $("#time,#serve").bind("click", function () {
                get_time();

            });


        })

        function get_time() {
            $.ajax({
                type: "get",
                url: "/Home/GetServDiffSec",
                // data: { "id": id, "state": state },
                success: function (data) {
                    //console.log(data);
                    Time = parseInt(data);
                    $("#time").html(Time);
                }

            });
        };
        function reduceTime() {
            if (Time == 0) {
                return;
            } else {
                $("#time").html(--Time);
                setTimeout(reduceTime, 1000);
            }
        }

    </script>
</head>
<body>

    <div class="time-block">
        <div id="time">120</div>
        <span id="serve">服务器时间(点击刷新)</span>
    </div>

</body>
</html>
