

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>内部在线用户</title>

    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/m_public.css?id=12" rel="stylesheet" />
 
    <style>
        .chart-nav {
            width: 100%;
            background-color: #e91e63;
            position: fixed;
            left: 0;
            top: 0;
            z-index: 900;
        }

        .nav-top {
            height: 2.5em;
        }

            .nav-top a {
                font-size: 1.6em;
                color: #fff;
                font-weight: 400;
            }

        .spider {
            width: 100%;
            height: 1px;
            background-color: #dfdfdf;
        }

        .item {
            padding:8px 0;
            font-size: 1.2em;
        }

        #main {
            overflow: scroll;
        }

        .photo {
            width:40px;
            height:40px;
            border-radius:50%;
        }

        .lnk {
            color:blue;
            font-size:18px;
        }

        .cl-1 {
            color:blue;
            font-size:18px;
            font-weight:bold;
        }

        .cl-2 {
            color: red;
            font-size: 16px;
            font-weight: bold;
        }
    </style>


    <script type="text/javascript">

        $(function () {
            //设置表格的高度
            init();
        })

        function init() {
        }

        function Remove(uid)
        {
            uid = uid.trim();
            if (!uid || uid.length != 19) {
                alert("uid错误");
                return false;
            }

            var tag = confirm("确定要移除吗，这会影响到正式系统的用户匹配情况");
            if (tag) {
                //后台
                $.ajax({
                    type: "Get",
                    url: "/Home/Remove_Uid/" + uid,
                    success: function (data) {
                        if (data == "True") {
                            
                            //刷新页面
                            window.location.reload();
                        }
                    }
                });
            }
        }

        function ClearAll() {
            var tag = confirm("确定要清除全部吗，这会影响到正式系统的用户匹配情况");
            if (tag) {
                //后台
                $.ajax({
                    type: "Get",
                    url: "/Home/Clear_Uids",
                    success: function (data) {
                        if (data == "True") {
                            
                            window.location.reload();
                        }
                    }
                });
            }
        }
        

    </script>

</head>
<body>
    <form id="form1">

        <div id="_title">
            <div class="nav-top ub padding-a500 chart-nav" style="background-color: #ff4f72; height: 3em; ">
                <a href="/Home/Index/@ViewData["id_key"]" class="ub width6000 ub-ac ub-ps " style=" font-size:1.2em;">
                    主站
                </a>
                <a class="ub ub-f1 ub-ac ub-pc " style="font-size:1.4em; font-weight:500;">
                    在线用户
                </a>
                <a href="javascript:ClearAll();" class=" ub width6000 ub-ac ub-pc " style=" font-size:1.2em;">
                    清理全部
                </a>
            </div>

            <div class="height5000"></div>
        </div>

       
        <div class="ub item ub-ac">
            <div class="ub width100"></div>
            <div class="ub" style="width:40px;">头像</div>
            <div class="ub ub-f1 padding-l1000">昵称</div>
            <div class="ub ub-f1 padding-l1000 ">魅力值</div>
            <div class="ub ub-f1 padding-l1000">姓名</div>
            <div class="ub ub-f1 padding-l1000 ">操作</div>
        </div>
        <div class="spider"></div>

            @foreach (System.Data.DataRow row in (ViewBag.dt as System.Data.DataTable).Rows)
            {
                <div class="ub item ub-ac">
                    <div class="ub width100"></div>
                    <div class="ub"><img class="photo" src="@ViewData["servUrl_AppData"].ToString()/photo/@row["photo"].ToString()" /></div>
                    <div class="ub ub-f1 padding-l1000">@row["nick"]</div>
                    <div class="ub ub-f1 padding-l1000">@row["total_score"]</div>
                    <div class="ub ub-f1 padding-l1000 cl-1">@row["name"]</div>
                    <div class="ub ub-f1 padding-l1000 "><a class="lnk" href="javascript:Remove('@row["uid"]');">移除</a></div>
                </div>
                <div class="ub item ub-ac">
                    <div class="ub ub-f1 padding-l1000 ">被匹配次</div>
                    <div class="ub ub-f1 padding-l1000 ">发送成功</div>
                    <div class="ub ub-f1 padding-l1000 ">发送失败</div>
                    <div class="ub ub-f1 padding-l1000 ">接收成功</div>
                    <div class="ub ub-f1 padding-l1000 ">接收失败</div>
                </div>
                <div class="ub item ub-ac">
                    <div class="ub ub-f1 padding-l1000 cl-1">@row["match_"]</div>
                    <div class="ub ub-f1 padding-l1000 cl-1">@row["send_suc"]</div>
                    <div class="ub ub-f1 padding-l1000 cl-2">@row["send_fail"]</div>
                    <div class="ub ub-f1 padding-l1000 cl-1">@row["send_suc_"]</div>
                    <div class="ub ub-f1 padding-l1000 cl-2">@row["send_fail_"]</div>
                </div>
                <div class="spider"></div>
            }
      
        
    </form>
</body>
</html>



