    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        $(function () {

            $.ajax({
                type: "get",
                url: "/Admin1/GetKillUserList_movie",
                // data: { "id": id, "state": state },
                success: function (data) {
                    //console.log(data);
                    var data = JSON.parse(data);
                    var id, uid, dtm, dtm_line, kill_hour, state, comment, reason, photo, nick, sex, create_time;
                    var h = '';
                    for (var i = 0; i < data.length; i++) {
                        id = data[i]["id"];
                        uid = data[i]["uid"];
                        dtm = data[i]["dtm"].replace(" ", "<br/>");
                        dtm_line = data[i]["dtm_line"].replace(" ", "<br/>");
                        kill_hour = data[i]["kill_hour"]
                        state = data[i]["state"]
                        comment = data[i]["comment"]
                        reason = data[i]["reason"]
                        photo = data[i]["photo"]
                        nick = data[i]["nick"]
                        sex = data[i]["sex"]
                        create_time = data[i]["create_time"]
                       
                        

                        var photo = servUrl_AppData + '/photo/' + photo;

                        photo = ' <a href="javascript:Show(\'' + uid + '\')">  <img src="' + photo + '" /></a>'

                        if (sex == "男生") {
                            var sex = '<span style="color:blue">(' + sex + ')</span>';
                        }
                        if (sex == "女生") {
                            var sex = '<span style="color:red">(' + sex + ')</span>';
                        }

                        var btn;

                        if (comment == "") {
                            btn = ' <div class="operate ub ub-pc ub-ac2">\
                                    <a href="javascript:update(\'' + id + '\')">解封</a>\
                                    </div>'
                        }
                        if (comment != "") {
                            btn = ' <div class="operate2 ub ub-pc ub-ac2">\
                                    <a href="javascript:update(\'' + id + '\')">解封</a>\
                                </div>'
                        }
                        if (state == "封杀") {
                            state = '<label style="color:red;">' + state + '</label>'
                        } else {
                            state = '<label style="color:blue;">' + state + '</label>'
                        }

                        h += '<div class="info">\
                                <div class="ub ub-pc ub-ac2">\
                                    <div class="ub ub-ver ub-pc">\
                                        '+photo+'\
                                        <span>\
                                            <label>' + nick + '</label>\
                                            <label>' + sex + '</label>\
                                        </span>\
                                    </div>\
                                    <div class="ub ub-ver ub-pc">\
                                        <span></span>\
                                        <span><label></label> <label>' + comment + '</label></span>\
                                    </div>\
                                '+btn+'\
                                </div>\
                                <div class="line" style="margin:5px 0;"></div>\
                                <div class="ub ub-ac2">\
                                    <div class="ub ub-ver ub-pc ub-ac">\
                                        <span>'+dtm+'</span>\
                                    </div>\
                                    <div class="ub ub-ver ub-pc ub-ac">\
                                        <div class="ub ub-pc">\
                                            <span style="color:#e92162">' + kill_hour + '小时</span>\
                                        </div>\
                                        <img class="arrow" src="http://www.daozhenec.com/img/%E5%8F%B3%E7%AE%AD%E5%A4%B4.e607b529.png" />\
                                        <span style="color:#888">' + reason + '</span>\
                                    </div>\
                                    <div class="ub ub-ver ub-pc ub-ac">\
                                        <span>' + dtm_line + '</span>\
                                    </div>\
                                </div>\
                            </div>'
                    }
                    $("#form1").html(h);


                }
            });

            $("#return").bind("click", function () {
                location.href = '/Home/Check_Survey';
            });

            $("#refresh").bind("click", function () {
                location.reload();
            });
        });

        function update(id) {
            if (!confirm("您确定要解除此人的封禁吗?")) {
                return;
            }

            //后台删除
            $.ajax({
                type: "POST",
                url: "/Admin1/UnKillUser",
                data: { "id": id },
                success: function (data) {
                    data = strToJson(data);
                    if (data.state == "1") {
                        location.reload();
                    }
                    else {
                        alert(data.msg);
                    }
                }
            });
        }


    </script>
