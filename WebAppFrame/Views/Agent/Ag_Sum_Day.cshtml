    <style>
        .item {
            display: flex;
            flex-direction: column;
            padding: 5px 0;
            margin-right: 10px;
            background-color: #FF9502;
        }

        .num {
            display: flex;
            justify-content: center;
            align-items: center;
            min-width: 180px;
            height: 60px;
            font-size: 22px;
            font-weight: bold;
            color: #fff;
        }

        .tips {
            display: flex;
            justify-content: center;
            height: 30px;
            font-size: 12px;
            color: #888;
            color: #fff;
        }
        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 14px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }

        .ub {
            display: flex;
        }

        .ub-pc {
            align-items: center;
        }

        .ub-ac {
            justify-content: center;
        }

        .ub-ac2 {
            justify-content: space-around;
        }

        .ub-ac1 {
            justify-content: space-between;
        }
    </style>

    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var id = '@ViewData["id"]';

        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 120);

            mini.parse();
            grid = mini.get("datagrid1");
            //grid.load();

            search();
            drawCell();

            init();
            init_count();

        })

        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 230);
        }

        function init_count() {
            var sumData = '@Html.Raw(ViewData["sumData"])';
            var sumData = JSON.parse(sumData);
            var fried_count = sumData.fried_count;
            var score_total = sumData.score_total;
            var today = (sumData.score_1 / 1000).toFixed(2);
            var yesterday = (sumData.score_2 / 1000).toFixed(2);
            var day30 = (sumData.score_3 / 1000).toFixed(2);
            var score_gift = (sumData.score_gift / 1000).toFixed(2);
            var score_msg = (sumData.score_msg / 1000).toFixed(2);
            var score_pay = (sumData.score_pay / 1000).toFixed(2);
            var score_total = (sumData.score_total / 1000).toFixed(2);


            $("#profit").html("￥" + score_total);
            $("#fried_count").html(fried_count+"人");
            $("#today").html("￥" +today);
            $("#yesterday").html("￥" +yesterday);
            $("#day30").html("￥" +day30);
            $("#score_gift").html("￥" +score_gift);
            $("#score_msg").html("￥" +score_msg);
            $("#score_pay").html("￥" +score_pay);
            $("#score_total").html("￥" +score_total);
        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                if (column.name == "score_pay") {
                    var score_pay = (record.score_pay / 1000).toFixed(2);
                    e.cellHtml = '<span>￥' + score_pay + '</span>';
                    if (score_pay > 0) {
                        e.cellHtml = '<span style="display:inline-block;margin:10px 0; color:red; font-size:18px; font-weight:bold;">￥' + score_pay + '</span>';
                    }
                }
                if (column.name == "score_gift") {
                    var score_gift = (record.score_gift / 1000).toFixed(2);
                    e.cellHtml = '<span>￥' + score_gift + '</span>';
                    if (score_gift > 0) {
                        e.cellHtml = '<span style="display:inline-block;margin:10px 0; color:red; font-size:18px; font-weight:bold;">￥' + score_gift + '</span>';
                    }
                }
                if (column.name == "score_msg") {
                    var score_msg = (record.score_msg / 1000).toFixed(2);
                    e.cellHtml = '<span>￥' + score_msg + '</span>';
                    if (score_msg > 0) {
                        e.cellHtml = '<span style="display:inline-block;margin:10px 0; color:red; font-size:18px; font-weight:bold;">￥' + score_msg + '</span>';
                    }
                }
                if (column.name == "score_invite") {
                    var score_invite = (record.score_invite / 1000).toFixed(2);
                    e.cellHtml = '<span>￥' + score_invite + '</span>';
                    if (score_invite > 0) {
                        e.cellHtml = '<span style="display:inline-block;margin:10px 0; color:red; font-size:18px; font-weight:bold;">￥' + score_invite + '</span>';
                    }
                }

            });
        }



    </script>

    <script>
        function onDrawSummaryCell(e) {
            var result = e.result;
            var grid = e.sender;

            //客户端汇总计算
            if (e.field == "score_pay") {
                var mny = "￥" + (e.cellHtml / 1000).toFixed(2);
                e.cellStyle = "text-align:right";
                e.cellHtml = '<span style="display:inline-block;margin:10px 0; color:red; font-size:18px; font-weight:bold;">' + mny + '</span>';
            }

            if (e.field == "score_gift") {
                var mny = "￥" + (e.cellHtml / 1000).toFixed(2);
                e.cellStyle = "text-align:right";
                e.cellHtml = '<span style="display:inline-block;margin:10px 0; color:red; font-size:18px;font-weight:bold;">' + mny + '</span>';
            }

            if (e.field == "score_msg") {
                var mny = "￥" + (e.cellHtml / 1000).toFixed(2);
                e.cellStyle = "text-align:right";
                e.cellHtml = '<span style="display:inline-block;margin:10px 0; color:red; font-size:18px; font-weight:bold;">' + mny + '</span>';
            }

            if (e.field == "score_invite") {
                var mny = "￥" + (e.cellHtml / 1000).toFixed(2);
                e.cellStyle = "text-align:right";
                e.cellHtml = '<span style="display:inline-block;margin:10px 0; color:red; font-size:18px; font-weight:bold;">' + mny + '</span>';
            }

        }

        function search() {
            var dtm_start = mini.get("dtm_start").getText();
            var dtm_end = mini.get("dtm_end").getText();
            
            grid.load({
                "fz_tag": id,
                "start": dtm_start,
                "end": dtm_end,
            });
        }
    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">收益统计</a></li>
        </ul>
    </div>
    <form id="form1">
        <ul id="desc" style="display:flex;  margin-bottom: 5px;">

            <li class="item" style="background-color: blue;">
                <div class="num" id="fried_count"></div>
                <div class="tips">累计邀请</div>
            </li>

            <li class="item" style="background-color: blue; ">
                <div class="num" id="profit"></div>
                <div class="tips">累计收益</div>
            </li>
           
            <li class="item" style="margin-left: 20px; background-color: #00BBFF;">
                <div class="num" id="today"></div>
                <div class="tips">今日</div>
            </li>
            <li class="item" style="background-color: #00BBFF;">
                <div class="num" id="yesterday"></div>
                <div class="tips">昨日</div>
            </li>
            <li class="item" style="background-color: #00BBFF;">
                <div class="num" id="day30"></div>
                <div class="tips">近30日</div>
            </li>
            <!--<li class="item" style="background-color: #00BBFF;">
                <div class="num" id="score_gift"></div>
                <div class="tips">礼物</div>
            </li>
            <li class="item" style="background-color: #00BBFF;">
                <div class="num" id="score_msg"></div>
                <div class="tips">私信</div>
            </li>
            <li class="item" style="background-color: #00BBFF;">
                <div class="num" id="score_pay"></div>
                <div class="tips">充值</div>
            </li>
            <li class="item" style="background-color: #00BBFF;">
                <div class="num" id="score_total"></div>
                <div class="tips">总收入</div>
            </li>-->
        </ul>

        <div class="sys-content-border" style="padding:8px 3px;">
            统计日期: <input id="dtm_start" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["start"]" />
            - <input id="dtm_end" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["end"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Agent/GetProfitData" idfield="id" allowresize="true" multiselect="true"
             showsummaryrow="true" ondrawsummarycell="onDrawSummaryCell"
             sizelist="[20,50,100,500]" pagesize="50">
            <div property="columns">
                <div field="xh" width="20" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="dtm" width="40" headeralign="center" align="center" allowsort="false">日期</div>
                <div name="score_pay" field="score_pay" width="40" headeralign="center" align="right" allowsort="false" summarytype="sum">支付收益</div>
                <div name="score_gift" field="score_gift" width="40" headeralign="center" align="right" allowsort="false" summarytype="sum">礼物收益</div>
                <div name="score_msg" field="score_msg" width="40" headeralign="center" align="right" allowsort="false" summarytype="sum">私信收益</div>
                <div name="score_invite" field="score_invite" width="40" headeralign="center" align="right" allowsort="false" summarytype="sum">总计</div>
                <div width="300" headeralign="center" align="center" allowsort="false">--</div>
            </div>
        </div>
    </form>
</body>
</html>
