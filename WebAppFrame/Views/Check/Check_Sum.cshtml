<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/public.css" rel="stylesheet" />
    <link href="~/Styles/style.css" rel="stylesheet" />
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <style>
        .empty {
            display: none;
        }

        .mini-tabs-position-top .mini-tabs-header {
            padding-top: 5px;
            background-color: #EDF6FA;
        }

        tr {
            height: 32px;
        }
    </style>
    <script type="text/javascript">
        var tabs;

        $(function () {
            mini.parse();
            tabs = mini.get("mainTabs");
        });

        function on_tab(event,title) {
            event.preventDefault();
            
            var tab = tabs.getTab(title);//getTabByTitle(title);
            if (tab) {
                tabs.activeTab(tab);
            }
        }

        function getTabByTitle(title) {
            var tabItems = tabs.getTabs();
            return tabItems.find(tab => tab.title === title)
        }

    </script>
    <script>
        function onTabsActiveChanged() {

        }

    </script>
</head>
<body>
    <div id="mainTabs" class="mini-tabs" activeindex="0" style="width:99%;height:99%; margin-left:3px;"
         onactivechanged="onTabsActiveChanged" plain="true">

        <div name="概况" title="概况" url="/Check/Check_Survey"></div>
        <div name="提现审核" title="提现审核" url="/Check/Score_Tx"></div>
        <div name="寻人区" title="寻人区" url="/Check/Seek_People"></div>
        <div name="信息审核" title="信息审核" url="/Check/UpData_UserInfo"></div>
        <div name="相册审核" title="相册审核" url="/Check/Album"></div>

        <div name="礼物投诉" title="礼物投诉" url="/Check/Gif_TouSu"></div>
        <div name="用户反馈" title="用户反馈" url="/Check/FeedBack"></div>
        <div name="聊天举报" title="聊天举报" url="/Check/Complain"></div>
        
    </div>
</body>
</html>

