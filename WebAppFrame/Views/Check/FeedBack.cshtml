

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=12"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 14px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            //grid.load();
            search();
            drawCell();

            init();
            bindEvent();
        })
        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml += '<a style="color:blue;" href="javascript:dtl(\'' + record.id + '\')">详情</a>';
                    e.cellHtml += '&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;';
                    e.cellHtml += '<a style="color:blue;" href="javascript:Check(\'' + record.id + '\')">审核</a>';
                    
                }
                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid + '\')"><img src="' + photo + '" class="photo-img" /></a>';

                }
                if (column.name == "check_state") {
                    var state = record.check_state;
                    var txt = '待审核';
                    var cls = 'gray';
                    if (state == "成功") {
                        txt = '通过';
                        cls = 'blue';
                    }
                    else if (state == "失败") {
                        txt = '失败';
                        cls = 'red';
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';

                }
                if (column.name == "check_cycle") {
                    var dtm = record.create_time;
                    var dtm_check = record.dtm_check;
                    var diff_time = "";
                    if (dtm_check == null) {
                        diff_time = "";
                    } else {
                        dtm = new Date(dtm).getTime();
                        dtm_check = new Date(dtm_check).getTime();
                        diff_time = dtm_check - dtm;
                        var audit_cycle_days = Math.floor(diff_time / (1000 * 60));
                        if (audit_cycle_days < 1) {
                            var second = diff_time / 1000;
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span class="blue">' + second + '秒</span>';
                        }
                        if (audit_cycle_days >= 1 && audit_cycle_days < 60) {
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="font-size: 14px;color:blue;">' + audit_cycle_days + '分钟</span>';
                        }
                        if (audit_cycle_days >= 60 && audit_cycle_days < 60 * 24) {
                            audit_cycle_days = Math.floor(diff_time / (1000 * 60 * 60));
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="color:red;font-size:14px;">' + audit_cycle_days + '小时</span>';
                        }
                        if (audit_cycle_days >= 60 * 24) {
                            audit_cycle_days = Math.floor(diff_time / (1000 * 60 * 60 * 24));
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="color:red;font-size:14px;font-weight: bold;">' + audit_cycle_days + '天</span>';
                        }
                    }

                }

            });
        }

    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#datagrid1").height(parentHeight - 80);
        }

        function bindEvent() {
        }

        function search() {
            var check_state = $("#check_state").val();

            var dtm_start = mini.get("dtm_start").getText();
            var dtm_end = mini.get("dtm_end").getText();

            grid.load({
                "start": dtm_start,
                "end": dtm_end,
                "check_state": check_state
            });
        }
        function Check(id) {
            mini.open({
                url: "/Check/CheckFeedBack/" + id,
                showMaxButton: false,
                title: "审核",
                width: 600,
                height: 350,
                ondestroy: function (action) {
                    grid.reload();
                }
            });
        }

        function dtl(id) {
            var parentHeight = $(window).height();
            var parentWidth = $(window.parent.document).find("#rightFrame").width();
            mini.open({
                url: "/Check/FeedBack_dtl/"+id,
                showMaxButton: false,
                title: "详情",
                width: 450,
                height: parentHeight,
                ondestroy: function (action) {
                   
                }
            });
        }

    </script>
</head>
<body>
    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            开始日期: <input id="dtm_start" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["start"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            截止日期: <input id="dtm_end" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["end"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            状态:<select id="check_state" style="height:24px;">
                <option value="" selected="selected">全部</option>
                <option value="待审核">待审核</option>
                <option value="成功">成功</option>
                <option value="失败">失败</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Check/GetTouSuData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[20,50,100]" pagesize="50">
            <div property="columns">
                <div field="xh" width="8" headeralign="center" align="center" allowsort="false">序号</div>
                <div name="photo" width="10" renderer="onGenderRenderer" align="center" headeralign="center">头像</div>
                <div field="nick" width="15" headeralign="center" align="left" allowsort="false">昵称</div>
                <div field="sex" width="8" headeralign="center" align="center" allowsort="false">性别</div>
                <div field="create_time" width="20" renderer="onGenderRenderer" align="center" headeralign="center">投诉时间</div>
                <div field="brife" width="60" renderer="onGenderRenderer" align="left" headeralign="center">问题描述</div>
                <div field="check_cycle" name="check_cycle" width="10" headeralign="center" align="center" allowsort="false">审核周期</div>
                <div name="check_state" width="10" renderer="onGenderRenderer" align="center" headeralign="center">审核状态</div>
                <div name="dtl" width="23" headeralign="center" align="center" allowsort="false">操作</div>
                <div field="dtm_check" width="20" renderer="onGenderRenderer" align="center" headeralign="center">审核时间</div>
                <div field="rst_check" width="30" renderer="onGenderRenderer" align="left" headeralign="center">审核结果</div>

            </div>
        </div>
    </form>
</body>
</html>
