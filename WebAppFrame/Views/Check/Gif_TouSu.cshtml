

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=12"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 14px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            //grid.load();
            search();
            drawCell();

            init();
            bindEvent();
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                    var uid = record.uid;
                    var amount = record.amount;
                    e.cellStyle = "text-align:center";
                    e.cellHtml += '<a style="color:blue;" href="javascript:LookGiftTouSuDtl(\'' + record.gift_id + '\')">详情</a>';
                    e.cellHtml += '&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;';
                    e.cellHtml += '<a style="color:blue;" href="javascript:CheckGiftTouSu(\'' + record.id + '\')">审核</a>';
                    e.cellHtml += '&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;';
                    e.cellHtml += '<a style="color:blue;" href="javascript:sendWxMsg(\'' + record.uid + '\',' + amount + ')">发送微信消息</a>';
                }
                if (column.name == "acc") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml += '<a>--></a>';
                }
                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;
                    var nick = record.nick;
                    var sex = record.sex;
                    var color = "";
                    if (sex == "男生") {
                        color = "blue";
                    } else {
                        color = "red";
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid + '\')"><img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "<br/>";
                    e.cellHtml += "<span style='color:" + color + "'>" + nick + "(" + sex + ")" + "</span></a>";

                   
                }
                if (column.name == "photo2") {
                    var photo = servUrl_AppData + '/photo/' + record.photo2;

                    var nick2 = record.nick2;
                    var sex2 = record.sex2;
                    var color = "";
                    if (sex == "男生") {
                        color = "blue";
                    } else {
                        color = "red";
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid_to + '\')"><img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "<br/>";
                    e.cellHtml += "<span style='color:" + color + "'>" + nick2 + "(" + sex2 + ")" + "</span></a>";
                }
                if (column.name == "state") {
                    var state = record.state;
                    var txt = '待审核';
                    var cls = 'gray';
                    if (state == "通过") {
                        txt = '通过';
                        cls = 'blue';
                    }
                    else if (state == "失败") {
                        txt = '失败';
                        cls = 'red';
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';

                }
                if (column.name == "check_cycle") {
                    var dtm = record.dtm;
                    var dtm_check = record.dtm_check;
                    var diff_time = "";
                    if (dtm_check == null) {
                        diff_time = "";
                    } else {
                        dtm = new Date(dtm).getTime();
                        dtm_check = new Date(dtm_check).getTime();
                        diff_time = dtm_check - dtm;
                        var audit_cycle_days = Math.floor(diff_time / (1000 * 60));
                        if (audit_cycle_days < 1) {
                            var second = diff_time / 1000;
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span class="blue">' + second + '秒</span>';
                        }
                        if (audit_cycle_days >= 1 && audit_cycle_days < 60) {
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="font-size: 14px;color:blue;">' + audit_cycle_days + '分钟</span>';
                        }
                        if (audit_cycle_days >= 60 && audit_cycle_days < 60 * 24) {
                            audit_cycle_days = Math.floor(diff_time / (1000 * 60 * 60));
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="color:red;font-size:14px;">' + audit_cycle_days + '小时</span>';
                        }
                        if (audit_cycle_days >= 60 * 24) {
                            audit_cycle_days = Math.floor(diff_time / (1000 * 60 * 60 * 24));
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="color:red;font-size:14px;font-weight: bold;">' + audit_cycle_days + '天</span>';
                        }
                    }

                }
                if (column.name == "gift_time") {
                    var dtm = record.gift_time;
                    if (dtm == null) { dtm = ''; }
                    else { dtm = dtm.replace(' ', '<br/>'); }

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="blue">' + dtm + '</span>';
                }
                if (column.name == "dtm") {
                    var dtm = record.dtm;
                    if (dtm == null) { dtm = ''; }
                    else { dtm = dtm.replace(' ', '<br/>'); }

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span style="color:#e77c10;font-size: 14px;font-weight: bold;">' + dtm + '</span>';
                }


            });
        }

    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#datagrid1").height(parentHeight - 80);
        }

        function bindEvent() {
        }

        function search() {
            var check_state = $("#check_state").val();

            var dtm_start = mini.get("dtm_start").getText();
            var dtm_end = mini.get("dtm_end").getText();

            grid.load({
                "start": dtm_start,
                "end": dtm_end,
                "check_state": check_state
            });
        }


        function LookGiftTouSuDtl(id) {
            var parentHeight = $(window).height();;
            var parentWidth = $(window.parent.document).find("#rightFrame").width();
            mini.open({
                url: "/Check/Gif_TouSuDtl/" + id,
                showMaxButton: false,
                title: "查看详情",
                width: 500,
                height: parentHeight-5,
                ondestroy: function (action) {

                }
            });
        }
        function CheckGiftTouSu(id) {
            mini.open({
                url: "/Check/CheckGiftTouSu/" + id,
                showMaxButton: false,
                title: "审核",
                width: 600,
                height: 350,
                ondestroy: function (action) {
                    grid.reload();
                }
            });
        }

        function sendWxMsg(uid, amount) {
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            var parentWidth = $(window.parent.document).find("#rightFrame").width();
            var dtm = '@ViewData["dtm"]';

            mini.open({
                url: "/Admin1/SendWxMsg_lwts/?uid=" + uid + "&amount=" + amount + "&dtm=" + dtm,
                showMaxButton: false,
                title: "发送微信通知",
                width: 600,
                height: 400,
                ondestroy: function (action) {
                    if (action == "ok") {
                    }
                    else if (action == "cancel") {

                    }
                }
            });
        }

    </script>
</head>
<body>
    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            开始日期: <input id="dtm_start" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["start"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            截止日期: <input id="dtm_end" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["end"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            状态:<select id="check_state" style="height:24px;">
                <option value="" selected="selected">全部</option>
                <option value="待审核">待审核</option>
                <option value="通过">通过</option>
                <option value="失败">失败</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Check/GetGifTouSuData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[20,50,100]" pagesize="50">
            <div property="columns">
                <div field="xh" width="5" headeralign="center" align="center" allowsort="false">序号</div>
                @*<div field="uid" width="17" renderer="onGenderRenderer" align="left" headeralign="center">uid</div>*@
                <div name="photo" width="10" renderer="onGenderRenderer" align="center" headeralign="center">投诉者</div>
                <div name="acc" width="10" renderer="onGenderRenderer" align="center" headeralign="center">--></div>
                <div name="photo2" width="10" renderer="onGenderRenderer" align="left" headeralign="center">被投诉者</div>
                <div name="gift_time" width="13" renderer="onGenderRenderer" align="center" headeralign="center">发送礼物时间</div>
                <div field="comment" width="8" renderer="onGenderRenderer" align="center" headeralign="center">投诉礼物</div>
                <div field="amount" width="8" renderer="onGenderRenderer" align="right" headeralign="center">消耗金币</div>
                <div name="dtm" width="13" renderer="onGenderRenderer" align="center" headeralign="center">投诉时间</div>
                <div field="brife" width="18" renderer="onGenderRenderer" align="left" headeralign="center">投诉详情</div>

                <div name="dtl" width="25" headeralign="center" align="center" allowsort="false">操作</div>

                <div field="check_cycle" name="check_cycle" width="10" headeralign="center" align="center" allowsort="false">审核周期</div>
                <div field="state" name="state" width="8" renderer="onGenderRenderer" align="center" headeralign="center">审核状态</div>
                <div field="dtm_check" width="15" renderer="onGenderRenderer" align="center" headeralign="center">审核时间</div>
                <div field="rst_check" width="30" renderer="onGenderRenderer" align="left" headeralign="center">审核结果</div>


            </div>
        </div>
    </form>
</body>
</html>
