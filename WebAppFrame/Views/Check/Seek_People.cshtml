

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=100"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            color: #f00;
        }

        .blue {
            font-size: 14px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }
        .txt {
            height: 22px;
            line-height: 22px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding-left: 5px;
            width: 160px;
        }
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            //grid.load();
            search();
            drawCell();

            init();
            bindEvent();
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                   
                    e.cellStyle = "text-align:center";
                    e.cellHtml += '<a style="color:blue;" href="javascript:Check(\'' + record.id + '\',\'通过\')">通过</a>';
                    e.cellHtml += '&nbsp;&nbsp;';
                    e.cellHtml += '<a style="color:blue;" href="javascript:Check(\'' + record.id + '\',\'失败\')">不通过</a>';
                }
                if (column.name == "dtl2") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml += '<a style="color:blue;" href="javascript:WxCheck(\'' + record.id + '\',\'正确\')">正确</a>';
                    e.cellHtml += '&nbsp;&nbsp;';
                    e.cellHtml += '<a style="color:blue;" href="javascript:WxCheck(\'' + record.id + '\',\'错误\')">错误</a>';
                }
                if (column.name == "dtl3") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml += '<a style="color:blue;" href="javascript:top_tie(\'' + record.id + '\')">置顶</a>';
                }
                //头像昵称性别
                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;
                    var nick = record.nick;
                    var sex = record.sex;
                    var color = "";
                    if (sex == "男生") {
                        color = "blue";
                    } else {
                        color = "red";
                    }

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid + '\')"><img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "<br/>";
                    e.cellHtml += "<span style='color:" + color + "'>" + nick + "(" + sex + ")" + "</span></a>";
                }
                //审核状态
                if (column.name == "state") {
                    var state = record.state;
                    var txt = '待审核';
                    var cls = 'gray';
                    if (state == "通过") {
                        txt = '通过';
                        cls = 'blue';
                    }
                    else if (state == "失败") {
                        txt = '失败';
                        cls = 'red';
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';

                }
                //审核周期
                if (column.name == "check_cycle") {
                    var dtm = record.create_time;
                    var dtm_check = record.dtm_check;
                    var diff_time = "";
                    if (dtm_check == "2020-03-05 00:00:00 ") {
                        diff_time = "";
                    } else {
                        dtm = new Date(dtm).getTime();
                        dtm_check = new Date(dtm_check).getTime();
                        diff_time = dtm_check - dtm;
                        var audit_cycle_days = Math.floor(diff_time / (1000 * 60));
                        if (audit_cycle_days < 1) {
                            var second = diff_time / 1000;
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span class="blue">' + second + '秒</span>';
                        }
                        if (audit_cycle_days >= 1 && audit_cycle_days < 60) {
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="font-size: 14px;color:blue;">' + audit_cycle_days + '分钟</span>';
                        }
                        if (audit_cycle_days >= 60 && audit_cycle_days < 60 * 24) {
                            audit_cycle_days = Math.floor(diff_time / (1000 * 60 * 60));
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="color:red;font-size:14px;">' + audit_cycle_days + '小时</span>';
                        }
                        if (audit_cycle_days >= 60 * 24) {
                            audit_cycle_days = Math.floor(diff_time / (1000 * 60 * 60 * 24));
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="color:red;font-size:14px;font-weight: bold;">' + audit_cycle_days + '天</span>';
                        }
                    }

                }
                //微信状态
                if (column.name == "wxcheck") {
                    var txt = '';
                    var wxcheck = record.wxcheck;
                    if (wxcheck == "正确") {
                        txt = '正确';
                        cls = 'blue';
                    }
                    else if (wxcheck == "错误") {
                        txt = '错误';
                        cls = 'red';
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';

                }
                if (column.name == "create_time") {
                    var create_time = record.create_time;
                    create_time = create_time.replace(" ", "<br/>");
                    e.cellHtml = '<span>' + create_time + '</span>';
                }
                if (column.name == "dtm_check") {
                    var dtm_check = record.dtm_check;
                    dtm_check = dtm_check.replace(" ", "<br/>");
                    e.cellHtml = '<span>' + dtm_check + '</span>';
                }
                if (column.name == "dtm_wxcheck") {
                    var dtm_wxcheck = record.dtm_wxcheck;
                    dtm_wxcheck = dtm_wxcheck.replace(" ", "<br/>");
                    e.cellHtml = '<span>' + dtm_wxcheck + '</span>';
                }
                if (column.name == "refurbish_time") {
                    var refurbish_time = record.refurbish_time;
                    refurbish_time = refurbish_time.replace(" ", "<br/>");
                    e.cellHtml = '<span>' + refurbish_time + '</span>';
                }

            });
        }
    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#datagrid1").height(parentHeight - 80);

            $("#sort").change(function () {
                search();
            });
        }


        function bindEvent() {
        }


        function search() {
            var c_type = $("#c_type").val();
            var sort = $("#sort").val();
            var dtm_start = mini.get("dtm_start").getText();
            var dtm_end = mini.get("dtm_end").getText();
            var key = $("#key").val();
            var publish_uid = $("#publish_uid").val();


            grid.load({
                "start": dtm_start,
                "end": dtm_end,
                "c_type": c_type,
                "sort": sort,
                "key": key,
                "publish_uid": publish_uid
            });
        }

        function Check(id, state) {
            // 获取当前登录者信息
            var operator_name = getCurrentOperator();
            
            $.ajax({
                type: "get",
                url: "/Check/Check_Seek_people",
                data: { "id": id, "state": state, "operatorName": operator_name },
                success: function (data) {
                    var data = JSON.parse(data);
                    if (data.state == '1') {
                        grid.reload();
                    }

                }
            });
        }

        function WxCheck(id, wxcheck) {
            $.ajax({
                type: "get",
                url: "/Check/WxCheck_Seek_people",
                data: { "id": id, "wxcheck": wxcheck },
                success: function (data) {
                    var data = JSON.parse(data);
                    if (data.state == '1') {
                        grid.reload();
                    }

                }
            });
        }

        function top_tie(id) {
            $.ajax({
                type: "get",
                url: "/Check/ReFresh",
                data: { "id": id},
                success: function (data) {
                    //console.log(data);
                    var data = JSON.parse(data);
                    if (data == '1') {
                        grid.reload();
                   }

                }
            });
        }

    </script>
</head>
<body>
    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            起始时间: <input id="dtm_start" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["start"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            截止时间: <input id="dtm_end" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["end"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            状态:
            <select id="c_type" style="height:24px;">
                <option value="" selected="selected">全部</option>
                <option value="未审核">未审核</option>
                <option value="通过">通过</option>
                <option value="失败">失败</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;

            排序:
            <select id="sort" style="height:24px;">
                <option value="comment asc, create_time desc" selected="selected">默认</option>
                <option value="refurbish_time desc">刷新时间</option>
                <option value="create_time desc">发布时间</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;

            关键词:<input type="text" class="txt" id="key" />&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            uid:<input type="text" class="txt" id="publish_uid" />&nbsp;&nbsp;&nbsp;&nbsp;

            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />

        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Check/GetSeekpeopleData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[20,50,100]" pagesize="50">
            <div property="columns">
                <div field="xh" width="20" headeralign="center" align="center" allowsort="false">序号</div>
                <div name="create_time" width="45" renderer="onGenderRenderer" align="center" headeralign="center">发布时间</div>
                <div name="photo" width="65" headeralign="center" align="center" allowsort="false">头像</div>
                <div field="title" width="90" renderer="onGenderRenderer" align="left" headeralign="center">标题</div>
                <div field="content" width="160" headeralign="center" align="left" allowsort="false">详情</div>
                <div field="check_cycle" name="check_cycle" width="50" headeralign="center" align="center" allowsort="false">审核周期</div>
                <div field="state" name="state" width="35" headeralign="center" align="center" allowsort="false">审核状态</div>
                <div name="dtm_check" width="45" headeralign="center" align="center" allowsort="false">审核时间</div>
                <div field="comment" width="45" renderer="onGenderRenderer" align="left" headeralign="center">备注</div>
                <div name="dtl" width="50" headeralign="center" align="center" allowsort="false">操作</div>

                <div field="wx" width="60" renderer="onGenderRenderer" align="left" headeralign="center">微信</div>
                <div name="wxcheck" width="35" headeralign="center" align="center" allowsort="false">微信状态</div>
                <div name="dtm_wxcheck" width="45" headeralign="center" align="center" allowsort="false">时间</div>
                <div name="dtl2" width="45" headeralign="center" align="center" allowsort="false">微信操作</div>


                <div name="refurbish_time" width="50" headeralign="center" align="left" allowsort="false">刷新时间</div>
                <div field="refurbish_count" width="30" headeralign="center" align="center" allowsort="false">次数</div>

                <div name="dtl3" width="30" headeralign="center" align="center" allowsort="false">置顶</div>

            </div>
        </div>
    </form>
</body>
</html>
