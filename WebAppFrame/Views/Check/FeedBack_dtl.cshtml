<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/demo.css" rel="stylesheet" type="text/css" />
    <script src="~/Scripts/jquery-1.8.2.min.js"></script>
    <style>
        .btn {
            margin-top: 20px;
            color: white;
            font-weight: 500;
            font-size: 18px;
            line-height: 30px;
            bottom: 0;
            border: 1px solid RGB(62,175,224);
            border-radius: 5px;
            width: 40%;
            cursor: pointer;
        }

        .ok {
            background-color: RGB(62,175,224);
        }

        .no {
            background-color: #f00;
        }

        .main {
            margin-top: 5px;
            display: flex;
            justify-content: center;
            padding:12px;
        }

        #form1 {
            
        }

        .nan {
            font-size: 18px;
            color: #3eafe0;
        }

        .nv {
            font-size: 18px;
            color: #de61a6;
        }

        .dtl {
            
        }
        .img-block{

        }
        .tit {
            display: inline-block;
            font-size: 16px;
            font-weight: 600;
            width:75px;
            margin:10px 0;
        }

        .dtl textarea {
            resize: none;
            width: 350px;
            height: 200px;
            padding: 10px 15px;
            font-size: 17px;
            line-height: 25px;
           border:solid .5px #333;
        }
        .dtl textarea:focus {
            border:solid 1px RGB(62,175,224);
        }
        .img {
            width: 350px;
            margin: 10px 0;
            border: .5px dashed #333;
        }
    </style>
    <script type="text/javascript">
        var data = '@Html.Raw(ViewData["data"])';
        var id = '@ViewData["id"]';
        $(function () {
          
            $.ajax({
                type: "POST",
                url: "/Check/Get_FeedBack_dtl",
                data: { "id": id },
                success: function (data) {
                    var data = JSON.parse(data);
                    $("#brife").val(data.brife);
                    var pic = data.pics;
                    pic = JSON.parse(pic)
                    var h = '';
                    for (var i = 0; i < pic.length; i++) {
                        h += ' <img src="' + pic[i] + '" class="img" />'
                    }
                    $("#img_con").html(h);
                }
            });
        });
       

        function CloseWindow(action) {
            if (window.CloseOwnerWindow) return window.CloseOwnerWindow(action);
            else window.close();
        }
    </script>
</head>
<body>
    <div class="main">
        <form id="form1">
            <div class="dtl">
                <span class="tit">问题描述:</span><br />
                <textarea id="brife" readonly="readonly"></textarea>
            </div>
            <div class="img-block">
                <span class="tit">问题图片:</span>
                <div id="img_con">
                    <img class="img" />
                </div>
            </div>
        </form>
    </div>
</body>
</html>
