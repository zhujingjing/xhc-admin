<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/demo.css" rel="stylesheet" type="text/css" />
    <style>
       .btn {
            margin-top: 20px;
            color: white;
            font-weight: 500;
            font-size: 18px;
            line-height: 30px;
            bottom: 0;
            border: 1px solid RGB(62,175,224);
            border-radius: 5px;
            width:30%;
            cursor: pointer;
            height:40px;
        }

        .ok {
            background-color: RGB(62,175,224);
        }

        .no {
            background-color: #f00;
        }

        #form1 {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 10px 30px;
        }

        .check {
            display: flex;
            justify-content: space-around;
        }

        textarea {
            padding: 6px 8px;
            height: 80px;
            margin-top: 10px;
            line-height: 20px;
            margin-bottom: 5px;
            border-radius: 5px;
            border: solid 1px #dcdcdc;
            height: 150px;
            font-size: 18px;
            resize: none;
            outline: none;
        }
    </style>
</head>
<body>
    <div class="main">
        <div class="">
            <form id="form1">
                <select id="slt_txt" style="width:100%; height:28px; line-height:28px;">
                    <option value="嗯呢，好的，你加我们客服微信，专属客服为你解决这个问题，客服微信：xhczjj201712，添加时请备注【解决问题】" selected>嗯呢，好的，你加我们客服微信，专属客服为你解决这个问题，客服微信：xhczjj201712，添加时请备注【解决问题】</option>
                    <option value="你好，此问题我们正在努力解决，请大家放心，我们的技术很厉害，大家账户里的金币和积分都不会受到任何影响；后续出现类似问题请在第一时间与客服反馈，致辞感谢。">你好，此问题我们正在努力解决，请大家放心，我们的技术很厉害，大家账户里的金币和积分都不会受到任何影响；后续出现类似问题请在第一时间与客服反馈，致辞感谢。</option>
                    <option value="嗯呢，这是很好的建议，下一版会考虑把这个功能加进来的">嗯呢，这是很好的建议，下一版会考虑把这个功能加进来的</option>
                </select>

                <textarea id="reason"></textarea>
                <div class="check">
                    <input type="button" id="btnok" class="btn ok" value="通过" />
                    <input type="button" id="btnno" class="btn no" value="不通过" />
                </div>
            </form>
        </div>
    </div>
</body>
</html>

<script src="~/Scripts/jquery-1.8.2.min.js"></script>

<script type="text/javascript">
    $(function () {
        $("#slt_txt").change(function () {
            var txt = $("#slt_txt").val();
            $("#reason").text(txt);
        });

        var txt = $("#slt_txt").val();
        $("#reason").text(txt);
    });



    $("#btnok").bind("click", function () {
        doCheck('成功');
    })

    $("#btnno").bind("click", function () {
        doCheck('失败');
    })

    function doCheck(rst) {

        var id = '@ViewData["id"]';
        var rst_check = $("#reason").val();
        $.ajax({
            type: "get",
            url: "/Check/Update_Check_TouSu",
            data: { "id": id, "rst_check": rst_check, "rst": rst },
            success: function (data) {
                var data = JSON.parse(data);
                if (data.state == "1") {
                    alert("审核成功");
                } else {
                    alert("审核失败");
                }
                CloseWindow("ok");
            }
        });
    }

    function CloseWindow(action) {
        if (window.CloseOwnerWindow) return window.CloseOwnerWindow(action);
        else window.close();
    }
</script>