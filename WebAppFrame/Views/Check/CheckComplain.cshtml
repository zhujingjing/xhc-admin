<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/demo.css" rel="stylesheet" type="text/css" />
    <style>
        .btn {
            margin-top: 20px;
            color: white;
            font-weight: 500;
            font-size: 18px;
            line-height: 30px;
            bottom: 0;
            border: 1px solid RGB(62,175,224);
            border-radius: 5px;
            cursor: pointer;
            height: 40px;
            padding:0 15px;
        }

        .ok {
            background-color: RGB(62,175,224);
           flex-grow:1;
        }

        .no {
            background-color: #f00;
            margin-left:30px;
        }

        #form1 {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 10px 30px;
        }

        .check {
            display: flex;
            justify-content: space-around;
        }

        textarea {
            padding: 6px 8px;
            height: 60px;
            margin-top: 10px;
            line-height: 20px;
            margin-bottom: 5px;
            border-radius: 5px;
            border: solid 1px #dcdcdc;
            height: 150px;
            font-size: 18px;
            resize: none;
            outline: none;
        }
    </style>
</head>
<body>
    <div class="main">
        <div class="">
            <form id="form1">
                <select id="slt_txt" style="width:100%; height:28px; line-height:28px;">
                    <option value="忽略" selected>忽略</option>
                    <option value="已警告">已警告</option>
                    <option value="已封号">已封号</option>
                </select>

                <textarea id="reason">忽略</textarea>

                <div class="check">
                    <input type="button" id="btnok" class="btn ok" value="通过" />
                    <input type="button" id="btnno" class="btn no" value="不通过" />
                </div>
            </form>
        </div>
    </div>
</body>
</html>

<script src="~/Scripts/jquery-1.8.2.min.js"></script>

<script type="text/javascript">
    $(function () {
      
    });
   

    $("#slt_txt").change(function () {
        var txt = $("#slt_txt").val();
        $("#reason").text(txt);
    });

    $("#btnok").bind("click", function () {
        doCheck('成功');

    })

    $("#btnno").bind("click", function () {
        doCheck('失败');
    })

    function doCheck(rst) {

        var id = '@ViewData["id"]';
       
        var rst_check = $("#reason").val();
        $.ajax({
            type: "get",
            url: "/Check/Update_Check_Complain",
            data: { "id": id, "rst_check": rst_check, "rst": rst },
            success: function (data) {
                var data = JSON.parse(data);
                if (data.state == "1") {
                } else {
                    alert("审核失败");
                }
                CloseWindow("ok");
            }
        });
    }

    function CloseWindow(action) {
        if (window.CloseOwnerWindow) return window.CloseOwnerWindow(action);
        else window.close();
    }
</script>