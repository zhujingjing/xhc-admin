

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=5"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 14px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }

        .c1 {
            font-size: 22px;
            line-height: 28px;
            height: 28px;
            color: blue;
            font-weight: bold;
        }

        .vip {
            color: red;
            font-weight: bold;
            
        }
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            grid.load();
           
            drawCell();

            init();
            
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:user_dtl(\'' + record.uid + '\')">---</a>';
                }

                if (column.name == "TableName") {
                    var dtm = record.TableName;
                    
                    e.cellHtml = '<span class="blue">'+dtm+'</span>';
                }
                if (column.name == "TotalRows") {
                    var dtm = record.TotalRows;
                    e.cellHtml = '<span class="red">' + dtm + '</span>';
                }
                if (column.name == "SpaceUsed") {
                    var dtm = record.SpaceUsed;
                    e.cellHtml = '<span class="red">' + dtm + '</span>';
                }

            });
        }
    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 65);
        }

        function bindEvent() {
        }


       

    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">数据库</a></li>
        </ul>
    </div>
    <form id="form1">
        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Admin1/Get_Sys_DB" idfield="id" allowresize="true" multiselect="true"
             sizelist="[50,100,300,500]" pagesize="300">
            <div property="columns">
                <div field="TableName" name="TableName" width="100" renderer="onGenderRenderer" align="left" headeralign="center">表名</div>
                <div field="TotalRows" name="TotalRows" width="100" renderer="onGenderRenderer" align="right" headeralign="center">行数</div>
                <div field="SpaceUsed" name="SpaceUsed" width="90" headeralign="center" align="right" allowsort="false">占用空间</div>
                <div name="dtl" width="800" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>
