﻿<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>@ViewData["nick"]</title>
    <link href="~/Styles/public.css" rel="stylesheet" />
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }
        .empty {
            display: none;
        }
    </style>
    <script type="text/javascript">
        $(function () {
            
            var user_type = '@ViewData["user_type"]';
            
            if (user_type == "普通用户") {
                $("#ordinary").show();
            }
            else if (user_type == "平台管理员") {
                $("#admin").show();
            }
        })
        
    </script>
    <script>
        function onTabsActiveChanged() {
        }
    </script>
</head>
<body>
    <div id="admin" showcollapsebutton="false" style="border:0px; display:none; width:100%; height:100%;">
        <div id="mainTabs" class="mini-tabs" activeindex="0" style="width:100%;height:100%;"
             onactivechanged="onTabsActiveChanged" plain="false">

            <div title="汇总" url="/Admin1/User_Sum/@ViewData["id"]"></div>
            <div title="金币" url="/Admin1/User_Coin/@ViewData["id"]"></div>
            <div title="积分" url="/Admin1/User_Score/@ViewData["id"]"></div>
            <div title="消息收入" url="/Admin1/User_ChatScore/@ViewData["id"]"></div>
            <div id="id_chatdtl" title="聊天对话" url="/Admin1/User_Chart/@ViewData["id"]"></div>
           

            <div title="总体活动图" url="/Admin1/User_Live/@ViewData["id"]"></div>

            

            <div title="登录记录" url="/Admin1/User_Login/@ViewData["id"]"></div>
            <div title="匹配记录" url="/Admin1/User_Match/@ViewData["id"]"></div>
            <div id="id_msgdtl" title="聊天详情" url="/Admin1/User_Msg/@ViewData["id"]"></div>
           
           
            <div title="投诉" url="/Admin1/TouSu_Record/@ViewData["id"]"></div>
            <div title="被投诉" url="/Admin1/User_Complain/@ViewData["id"]"></div>
            <div title="封号警告" url="/Admin1/User_Kill/@ViewData["id"]"></div>

            <div title="沟通记录" url="/Admin1/User_Record/@ViewData["id"]"></div>
            <div title="基本信息" url="/Admin1/User_Base/@ViewData["id"]"></div>
            


        </div>
    </div>

    <div id="ordinary" showcollapsebutton="false" style="border:0px; display:none; width:100%; height:100%;">
        <div id="mainTabs" class="mini-tabs" activeindex="0" style="width:100%;height:100%;"
             onactivechanged="onTabsActiveChanged" plain="false">

            <div title="汇总" url="/Admin1/User_Sum/@ViewData["id"]"></div>
            <div title="金币" url="/Admin1/User_Coin/@ViewData["id"]"></div>
            <div title="积分" url="/Admin1/User_Score/@ViewData["id"]"></div>
            <div title="消息收入" url="/Admin1/User_ChatScore/@ViewData["id"]"></div>
            <div id="id_chatdtl" title="聊天对话" url="/Admin1/User_Chart/@ViewData["id"]"></div>

            <div title="总体活动图" url="/Admin1/User_Live/@ViewData["id"]"></div>

            <div title="登录记录" url="/Admin1/User_Login/@ViewData["id"]"></div>
            <div title="匹配记录" url="/Admin1/User_Match/@ViewData["id"]"></div>

            <div title="投诉" url="/Admin1/TouSu_Record/@ViewData["id"]"></div>
            <div title="被投诉" url="/Admin1/User_Complain/@ViewData["id"]"></div>
            <div title="封号警告" url="/Admin1/User_Kill/@ViewData["id"]"></div>

            <div title="沟通记录" url="/Admin1/User_Record/@ViewData["id"]"></div>
            <div title="基本信息" url="/Admin1/User_Base/@ViewData["id"]"></div>
            


        </div>
    </div>
</body>
</html>