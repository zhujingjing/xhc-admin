    <style>
        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        #chat_dtl {
            overflow-x: hidden;
            overflow-y: scroll;
            border: solid 1px #dcdcdc;
            background-color: RGB(239,239,244);
        }

        .font-bold {
            font-weight: bold;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
        }

        .size-x {
            font-size: 14px;
            color: blue;
        }
        .size-xx {
            font-size: 14px;
            font-weight: bold;
            color: blue;
        }
        .size-xxx {
            font-size: 18px;
            font-weight: bold;
            color: blue;
        }

        .gray{
            color:red;
        }

        .msg-rece {
            display:flexbox;
            border:solid 1px red;
            padding:8px;
