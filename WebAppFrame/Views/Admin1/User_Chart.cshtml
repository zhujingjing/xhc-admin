    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
       
        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent).height();
            $("#datagrid1,#chat_dtl").height(parentHeight - 160);

            mini.parse();

            grid = mini.get("datagrid1");

            //grid.load();

            drawCell();

            init();

            search();

            $("#sort").change(function () {
                search();
            });

            $("#data_from").change(function () {
                search();
            });

            
        })

        function init() {
           
        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;
                
                //时间
                if (column.name == "time_start") {
                    var dtm = record.time_start;
                    if (dtm == null) { dtm = ''; }
                    else { dtm = dtm.replace(' ', '<br/>'); }

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="dtm">' + dtm + '</span>';
                }

                if (column.name == "info") {
                    var day = 24 * 60 * 60 * 1000;
                    var reg_time = Math.floor((Date.now() - new Date(record.create_time).getTime()) / day);
                    var scoreTotal = record.score_total;
                    var coinTotal = record.coin_total;
                    var score = record.score;
                    var coin = record.coin;
                    var vip = record.member;
                    var remark =  record.remark;
                    e.cellHtml = '';
                    e.cellHtml += '<div style="display: flex; flex-direction: column;">';
                    //e.cellHtml += '<div><span style="color:#666;">备注:</span><span style="color:red;">' + remark + '</span></div>';
                    e.cellHtml += '<div><span style="color:#666;">时长:</span><span style="color:red;">' + reg_time + '天</span></div>';
                    e.cellHtml += '<div><span style="color:#666;">豪:</span><span style="color:red;">' + coinTotal + '</span>-<span style="color:blue;">' + coin + '</span></div>';
                    e.cellHtml += '<div><span style="color:#666;">魅:</span><span style="color:red;">' + scoreTotal + '</span>-<span style="color:blue;">' + score + '</span></div>';
                    e.cellHtml += '</div>';
                }   
                if (column.name == "score") {
                    var score_today = record.s;
                    var coin_today = record.c;
                    if(score_today == null) score_today = 0;
                    if(coin_today == null) coin_today = 0;

                    var html = '';
                    html += '<div>' ;
                    if(coin_today)
                    {
                        html += '<div><span style="color:#666;">金币:</span><span style="color:red;">' + coin_today + '</span></div>';
                    }
                    if(score_today)
                    {
                        html += '<div><span style="color:#666;">积分:</span><span style="color:blue;">' + score_today + '</span></div>';
                    }
                    html += '</div>';
                    e.cellHtml = html;
                }

                //是否对方发起会话
                if (column.name == "diff_first") {
                    var diff_first = record.diff_first;

                    var cls = '';
                    var txt = 0;
                    if (diff_first == null ) {
                        txt = '未响应';
                        cls = 'gray';
                    }
                    else if (diff_first < 0) {
                        //对方发起的会话
                        if (diff_first <= -60) {
                            txt = (diff_first / 60).toFixed(0) + '分钟';
                        } else {
                            txt = diff_first + '秒';
                        }
                        cls = 'msg-rece';
                    }
                    else {
                        //自己发起的
                        if (diff_first >= 60) {
                            txt = (diff_first / 60).toFixed(0) + '分钟';
                        } else {
                            txt = diff_first + '秒';
                        }
                        cls = 'size-x';
                    }


                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';
                }

                //持续时长
                if (column.name == "sec_diff") {
                    var time_start = record.time_start;
                    var time_end = record.time_end;
                    var sec_diff = record.sec_diff;

                    var tiaoshu_receive = record.tiaoshu_receive;

                    var cls = '';
                    var txt = 0;
                    if (sec_diff) {
                        txt = DateDiff_Txt(time_start, time_end);
                        if (txt.indexOf("天") > -1) {
                            cls = 'size-xxx';
                        }
                        if (txt.indexOf("小时") > -1) {
                            cls = 'size-xxx';
                        }
                        if (txt.indexOf("分钟") > -1) {
                            cls = 'size-xx';
                        }
                        if (txt.indexOf("秒") > -1) {
                            cls = 'size-x';
                        }
                    }
                    else {
                        txt = sec_diff;
                        cls = 'gray';
                    }

                    if (tiaoshu_receive == 0) {
                        cls = 'gray';
                    }



                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';
                }

                //消息条数
                if (column.name == "tiaoshu") {
                    var txt = record.tiaoshu;
                    

                    var color = '';
                    if (txt == 1) {
                        color = "gray";
                    }
                    else {
                        color = "size-xx";
                    }

                    

                    if (record.sec_diff == 0 || record.tiaoshu_receive == 0) {
                        color = "gray";
                    }
                   

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + color + '">' + txt + '</span>';
                }

                if (column.name == "tiaoshu_receive") {
                    var txt = record.tiaoshu_receive;


                    var color = '';
                    if (record.tiaoshu_receive > 0) {
                        color = "size-xx";
                    }

                    if (record.sec_diff == 0 || record.tiaoshu_receive == 0) {
                        color = "gray";
                    }   


                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + color + '">' + txt + '</span>';
                }

                //消息内容
                if (column.name == "txt") {
                    var txt = record.txt;
                    var type = record.type;
                    var state = record.state;
                    var txt_state = '';

                    var color = '';
                    if (state == "success") { color = "blue"; txt_state = '成功'; }
                    if (state == "fail") { color = "red"; txt_state = '失败'; }

                    e.cellStyle = "text-align:left";
                    e.cellHtml = '<span style="color:' + color + '">' + txt + '</span>';
                }



                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:dtl(\'' + record.uid_from + '\', \'' + record.uid_to + '\')">详情</a>';
                }

                if (column.name == "photo2") {
                    var photo = servUrl_AppData + '/photo/' + record.photo2;
                    var nick = record.nick2;
                    var sex = record.sex2;
                    var chat_mny_score = record.chat_mny_score;
                    var chat_mny_score2 = record.chat_mny_score2;
                    var remark =  record.remark;
                    if(remark != null){
                        nick = remark;
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid_to + '\',500,1300)"><img src="' + photo + '" class="photo-img" /><br/>';
                    e.cellHtml += nick + "<br/>(" + sex + ")";
                    e.cellHtml += "&nbsp;&nbsp;" + chat_mny_score + "-" + chat_mny_score2;
                    e.cellHtml += "</a>";
                }

            });
        }


        function dtl(from, to) {

            var dtm = mini.get("dtm").getText();
            ChartAB(dtm, from, to);
        }

        function evaluateChat(uidFrom, uidTo, dtm, coinUsed, scoreEarned, sendCount, receiveCount) {
            // 计算聊天深度（取发送量和接收量的最小值）
            var chatDepth = chat_deep;
            
            var url = "/Admin1/Chat_Check_Add?uidFrom=" + uidFrom + "&uidTo=" + uidTo + "&dtm=" + dtm + "&coinUsed=" + coinUsed + "&scoreEarned=" + scoreEarned + "&sendCount=" + sendCount + "&receiveCount=" + receiveCount + "&chatDepth=" + chatDepth;
            mini.open({
                url: url,
                showMaxButton: false,
                title: "聊天审核评价",
                width: 800,
                height: 600,
                onload: function () {
                    var iframe = this.getIFrameEl();
                },
                ondestroy: function (action) {
                    if (action == "ok") {
                        // 可以选择是否刷新列表
                    }
                }
            });
        }

        function evaluateSelectedChats() {
            var selectedRows = grid.getSelecteds();
            if (selectedRows.length == 0) {
                mini.alert("请先选择要评价的聊天记录");
                return;
            }
            
            // 只处理选中的第一行记录
            var row = selectedRows[0];
            // 依次提取参数
            var uidFrom = row.uid_from;
            var uidTo = row.uid_to;
            var timeStart = row.time_start;
            var coinUsed = row.c;
            var scoreEarned = row.s;
            var sendCount = row.tiaoshu;
            var receiveCount = row.tiaoshu_receive;
            
            // 这里可以添加参数处理逻辑
            // 只保留日期部分（去掉时间）
            var timeStart = timeStart.split(' ')[0];
            
            // 调用评价函数
            evaluateChat(uidFrom, uidTo, timeStart, coinUsed, scoreEarned, sendCount, receiveCount);
        }

        function showTransactionDetails() {
            var selectedRows = grid.getSelecteds();
            if (selectedRows.length == 0) {
                mini.alert("请先选择要查看交易情况的聊天记录");
                return;
            }
            
            // 只处理选中的第一行记录
            var row = selectedRows[0];
            var userA = row.uid_from;
            var userB = row.uid_to;
            
            // 打开交易情况弹窗
            mini.open({
                url: "/Admin1/TransactionDetails?userA=" + userA + "&userB=" + userB,
                showMaxButton: false,
                title: "二人历史统计",
                width: 980,
                height: 720,
                onload: function () {
                    var iframe = this.getIFrameEl();
                },
                ondestroy: function (action) {
                    if (action == "ok") {
                        // 可以选择是否刷新列表
                    }
                }
            });
        }

        function onRowClick(e) {
            var item = e.record;
            $('.messages').html('');
            $("#btn_msg_more").show();
            $("#btn_msg_more_after").show();
            photo_to = servUrl_AppData + '/photo/' + item.photo2;

            uid_from = item.uid_from;
            uid_to = item.uid_to;
            sex_to = item.sex2;
            var dtm = mini.get("dtm").getText();

            var start = dtm + " 00:00:00";
            var end =  dtm + " 23:59:59";
        
            //重置历史数据日期
            pre_time = start;
            after_time = start;

            $.ajax({
                type: "GET",
                url: "/Admin1/GetChartA_B",
                data: { "start": start, "end": end, "from": uid_from, "to": uid_to },
                success: function (data) {
                    data = JSON.parse(data);
                    show_msg(data);
                    var htmlTxt = '<div class="fg-line">' + start.substr(0, 10) + '</div>';
                    $(".messages").prepend(htmlTxt);
                    // 计算聊天深度
                    chat_deep = calculateChatDepth(data);
                    $("#chat_deep").text(chat_deep);
                }
            });

            initUserSum();
        }


        function search() {
            var dtm = mini.get("dtm").getText();
            var sort = $("#sort").val();
            var data_from =  $("#data_from").val();
            grid.load({
                "dtm": dtm,
                "sort": sort,
                "data_from":data_from
            });
        }

        function jump_date(num) {
            var d = new Date(mini.get("dtm").getText());

            d.setDate(d.getDate() + num);
            var dtm = formatTime(d);
            mini.get("dtm").setValue(dtm);
            search();
        }

        function formatTime(date) {
            var year = date.getFullYear();
            var month = date.getMonth() + 1, month = month < 10 ? '0' + month : month;
            var day = date.getDate(), day = day < 10 ? '0' + day : day;
            return year + '-' + month + '-' + day;
        }


        function onDrawSummaryCell(e) {
            var result = e.result;
            var grid = e.sender;

            //客户端汇总计算
            if (e.field == "tiaoshu" || e.field == "tiaoshu_receive") {
                e.cellStyle = "text-align:right";
                e.cellHtml = '<span style="display:inline-block;margin:12px 0; font-size:18px;color:red; font-weight: bold;">' + e.cellHtml + '</span>';
            }

        }

    </script>

    <script type="text/javascript">
        var photo_from = "";

        var uid_from = "";
        var uid_to = "";
        
        //聊天深度（代表聊天的回合数）
        var chat_deep = 0;

        var pre_time = '@ViewData["dtm"]';
        var after_time = '@ViewData["dtm"]';

        function show_msg(data) {
            for (var i = 0; i < data.length; i++) {
                //跳过探测消息
                if (data[i].type == "sys_probe") {
                    continue;
                }
                if (data[i].uid_from == uid_to) {
                    appendHistory("3", data[i], 1);
                }
                if (data[i].uid_from == uid_from) {
                    appendHistory("2", data[i], 1);
                }

            }
        }

        function appendHistory(txtType, data, pos) {
            var txt = data.txt;
            var msg_type = data.type;
            if (msg_type == "gif" || msg_type == "emoji" || msg_type == "gift") {
                txt = "<img src='" + txt + "' style='width:100px;' />";
            }
            if (msg_type == "pic") {
                txt = "<span style='color: blue;' onclick='show_pic(\"" + txt + "\")'>【图片】-详情</span>";
            }
            if (msg_type.startsWith('check')) {
                msg = JSON.parse(data.txt);
                txt = msg.txt;
            }

            if (data.type == "sys_kill") {
                var kill_info = JSON.parse(txt);
                txt = "封号消息:" + kill_info.kill_time / (1000 * 60 * 60) + "小时,原因:" + kill_info.kill_ause;
            }
            if (data.type == "sys_warn") {
                txt = "警告消息:" + txt / 1000 + "秒";
            }

            var id = '';
            var htmlTxt = '';
            var iwidth;

            var font_wt = "";
            var time_ss = "";

            if (pos == 1) {
                var timestamp = parseInt(data.dtm.match(/\d+/)[0], 10);
                var dtm = new Date(timestamp);
                time_ss = formatTimestamp(dtm);
            }
            if (pos == -1) {
                time_ss = data.dtm;
                if (data.dtm.startsWith('/Date')) {
                    var timestamp = parseInt(data.dtm.match(/\d+/)[0], 10);
                    var dtm = new Date(timestamp);
                    time_ss = formatTimestamp(dtm);
                }
                //time_ss = data.dtm.substr(10, 10); //data.dtm.replace(" ", "<br/>");
            }
            time_ss = time_ss.substr(10, 10);

            switch (txtType) {
                //自己说话
                case "2":
                    id = Math.floor(Math.random() * 100000);

                    htmlTxt = '<div id="m' + id + '" class="message right" style="max-width: 45rem;"><div class="" style="">' + time_ss + '</div> <div class="message-text' + font_wt + '" style="max-width: 30rem;">' + txt + '</div></div>';
                    if (pos == 1) {
                        $(".messages").append(htmlTxt);
                    }
                    if (pos == -1) {
                        $(".messages").prepend(htmlTxt);
                    }

                    iwidth = $("#m" + id + " .message-text").width() + 60;
                    $("#m" + id + " .readSign").css({ "right": iwidth.toString() + "px", "visibility": "visible" });
                    break;
                //对方说话
                case "3":
                    id = Math.floor(Math.random() * 100000);
                    if (msg_type.startsWith('check')) {
                        htmlTxt = '<div id="m' + id + '" class="message left" style="max-width: 45rem;"> <img id="photo_to" style="width:50px;border-radius:50%;" src="' + photo_to + '"/> <div class="message-text' + font_wt + '" style="border-radius: 0;border-right: 2px solid red; margin-right: 10px;">' + txt + '</div><div class="" style="">' + time_ss + '</div></div>';
                    } else {
                        htmlTxt = '<div id="m' + id + '" class="message left" style="max-width: 45rem;"> <img id="photo_to" style="width:50px;border-radius:50%;" src="' + photo_to + '"/> <div class="message-text' + font_wt + '" style="max-width: 30rem; margin-right: 10px;" >' + txt + '</div><div class="" style="">' + time_ss + '</div></div>';
                    }

                    if (pos == 1) {
                        $(".messages").append(htmlTxt);
                    }
                    if (pos == -1) {
                        $(".messages").prepend(htmlTxt);
                    }
                    break;

            }
        }

        //前一天
        function history_msg_front() {
            //后台
            var start = pre_time;
            var time = get_dtm(start,"front");
            //alert(time);
            pre_time = time;
            $.ajax({
                type: "GET",
                url: "/Admin1/GetChartA_B",
                data: { "start": time + " 00:00:00", "end": time +" 23:59:59", "from": uid_from, "to": uid_to },
                success: function (data) {
                    data = JSON.parse(data);
                    dtl_history(data, uid_to, uid_from, -1);
                    //增加一个分割线
                    var htmlTxt = '<div class="fg-line">' + time.substr(0, 10) + '</div>';
                    $(".messages").prepend(htmlTxt);
                }
            });

        }

        //后一天
        function history_msg_after() {
            //后台
            var start = after_time;
            var time = get_dtm(start, "after");
            //alert(time);
            after_time = time;
            $.ajax({
                type: "GET",
                url: "/Admin1/GetChartA_B",
                data: { "start": time + " 00:00:00", "end": time + " 23:59:59", "from": uid_from, "to": uid_to },
                success: function (data) {
                    data = JSON.parse(data);
                    //增加一个分割线
                    var htmlTxt = '<div class="fg-line">' + time.substr(0, 10) + '</div>';
                    $(".messages").append(htmlTxt);
                    var reversedData = data.reverse(); //处理后一天消息倒排
                    dtl_history(reversedData, uid_to, uid_from, 1);

                }
            });
        }

        function dtl_history(data, uid_to, uid_from ,pos) {
            for (var i = data.length - 1; i >= 0; i--) {
                if (data[i].type == "sys_probe") {
                    continue;
                }
                if (data[i].uid_to == uid_to) {
                    appendHistory("3", data[i], pos);
                }
                if (data[i].uid_to == uid_from) {
                    appendHistory("2", data[i], pos);
                }
            }
        }

        function get_dtm(dtm, type) {
            var [datePart, timePart] = dtm.split(" ");
            var dateParts = datePart.split("-");
            var year = parseInt(dateParts[0], 10);
            var month = parseInt(dateParts[1], 10) - 1; // 月份从0开始
            var day = parseInt(dateParts[2], 10);
            var date = new Date(year, month, day);
            date.setDate(date.getDate());
            if (type == "after") {
                date.setDate(date.getDate() + 2);
            }
            var newDate = date.toISOString().split("T")[0];
            return newDate;
        }

    </script>

    <script>
        function initUserSum(){
            var dtm = mini.get("dtm").getText();
            $.ajax({
                type: "GET",
                url: "/Check/GetChartA_B_Info",
                data: { "dtm": dtm, "from": uid_from, "to": uid_to , "sex_to": sex_to},
                success: function (data) {
                    //alert(data);
                    data = JSON.parse(data);
                    var scoreCoin = data.scoreCoin;
                    scoreCoin = JSON.parse(scoreCoin);

                    var htmlTxt = '本次会话: <br/>' ;
                    var txt_coin = "";
                    var txt_score = "";
                    for(var i=0; i<scoreCoin.length; i++){
                        if(scoreCoin[i]["t"] == "coin"){
                            txt_coin += '<span>金币-'+ scoreCoin[i]["type_dtl"] +':</span><span style="color:red;">'+ scoreCoin[i]["c"] +'</span>';
                            txt_coin +=  '&nbsp;&nbsp;&nbsp;&nbsp;';
                        }
                        if(scoreCoin[i]["t"] == "score"){
                            txt_score += '<span>积分-'+ scoreCoin[i]["type_dtl"] +':</span><span style="color:green;font-weight:bold;">'+ scoreCoin[i]["c"] +'</span>';
                            txt_score +=  '&nbsp;&nbsp;&nbsp;&nbsp;';
                        }
                        
                    }
                    if(txt_coin){
                        htmlTxt += txt_coin;
                        htmlTxt += "<br/>";
                    }
                    if(txt_score){
                        htmlTxt += txt_score;
                        htmlTxt += "<br/>";
                    }
                   
                    var friendTime = data.friendTime;
                    if(friendTime){
                        htmlTxt += '<span>好友:</span><span>'+ friendTime +'</span>';
                    }

                    $("#chatAB_Info").html(htmlTxt);
                    $("#chatAB_Info").attr("title", JSON.stringify(data));

                    //对方信息展示
                    var sum_info = data.sum_info;
                    sum_info = JSON.parse(sum_info);
                    if(sex_to == "男生"){
                        htmlTxt = init_user_coin(sum_info);
                    }else{
                        htmlTxt = init_user_score(sum_info);
                    }
                    $("#chatAB_to").html(htmlTxt);
                }
            });
        }

        function init_user_coin(data){
            var htmlTxt = '';
            var txt = '';

            txt = data.mny;
            txt = parseFloat(txt);
            htmlTxt = '<span>总充值:</span><span style="color:red; font-weight:bold;">￥'+ txt.toFixed(2) +'</span>';
            htmlTxt +=  '&nbsp;&nbsp;'
            txt = data.mny_day;
            txt = parseFloat(txt);
            htmlTxt += '<span>当日充值:</span><span style="color:red; font-weight:bold;">￥'+ txt.toFixed(2) +'</span>';
            htmlTxt +=  '&nbsp;&nbsp;&nbsp;&nbsp;'
            htmlTxt += '<span>当日获得金币:</span><span style="color:red;">'+ data.c_add +'</span>';
            htmlTxt +=  '&nbsp;&nbsp;'
            htmlTxt += '<span>当日消耗:</span><span style="color:red;">'+ data.c_sub +'</span>';
            return htmlTxt;
        }
        function init_user_score(data){
            var htmlTxt = '';
            var txt = '';

            txt = data.s_sub;
            txt = txt / 1000;
            htmlTxt = '<span>总提现:</span><span style="color:red; font-weight:bold;">￥'+ txt.toFixed(2) +'</span>';
            htmlTxt +=  '&nbsp;&nbsp;'
            htmlTxt += '<span>当日积分:</span><span style="color:green; font-weight:bold;">'+ data.s_add +'</span>';
            return htmlTxt;
        }

        function show_pic(url) {
            document.getElementById("img-album").src = url;
            document.getElementById("popup").style.display = 'flex';
        }
        function closePopup() {
            document.getElementById("popup").style.display = 'none';
            document.getElementById("alert_json").style.display = 'none';
        }

        function toggleChatInfo() {
            var content = document.getElementById("chatAB_content");
            var toggle = document.getElementById("chatInfo_toggle");
            if (content.style.display == 'none') {
                content.style.display = 'block';
                toggle.textContent = '▼';
            } else {
                content.style.display = 'none';
                toggle.textContent = '▶';
            }
        }

        function calculateChatDepth(messages) {
            if (!messages || messages.length == 0) {
                return 0;
            }
            
            var depth = 0;
            var lastSpeaker = '';
            var roundStarted = false;
            
            for (var i = 0; i < messages.length; i++) {
                var msg = messages[i];
                var currentSpeaker = msg.uid_from;
                
                if (lastSpeaker != '' && currentSpeaker != lastSpeaker) {
                    if (!roundStarted) {
                        // 开始一个新的来回
                        roundStarted = true;
                    } else {
                        // 完成一个来回，深度+1
                        depth++;
                        roundStarted = false;
                    }
                }
                
                lastSpeaker = currentSpeaker;
            }
            
            return depth;
        }
    </script>
</head>
<body>
    <form id="form1">

        <div style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc;">
            数据源:
            <select id="data_from" style="height:24px; width:100px">
                <option value="msg_self" selected="selected">自己发消息</option>
                <option value="msg_to_only">纯接受</option>
            
            </select>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;

            日期: <input id="dtm" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["dtm"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            
            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" class="sys-btn" style="background-color:forestgreen" value="前一天" onclick="jump_date(-1)" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" class="sys-btn" style="background-color:orange" value="后一天" onclick="jump_date(1)" />&nbsp;&nbsp;&nbsp;&nbsp;

            排序:
            <select id="sort" style="height:24px; width:80px">
                <option value="tiaoshu desc" selected="selected">发送量</option>
                <option value="tiaoshu_receive desc">接收量</option>
                <option value="time_start2 desc">时间</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_evaluate" type="button" style="background-color:#e92162; color:white; height:24px; padding:0 15px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;" value="评价" onclick="evaluateSelectedChats()" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_transaction" type="button" style="background-color:#4CAF50; color:white; height:24px; padding:0 15px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;" value="历史情况" onclick="showTransactionDetails()" />
        </div>  

        <table>
            <tr>
                <td style="display: flex; justify-content: space-between;">
                    <div id="datagrid1" class="mini-datagrid" style="width:60%;"
                         url="/Admin1/GetChartDtl/@ViewData["uid"]" idfield="id" allowresize="true"
                         showsummaryrow="true" ondrawsummarycell="onDrawSummaryCell" onrowclick="onRowClick"
                         sizelist="[50,100,200]" pagesize="200" allowmultipleselection="true" multiSelect="true">
                        <div property="columns">

                            <div type="checkcolumn" width="30"></div>
                            <div field="xh" name="xh" width="30" headeralign="center" align="center" allowsort="false">序号</div>
                            <div field="time_start" name="time_start" width="80" align="center" headeralign="center">时间</div>
                            <div name="photo2" width="80" align="center" headeralign="center">聊天对象</div>
                            <div name="info" width="100" headeralign="center" align="left" allowsort="false">综合信息</div>
                            <div name="score" width="70" headeralign="center" align="left" allowsort="false">耗金币/得积分</div>
                            <div field="txt" name="txt" width="120" headeralign="center" align="left" allowsort="false">首条消息</div>
                            <div field="diff_first" name="diff_first" width="80" headeralign="center" align="left" allowsort="false">对方响应</div>
                            <div field="sec_diff" name="sec_diff" width="60" align="center" headeralign="center">自己持续</div>
                            <div field="tiaoshu" name="tiaoshu" width="60" headeralign="center" align="center" allowsort="center" summarytype="sum">发送量</div>
                            <div field="tiaoshu_receive" name="tiaoshu_receive" width="60" headeralign="center" align="center" allowsort="center" summarytype="sum">接收量</div>

                        </div>
                    </div>
                  

                    <div style="width: 39%;">
                        <div id="chat_dtl">
                            <div id="div_AbInfo" style="position:fixed; top:5px; right:20px; border-radius:3px; border-top:3px solid red; background-color:black; color:#fff;z-index:1000;">
                                <div id="chatAB_title" style="border-bottom: 1px solid #888; padding: 8px; text-align: center; background-color: #333; cursor: pointer; user-select: none;" onclick="toggleChatInfo()">
                                    会话统计(深度:<span id="chat_deep"></span>) <span id="chatInfo_toggle">▼</span>
                                </div>
                                <div id="chatAB_content" style="padding:8px;">
                                    
                                    <div id="chatAB_to" title="" style="border-bottom:1px solid #888; margin-bottom:8px;">
                                        <span>总充值:</span><span>-</span>
                                        <span>当日充值:</span><span>-</span>
                                        <span>当日获得金币:</span><span>-</span>
                                        <span>当日消耗:</span><span>-</span>
                                    </div>
                                    <div id="chatAB_Info" title="" style="margin:8px 0;">
                                        <span>金币:</span><span>-</span>
                                        <span>积分:</span><span>-</span>
                                    </div>
                                </div>
                            </div>
                            <div class="content-inner" style="height:100%; margin-top: 0; transition-timing-function: cubic-bezier(0.1, 0.57, 0.1, 1); transition-duration: 0ms; transform: translate(0px, 0px) translateZ(0px);">
                                <div id="btn_msg_more" class="msg-more" style="display:none;" onclick="history_msg_front()">--- 前一天 ---</div>
                                <div id="contMsg" class="messages"></div>
                                <div id="btn_msg_more_after" class="msg-more" style="display:none;" onclick="history_msg_after()">--- 后一天 ---</div>
                            </div>
                        </div>

                        <div id="popup" class="ub ub-pc ub-ac" style="display: none; justify-content:center; align-items:center; position: fixed; top: 0; right: 0; width: 33%; height: 100%; background-color: rgba(0, 0, 0, 0.9); z-index: 99;" onclick="closePopup()">
                            <img id="img-album" style="width: 80%; height: auto;" src="" />
                        </div>
                    </div>
                </td>
            </tr>
        </table>

    </form>
</body>
</html>
