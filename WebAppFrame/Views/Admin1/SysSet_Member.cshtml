

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=10" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=5"></script>

    <style lang="scss">
        .range {
            padding: 8px 3px;
            margin-bottom: 15px;
        }

        .online-least {
            .comment{ 
            position: absolute;
            font-size: 8px;
            color: #fff;
            background-color: rgb(186, 97, 255);
            padding: 2px 12px;
            border-radius: 8px 0 8px 0;
        }

        .comment-on {
            background-color: #dcdcdc;
            color: #fff;
        }

        .top-up {
            display: flex;
            flex-direction:column;
            justify-content:center;
            align-items:center;
            position: relative;
            border: 1px solid #dcdcdc;
            line-height: 24px;
            padding: 5px 12px;
            border-radius: 8px;
            width: 64px;
            height: 99px;
            .sp1
        {
                display: flex;
                margin-top: 23px;
            font-size: 13px;
            margin-left: 12px;
            color: #111;
        }

        .sp2 {
            font-size: 24px;
            font-weight: 600;
            color: #111;
        }

        .lab {
            font-size: 8px;
        }

        .sp3 {
            text-decoration: line-through;
            color: #dadada;
            margin-left: 8px;
            font-size: 14px;
        }

        }

        .on-vip {
            border: 1px solid rgb(186, 97, 255);
        }

        }
        .alert_json {
            display: none;
            position: fixed;
            margin: auto;
            left: 0;
            right: 0;
            top: 0;
            bottom: 0;
            width: 550px;
            height: 700px;
            background-color: #E3E6E8;
            border: 1px solid #999999;
            z-index: 99;
        }

        .close {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 10px;
            height: 30px;
        }

        .close span {
            font-size: 14px;
        }
    </style>

    <script type="text/javascript">
        $(function () {
            init();
        })
    </script>

    <script>
        var data = '@Html.Raw(ViewData["data"])';
        function init() {

            data = JSON.parse(data);
            var arr_vip = [];
            var arr_svip = [];
            arr_vip = data.filter(item => item.vip_type === "VIP");
            arr_svip = data.filter(item => item.vip_type === "SVIP");
            var h = '';
            for (var i = 0; i < arr_vip.length; i++) {
                var item = arr_vip[i];
                var topUpClass = item.comment === "推荐" ? "top-up on-vip" : "top-up";

                h += `
                <div style="display: flex;flex-direction:column; align-items:center;">
                  <div class="online-least">
                    ${item.comment ? `<div class="comment">${item.comment}</div>` : ''}

                    <div>
                      <div class="${topUpClass}">
                        <span class="sp1">${item.name}</span>
                        <span class="sp2"><label class="lab">￥</label>${item.mny}</span>
                        <span class="sp3">${item.mny_old}</span>
                      </div>
                    </div>
                  </div>
                  <div>lv:${item.lv}</div>
                </div>
                `;
            }

            $("#vip").html(h);

            var h2 = '';
            for (var j = 0; j < arr_svip.length; j++) {
                var item = arr_svip[j];
                var topUpClass = item.comment === "推荐" ? "top-up on-vip" : "top-up";

                h2 += `
                <div style="display: flex;flex-direction:column; align-items:center;">
                  <div class="online-least">
                    ${item.comment ? `<div class="comment">${item.comment}</div>` : ''}
                    <div>
                      <div class="${topUpClass}">
                        <span class="sp1">${item.name}</span>
                        <span class="sp2"><label class="lab">￥</label>${item.mny}</span>
                        <span class="sp3">${item.mny_old}</span>
                      </div>
                    </div>
                  </div>
                  <div>lv:${item.lv}</div>
                </div>
                `;
            }
            $("#svip").html(h2);
        }

        function SetOnLine() {
            var tag = confirm("确定要更新吗，这会影响到正式系统的会员支付数据");
            if(tag)
            {
                //后台
                $.ajax({
                    type: "Get",
                    url: "/Home/SetOnline_Member",
                    success:function (data) {
                        if(data == "True"){
                            alert("更新成功");
                        }
                    }
                });
            }
        }
        function show_json(data) {
            var json_data = JSON.stringify(data);
            document.getElementById("alert_json").style.display = 'flex';
            document.getElementById("alert_json").style.flexDirection = 'column';
            document.getElementById("alert_json").style.justifyContent = 'center';
            $("#json_data").html(json_data);
        }

        function closePopup() {
            document.getElementById("alert_json").style.display = 'none';
        }
    </script>
</head>
<body>
    <div id="alert_json" class="alert_json">
        <div class="close">
            <span>json数据</span>
            <span style="font-size: 16px;" onclick="closePopup()">关闭</span>
        </div>
        <textarea id="json_data" style="height: 95%; background: white; resize: none;padding:3px;"></textarea>
    </div>

    <form id="form1">
        <div class="tools">
            <ul class="toolbar">
                <li class="click" onclick="SetOnLine()"><span><img src="/Images/frame/ico04.png" /></span>上线</li>
                <li style="margin-left:10px;" class="click" onclick="show_json(data)"><span><img src="/Images/frame/ico02.png" /></span>数据</li>
            </ul>
        </div>

        <span>购买VIP</span>
        <div id="vip" class="sys-content-border range" style="display: flex; justify-content: space-evenly; width: 600px;">
        </div>

        <span>购买SVIP</span>
        <div id="svip" class="sys-content-border range" style="display: flex; justify-content: space-evenly; width: 600px;">
        </div>
    </form>
</body>
</html>

