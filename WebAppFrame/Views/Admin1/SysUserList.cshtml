
<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=5"></script>

    <style>
       
    </style>

    <script type="text/javascript">
        var grid;
        var user_type = "";
        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 100);

            init_user_type();

            mini.parse();
            grid = mini.get("datagrid1");

            search();

            drawCell();

            init();

            
        })

        function init() {

        }

        //获取当前用户类型
        function init_user_type() {
            user_type = $(window.parent.frames["topFrame"].document).find("#sys_user_type").val();
        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;
                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:left";
                    e.cellHtml = '<a style="color:blue;" href="javascript:Add(\'' + record.id + '\')">&nbsp;&nbsp;修改</a>';
                }
            });
        }

        function search() {
            grid.load({
                "user_type": user_type,
            });
        }

        function Add(id) {
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            var parentWidth = $(window.parent.document).find("#rightFrame").width();

            mini.open({
                url: "/Admin1/SysUser_Add/" + id + "?user_type=" + user_type,
                showMaxButton: false,
                title: "添加用户",
                width: 600,
                height: 400,
                ondestroy: function (action) {
                    if (action == "ok") {
                        grid.reload();
                    }
                    else if (action == "cancel") {

                    }
                }
            });
        }
    </script>


</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">用户管理</a></li>
        </ul>
    </div>
    <form id="form1">
        <div class="tools">
            <ul class="toolbar">
                <li class="click" onclick="Add('')"><span><img src="/Images/frame/t01.png" /></span>添加</li>
            </ul>
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px;"
             url="/Admin1/GetSysUserData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[50,100,500]" pagesize="500">
            <div property="columns">
                <div field="xh" width="10" renderer="onGenderRenderer" align="center" headeralign="center">序号</div>
                <div field="user_name" width="35" renderer="onGenderRenderer" align="left" headeralign="center">账号</div>
                <div field="user_pwd" width="30" renderer="onGenderRenderer" align="left" headeralign="center">密码</div>
                @*<div field="name" width="25" headeralign="center" align="left" allowsort="false">姓名</div>*@
                <div field="type" width="25" headeralign="center" align="left" allowsort="false">类别</div>
                <div field="is_use" width="10" headeralign="center" align="center" allowsort="false">是否可用</div>
                <div field="comment" width="50" headeralign="center" align="left" allowsort="false">备注</div>

                <div name="dtl" width="100" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>
