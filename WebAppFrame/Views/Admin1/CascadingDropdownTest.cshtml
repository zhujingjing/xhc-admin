<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>级联下拉框测试</title>
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/public.js"></script>
    <style>
        .form-item {
            margin: 20px 0;
        }
        .form-label {
            display: inline-block;
            width: 100px;
            text-align: right;
            margin-right: 10px;
            font-weight: bold;
        }
        .txt {
            width: 200px;
            height: 30px;
            line-height: 30px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding: 0 10px;
        }
    </style>
</head>
<body>
    <div style="padding: 20px;">
        <h1>级联下拉框测试</h1>
        
        <div class="form-item">
            <label class="form-label">省份：</label>
            <select id="province" class="txt">
                <option value="">请选择</option>
            </select>
        </div>
        
        <div class="form-item">
            <label class="form-label">城市：</label>
            <select id="city" class="txt">
                <option value="">请选择</option>
            </select>
        </div>
    </div>
    
    <script type="text/javascript">
        $(function() {
            // 加载省份下拉框
            loadDropdownOptions("province", "province");
            
            // 监听省份变化，加载对应城市
            $("#province").change(function() {
                var provinceKey = $(this).val();
                loadCascadingDropdownOptions("city", "city", provinceKey, "province");
            });
        });
    </script>
</body>
</html>