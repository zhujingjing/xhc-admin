

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=6"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .txt {
            height: 22px;
            line-height: 22px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding-left: 5px;
            width: 220px;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 22px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 22px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            grid.load();
            //search();
            drawCell();

            init();
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml += '<a style="color:blue;" href="javascript:dtl(\'' + record.uid + '\',\'' + record.dtm_start + '\',\'' + record.dtm_end + '\' )">详情</a>';
                    e.cellHtml += '&nbsp;&nbsp;&nbsp;&nbsp;';
                    e.cellHtml += '<a style="color:blue;" href="javascript:UserAllInfo(\'' + record.uid + '\')">全貌</a>';
                    e.cellHtml += '&nbsp;&nbsp;&nbsp;&nbsp;';
                    e.cellHtml += '<a style="color:blue;" href="javascript:RemoveUid(\'' + record.uid + '\', 1)">移除</a>';
                }
                
                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }

                if (column.name == "name") {
                    var r = record.name;
                    e.cellHtml = '<span class="blue">' + r + '</span>';
                }

                if (column.name == "total_score") {
                    var total_score = record.total_score;
                    e.cellHtml = '<span class="red">' + total_score + '</span>';
                }

                if (column.name == "dtm_start") {
                    var dtm_start = record.dtm_start.split(" ")[1];
                    var dtm_end = record.dtm_end.split(" ")[1];

                    e.cellHtml =  '<span style="font-size:18px; color:red;">' + dtm_end + '</span>';
                    e.cellHtml += '<br/>↑<br/>';
                    e.cellHtml += '<span style="font-size:18px; color:blue;">' + dtm_start + '</span>';
                }
                if (column.name == "online_mi") {
                    var online_mi = record.online_mi;
                    e.cellHtml = '<span class="red">' + online_mi + '</span>';
                }

                if (column.name == "rece_match_count") {
                    var rece_match_count = record.rece_match_count;
                    var rece_match_user = record.rece_match_user;

                    e.cellHtml = '<span class="blue">' + rece_match_count + '(' + rece_match_user + ')</span>';
                }

                if (column.name == "rece_info") {
                    var rece_msg_user = record.rece_msg_user;
                    var rece_msg_count = record.rece_msg_count;
                    var rece_msg_count_sucess = record.rece_msg_count_sucess;
                    var rece_msg_count_fail = record.rece_msg_count_fail;
                    
                    e.cellHtml = '<span class="blue">' + rece_msg_user + ' - </span>';

                    e.cellHtml += '<span style="font-size:18px; color:blue;">' + rece_msg_count + '</span>';
                    e.cellHtml += ' ( ';
                    e.cellHtml += '<span style="font-size:18px; color:blue;">' + rece_msg_count_sucess + '</span>';
                    e.cellHtml += ' - ';
                    if (rece_msg_count_fail == "0") {
                        e.cellHtml += '<span style="font-size:18px; color:blue;">' + rece_msg_count_fail + '</span>';
                    }
                    else {
                        e.cellHtml += '<span style="font-size:18px; color:red;">' + rece_msg_count_fail + '</span>';
                    }
                    e.cellHtml += ' ) ';
                }

                if (column.name == "send_info") {
                    var send_msg_user = record.send_msg_user;
                    var send_msg_count = record.send_msg_count;
                    var send_msg_count_sucess = record.send_msg_count_sucess;
                    var send_msg_count_fail = record.send_msg_count_fail;

                    e.cellHtml = '<span class="blue">' + send_msg_user + ' - </span>';

                    e.cellHtml += '<span style="font-size:18px; color:blue;">' + send_msg_count + '</span>';
                    e.cellHtml += ' ( ';
                    e.cellHtml += '<span style="font-size:18px; color:blue;">' + send_msg_count_sucess + '</span>';
                    e.cellHtml += ' - ';
                    if (send_msg_count_fail == "0") {
                        e.cellHtml += '<span style="font-size:18px; color:blue;">' + send_msg_count_fail + '</span>';
                    }
                    else {
                        e.cellHtml += '<span style="font-size:18px; color:#FFFF00;">' + send_msg_count_fail + '</span>';
                    }
                    
                    e.cellHtml += ' ) ';
                }
                


                if (column.name == "send_info") {
                    var rece_msg_user = record.rece_msg_user;
                    var send_msg_user = record.send_msg_user;
                    
                    var rece_msg_count_fail = record.rece_msg_count_fail;

                    if (rece_msg_user - send_msg_user > 1) {
                        e.rowStyle = 'background-color:#FFDDAA;';
                    }
                    //if (rece_msg_count_fail > 0) {
                    //    e.rowStyle = 'background-color:#ffd800;';
                    //}
                }
            });
        }

    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var uids_online = '@ViewData["uids"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 110);
        }

        function search() {

            var name = $("#name").val();
            var dtm = mini.get("dtm").getText();

            grid.load({
                "dtm": dtm,
                "name": name
            });
        }

        function dtl(uid, start, end)
        {
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            var parentWidth = $(window.parent.document).find("#rightFrame").width();

            mini.open({
                url: "/Admin1/ReceMatch_Dtl/?uid=" + uid + "&dtm_start=" + start + "&dtm_end=" + end,
                showMaxButton: false,
                title: "接收匹配详情",
                width: parentWidth,
                height: parentHeight,
                ondestroy: function (action) {
                }
            });
        }

        function RemoveUid(uid) {
            uid = uid.trim();
            if (!uid || uid.length != 19) {
                alert("uid错误");
                return false;
            }

            var tag = confirm("确定要移除吗，这会影响到正式系统的用户匹配情况");
            if (tag) {
                //后台
                $.ajax({
                    type: "Get",
                    url: "/Home/Remove_ReceMatch/" + uid,
                    success: function (data) {
                        if (data == "1") {
                            //alert("移除成功");
                            grid.reload();
                        }
                    }
                });
            }
        }


    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">接收匹配(高级)</a></li>
        </ul>
    </div>

    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            日期: <input id="dtm" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["dtm"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            统计对象:
            <select id="name" style="height:24px;">
                <option value="" selected="selected">全部</option>

                @{
                    List<string> list = ViewBag.listMan;
                    string tie_man = string.Empty;
                    for (int i = 0; i < list.Count; i++)
                    {
                        tie_man = list[i];
                    <option value="@tie_man">@tie_man</option>
                    }
                }

            </select>&nbsp;&nbsp;&nbsp;&nbsp;

            排序:
            <select id="name" style="height:24px;">
                <option value="order by name asc, nick desc, dtm_end desc" selected="selected">默认</option>
                <option value="order by dtm_start desc">上线时间</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;

            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Admin1/GetReceMatchData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[20,50,100]" pagesize="50">
            <div property="columns">

                <div name="photo" width="60" renderer="onGenderRenderer" align="center" headeralign="center">头像</div>
                <div field="nick" width="60" headeralign="center" align="left" allowsort="false">昵称</div>
                <div field="sex" width="50" headeralign="center" align="center" allowsort="false">性别</div>

                <div name="total_score" width="80" headeralign="center" align="right" allowsort="false">总魅力值</div>
                <div field="name" name="name" width="60" headeralign="center" align="left" allowsort="false">所属</div>

                <div field="dtm_start" name="dtm_start" width="100" headeralign="center" align="center" allowsort="false">起止时间</div>
                <div field="online_mi" name="online_mi" width="60" headeralign="center" align="right" allowsort="false">持续时长</div>

                <div field="rece_match_count" name="rece_match_count" width="100" headeralign="center" align="right" allowsort="false">接收匹配次数(人数)</div>
                <div name="rece_info" width="150" headeralign="center" align="right" allowsort="false">接收消息:人数-消息总量(成功-失败)</div>
                <div name="send_info" width="150" headeralign="center" align="right" allowsort="false">发送消息:人数-消息总量(成功-失败)</div>

                <div name="dtl" width="100" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>
