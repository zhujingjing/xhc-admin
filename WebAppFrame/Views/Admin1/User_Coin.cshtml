

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>

    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js?id=1"></script>
    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=15"></script>
    <style>
        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
        }

        .gray {
            color: #f30f86;
        }

        .blue {
            color: blue;
        }

        .red {
            color: red;
        }

        .mny {
            display: inline-block;
            width: 140px;
            height: 40px;
            line-height: 40px;
            font-size: 18px;
            font-weight: bold;
            text-align: center;
        }

        .font-size {
            font-size: 18px;
        }

        .watit {
            color: gray;
        }
    </style>

    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var uid = '@ViewData["id"]';
        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window).height();
            var width = $("#desc").width();
            $("#datagrid1").height(parentHeight - 196);
            $("#datagrid2").height(parentHeight - 196);

            $("#datagrid1, #cnd_1").width(width / 2 - 100);
            $("#datagrid2, #cnd_2").width(width / 2 + 100);

            mini.parse();

            grid = mini.get("datagrid1");

            grid2 = mini.get("datagrid2");

            grid.load();
            grid2.load();

            drawCell();

            init();
        })

        function init() {

        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                var record = e.record,
                     column = e.column,
                     field = e.field,
                     value = e.value;

                if (column.name == "amount") {
                    var amount = record.amount;
                    var cls = 'red';
                    e.cellStyle = "text-align:right";
                    e.cellHtml = '<span class="' + cls + '" style="font-size:18px;">' + amount + '</span>';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }
                if (column.name == "type") {
                    var type = record.type;
                    var type_dtl = record.type_dtl;

                    var cls = 'gray';
                    if (type == "减少") {
                        cls = 'blue';
                    }
                    if (type_dtl == "购买") {
                        cls = 'red';
                    }

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '" style="font-size:18px;">' + type + '</span>';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }

            });

            grid2.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                if (column.name == "amount") {
                    var amount = record.amount;
                    var cls = 'red';
                    e.cellStyle = "text-align:right";
                    e.cellHtml = '<a href="javascript:ChartAB(\'' + record.dtm + '\',\'' + record.uid_from + '\',\'' + record.uid_to + '\')"><span class="' + cls + '" style="font-size:18px;">' + amount + '</span></a>';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }
                if (column.name == "type") {
                    var type = record.type;
                    var type_dtl = record.type_dtl;

                    var cls = 'gray';
                    if (type == "减少") {
                        cls = 'blue';
                    }
                    if (type_dtl == "购买") {
                        cls = 'red';
                    }

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '" style="font-size:18px;">' + type + '</span>';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }

                if (column.name == "photo2") {

                    if (record.photo2) {
                        var photo = servUrl_AppData + '/photo/' + record.photo2;
                        var nick = record.nick2;
                        var sex = record.sex2;
                        var color = "";
                        if (sex == "男生") {
                            color = "blue";
                        } else {
                            color = "red";
                        }

                        e.cellStyle = "text-align:center";
                        e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid_to + '\',500,1300)"><img src="' + photo + '" class="photo-img" />';
                        e.cellHtml += " ";
                        e.cellHtml += "<span style='color:" + color + "'>" + nick + "(" + sex + ")" + "</span></a>";
                    }
                }

            });
        }

        function search2() {
            var type_dtl = $("#type_dtl2").val();
            var dtm = mini.get("dtm2").getText();

            grid.load({
                "type_dtl": type_dtl,
                "dtm": dtm
            });
        }
        function search() {
            var type_dtl = $("#type_dtl").val();
            var dtm = mini.get("dtm").getText();

            grid2.load({
                "type_dtl": type_dtl,
                "dtm": dtm
            });
        }


        function handle_coin() {
            mini.open({
                url: "/Admin1/Action_coin/" + uid,
                showMaxButton: false,
                title: "金币操作",
                width: 650,
                height: 560,
                ondestroy: function (action) {
                    if (action == "ok") {
                        grid.reload();
                        grid2.reload();
                    }
                    else if (action == "cancel") {

                    }

                }
            });
        }
   
    </script>

</head>
<body>
    <form id="form1">
        <div id="desc" style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc;">
            <span class="mny">总金币:<br /><span class="gray">@ViewData["coin_total"]</span></span>
            <span class="mny">可用:<br /><span class="gray">@ViewData["coin_canuse"]</span></span>
            <span class="mny">已用:<br /><span class="gray">@ViewData["coin_used"]</span></span>
        </div>

        <div class="sys-content-border ub" style="padding:8px 3px;">
            <div id="cnd_1" style="">
                日期: <input id="dtm2" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="" /> &nbsp;&nbsp;&nbsp;&nbsp;
                类别:
                <select id="type_dtl2" style="height:24px;">
                    <option value="" selected="selected">全部</option>
                    <option value="购买">购买</option>
                    <option value="签到">签到</option>
                    <option value="任务奖励-会员">任务奖励-会员</option>
                    <option value="积分兑换">积分兑换</option>

                </select>&nbsp;&nbsp;&nbsp;&nbsp;

                <input id="btn_search2" type="button" class="sys-btn" value="查找" onclick="search2()" />&nbsp;&nbsp;&nbsp;&nbsp;
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                <input id="btn_opt" type="button" class="sys-btn" style="background-color: orange" value="金币操作" onclick="handle_coin()" />&nbsp;&nbsp;&nbsp;&nbsp;
            </div>

            <div id="cnd_2">
                日期: <input id="dtm" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="" /> &nbsp;&nbsp;&nbsp;&nbsp;
                类别:
                <select id="type_dtl" style="height:24px;">

                    <option value="" selected="selected">全部</option>
                    <option value="发送礼物">发送礼物</option>
                    <option value="发送语音">发送语音</option>
                    <option value="添加好友">添加好友</option>
                    <option value="消息支出">消息支出</option>
                </select>&nbsp;&nbsp;&nbsp;&nbsp;

                <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;

            </div>
        </div>

        <table>
            <tr>
                <td>
                    <div id="datagrid1" class="mini-datagrid" style="width:500px;height:600px;"
                         url="/Admin1/GetCoinList/@ViewData["id"]?bll=增加" idfield="id" allowresize="true"
                         sizelist="[20,100,1000]" pagesize="20">
                        <div property="columns">
                            <div field="xh" width="40" headeralign="center" align="center" allowsort="false">序号</div>

                            <div field="dtm" width="120" renderer="onGenderRenderer" align="center" headeralign="center">操作时间</div>
                            <div name="amount" width="80" renderer="onGenderRenderer" align="center" headeralign="center">金币</div>
                            <div name="type" width="80" renderer="onGenderRenderer" align="center" headeralign="center">类型</div>
                            <div field="type_dtl" width="80" renderer="onGenderRenderer" align="center" headeralign="center">类型详情</div>
                            <div field="comment" width="80" renderer="onGenderRenderer" align="center" headeralign="center">备注</div>
                        </div>
                    </div>
                </td>
                <td>
                    <div id="datagrid2" class="mini-datagrid" style="width:500px;height:600px;"
                         url="/Admin1/GetCoinList/@ViewData["id"]?bll=减少" idfield="id" allowresize="true"
                         sizelist="[20,100,1000]" pagesize="20">
                        <div property="columns">
                            <div field="xh" width="40" headeralign="center" align="center" allowsort="false">序号</div>

                            <div field="dtm" width="100" renderer="onGenderRenderer" align="center" headeralign="center">操作时间</div>
                            <div name="amount" width="70" renderer="onGenderRenderer" align="center" headeralign="center">金币</div>
                            <div name="type" width="70" renderer="onGenderRenderer" align="center" headeralign="center">类型</div>
                            <div field="type_dtl" width="80" renderer="onGenderRenderer" align="center" headeralign="center">类型详情</div>
                            <div name="photo2" width="100" renderer="onGenderRenderer" align="center" headeralign="center">对象</div>
                            <div field="comment" width="70" renderer="onGenderRenderer" align="center" headeralign="center">备注</div>
                        </div>
                    </div>
                </td>
            </tr>
        </table>

    </form>
</body>
</html>
