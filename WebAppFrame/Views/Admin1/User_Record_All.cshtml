<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8" />
    <title>用户记录管理</title>
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=12"></script>
    <style type="text/css">
        body {
            font-family: tahoma, arial, sans-serif;
            font-size: 12px;
        }
        .font-bold {
            font-weight: bold;
        }
        .photo-img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
        }
        .size-x {
            font-size: 14px;
            color: red;
        }
        .size-xx {
            font-size: 14px;
            font-weight: bold;
            color: red;
        }
        .size-xxx {
            font-size: 18px;
            font-weight: bold;
            color: red;
        }
        .gray {
            color: red;
        }
        .msg-rece {
            display: flexbox;
            border: solid 1px red;
            padding: 8px;
            color: white;
            background-color: black;
            font-size: 18px;
            font-weight: bold;
        }
        .lb {
            color: #666;
            margin-left: 20px;
        }
        .txt {
            margin-left: 6px;
            font-weight: bold;
            font-size: 18px;
        }
        .right {
            display: flex;
            justify-content: flex-end;
            align-items: center;
        }
        .left {
            display: flex;
            justify-content: flex-start;
            align-items: center;
        }
        .off {
            position: fixed;
            bottom: 30px;
            right: 80px;
            padding: 5px 10px;
            background-color: #e92162;
            color: #fff;
            border-radius: 5px;
            width: 400px;
            text-align: center;
        }
        .msg-more {
            text-align: center;
            color: blue;
            cursor: pointer;
        }
        .message-text {
            margin-left: 5px;
            margin-right: 5px;
        }
        .fg-line {
            text-align: center;
            color: #808080;
            background: #dcdcdc;
        }
    </style>
    <script type="text/javascript">
        var grid;
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent).height();
            $("#datagrid").height(parentHeight - 120);

            mini.parse();

            grid = mini.get("datagrid");

            drawCell();

            init();

            // 加载用户记录表格数据
            queryRecords();
        })

        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid").height(parentHeight - 110);
            
            // 使用后端设置的默认时间
            var startDate = "@ViewData["startDate"]";
            var endDate = "@ViewData["endDate"]";
            
            if (startDate && startDate != "") {
                mini.get("startDate").setValue(new Date(startDate));
            }
            if (endDate && endDate != "") {
                mini.get("endDate").setValue(new Date(endDate));
            }
        }

        function drawCell() {
            mini.get("datagrid").on("drawcell", function (e) {
                var record = e.record;
                var field = e.field;
                var value = e.value;

                if (field == "xh") {
                    e.cellHtml = (e.rowIndex + 1).toString();
                }
                
                // 评价字段样式处理
                if (field == "evaluation") {
                    var color = '';
                    if (value == "很好" || value == "好") {
                        color = "blue";
                    } else if (value == "一般") {
                        color = "black";
                    } else if (value == "差" || value == "很差") {
                        color = "red";
                    }
                    e.cellHtml = '<span style="color: ' + color + ';">' + (value || '') + '</span>';
                }
                
                // 用户信息（头像、昵称、性别）
                if (field == "user_info") {
                    e.cellStyle = "text-align:center";
                    
                    var html = '';
                    if (record.photo) {
                        var photo = servUrl_AppData + '/photo/' + record.photo;
                        html += '<a href="javascript:UserAllInfo(\'' + record.uid + '\')"><img src="' + photo + '" class="photo-img" /><br>';
                    } else {
                        html += '<div>';
                    }
                    
                    if (record.nick) {
                        var nickColor = record.sex == "女生" ? "red" : (record.sex == "男生" ? "blue" : "black");
                        html += '<span style="color: ' + nickColor + ';">' + record.nick + '</span>';
                    }
                    
                    if (record.sex) {
                        var sexColor = record.sex == "女生" ? "red" : (record.sex == "男生" ? "blue" : "black");
                        html += '<span style="color: ' + sexColor + ';">(' + record.sex + ')</span>';
                    }
                    
                    if (record.photo) {
                        html += '</a>';
                    } else {
                        html += '</div>';
                    }
                    
                    e.cellHtml = html;
                }
                
                // 创建时间（日期和时分秒分上下两行）
                if (field == "create_time") {
                    e.cellStyle = "text-align:center";
                    if (value) {
                        e.cellHtml = '<span>' + value.replace(' ', '<br>') + '</span>';
                    }
                }
            });
        }

        function formatTime(date) {
            var year = date.getFullYear();
            var month = date.getMonth() + 1, month = month < 10 ? '0' + month : month;
            var day = date.getDate(), day = day < 10 ? '0' + day : day;
            return year + '-' + month + '-' + day;
        }

        // 格式化时间戳
        function formatTimestamp(date) {
            var year = date.getFullYear();
            var month = date.getMonth() + 1, month = month < 10 ? '0' + month : month;
            var day = date.getDate(), day = day < 10 ? '0' + day : day;
            var hours = date.getHours(), hours = hours < 10 ? '0' + hours : hours;
            var minutes = date.getMinutes(), minutes = minutes < 10 ? '0' + minutes : minutes;
            var seconds = date.getSeconds(), seconds = seconds < 10 ? '0' + seconds : seconds;
            return year + '-' + month + '-' + day + ' ' + hours + ':' + minutes + ':' + seconds;
        }

        // 格式化日期显示
        // 检查：formatDate 仅在 record_date 列的 renderer 中引用，
        // 而 record_date 列本身已在 mini-datagrid 中通过 format="yyyy-MM-dd" 自动格式化，
        // 因此该函数实际已冗余，可删除。
        // 如后续需要自定义格式再恢复即可。

        function onDrawSummaryCell(e) {
            var result = e.result;
            var grid = e.sender;

            //客户端统计
            if (e.field == "tiaoshu" || e.field == "tiaoshu_receive") {
                e.cellStyle = "text-align:right";
                e.cellHtml = '<span style="display:inline-block;margin:12px 0; font-size:18px;color:red; font-weight: bold;">' + e.cellHtml + '</span>';
            }
        }

        // 渲染操作按钮
        function onActionRenderer(e) {
            var record = e.record;
            var id = record.id;
            var uid = record.uid;
            return '<a href="javascript:editRecord(\'' + id + '\', \'' + uid + '\')" style="color:green;">修改</a> | <a href="javascript:deleteRecord(\'' + id + '\')" style="color:red;">删除</a>';
        }

        // 查询记录
        function queryRecords() {
            var startDate = mini.get("startDate").getValue();
            var endDate = mini.get("endDate").getValue();
            var uid = mini.get("uid").getValue();

            // 确保日期格式正确
            if (startDate instanceof Date) {
                var year = startDate.getFullYear();
                var month = startDate.getMonth() + 1;
                var day = startDate.getDate();
                startDate = year + '-' + (month < 10 ? '0' + month : month) + '-' + (day < 10 ? '0' + day : day);
            }
            if (endDate instanceof Date) {
                var year = endDate.getFullYear();
                var month = endDate.getMonth() + 1;
                var day = endDate.getDate();
                endDate = year + '-' + (month < 10 ? '0' + month : month) + '-' + (day < 10 ? '0' + day : day);
            }

            grid.load({
                pageIndex: 1,
                pageSize: 200,
                uid: uid,
                startDate: startDate,
                endDate: endDate
            });
        }

        // 修改记录
        function editRecord(id, uid) {
            mini.open({
                url: "/Admin1/User_Record_Add?uid=" + uid + "&id=" + id,
                title: "修改用户记录",
                width: 800,
                height: 700,
                onload: function () {
                    var iframe = this.getIFrameEl();
                },
                ondestroy: function (action) {
                    if (action == "ok") {
                        queryRecords();
                    }
                }
            });
        }

        // 删除记录
        function deleteRecord(id) {
            if (confirm('确定要删除这条记录吗？')) {
                $.ajax({
                    url: "/Admin1/DeleteUserRecord",
                    type: "POST",
                    data: { id: id },
                    dataType: "json",
                    success: function (result) {
                        try {
                            // 同时支持大写和小写字段名
                            var state = result.state || result.State;
                            var msg = result.msg || result.Msg || "未知错误";

                            if (state == "1" || state == 1) {
                                alert("删除成功");
                                queryRecords();
                            } else {
                                alert("删除失败: " + msg);
                            }
                        } catch (e) {
                            alert("解析返回结果失败: " + e.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        alert("请求错误: " + error);
                    }
                });
            }
        }

        // 查看用户详细信息
        function UserAllInfo(uid, h, w) {
            var parentHeight = "100%";
            var parentWidth = "100%";
            var user_type = "普通用户";
            if (window.parent.frames["topFrame"]) {
                user_type = $(window.parent.frames["topFrame"].document).find("#sys_user_type").val();
            }

            if (window.parent.parent.frames["topFrame"]) {
                user_type = $(window.parent.parent.frames["topFrame"].document).find("#sys_user_type").val();
            }
                
            mini.open({
                url: "/Admin1/UserAll/" + uid + "?user_type=" + user_type,
                showMaxButton: false,
                title: "全貌",
                width: parentWidth,
                height: parentHeight,
                ondestroy: function (action) {
                    if (action == "ok") {

                    }
                    else if (action == "cancel") {

                    }
                }
            });
        }
    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">用户记录管理</a></li>
        </ul>
    </div>
    <form id="form1">
        <div class="sys-content-border" style="padding:8px 3px;">
            起始日期: <input id="startDate" class="mini-datepicker" format="yyyy-MM-dd" style="width:120px;" />&nbsp;&nbsp;&nbsp;&nbsp;
            截止日期: <input id="endDate" class="mini-datepicker" format="yyyy-MM-dd" style="width:120px;" />&nbsp;&nbsp;&nbsp;&nbsp;
            用户ID:
            <input id="uid" class="mini-textbox" style="width:150px;" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_query" type="button" class="sys-btn" value="查询" onclick="queryRecords()" style="background-color: #E3F2FD; color: #1976D2;" />
        </div>
        <div id="datagrid" class="mini-datagrid" style="width:100%; margin-top:5px;" url="/Admin1/GetUserRecordsAll" idfield="id" allowresize="true"
             showsummaryrow="true" ondrawsummarycell="onDrawSummaryCell"
             sizelist="[50,100,200]" pagesize="200">
            <div property="columns">
                <div field="xh" name="xh" width="30" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="record_date" width="80" align="center" headeralign="center" format="yyyy-MM-dd">日期</div>
                <div field="user_info" width="80" headeralign="center" align="center">用户信息</div>
                <div field="remark" width="80" headeralign="center" align="left">备注</div>
                <div field="source" width="80" headeralign="center" align="left">来源</div>
                <div field="evaluation" width="60" headeralign="center" align="left">评价</div>
                <div field="summary" width="300" headeralign="center" align="left">简述</div>
                <div field="details" width="300" headeralign="center" align="left">详情</div>
                <div field="processing_result" width="100" headeralign="center" align="left">处理结果</div>
                <div field="violation" width="120" headeralign="center" align="left">违规情况</div>
                <div field="record_remark" width="80" headeralign="center" align="left">备注</div>
                
                <div field="operator_name" width="60" headeralign="center" align="left">操作人</div>
                <div field="create_time" width="100" align="center" headeralign="center">创建时间</div>
                <div field="action" width="100" headeralign="center" align="center" renderer="onActionRenderer">操作</div>
            </div>
        </div>
    </form>
</body>
</html>