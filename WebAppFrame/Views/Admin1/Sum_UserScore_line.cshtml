    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }
        .red {
            font-size: 22px;
            font-weight: bold;
            color: red;
            height: 38px;
             line-height: 40px;
        }
        .blue {
            font-size: 18px;
            font-weight: bold;
            color: blue;
             line-height: 40px;
        }
