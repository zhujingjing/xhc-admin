    <script type="text/javascript">
        var data = '@Html.Raw(ViewData["data"])';
        data = JSON.parse(data);

        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#divContainer").height(parentHeight - 181);

            init();

            $("#name").change(function () {
                loadData();
            });
        })

        function init() {
            var name = "@ViewData["name"]";
            $("#name").val(name);

            var data2 = '@Html.Raw(ViewData["data2"])';
            data2 = JSON.parse(data2);

            $("#total").html(data2.total);
            $("#rate").html(data2.rate + "%");
            $("#gift").html(data2.gift);

            search5();
        }
        //加载数据
        function loadData() {
            var start = mini.get("start").getText();
            var end = mini.get("end").getText();
            var name = $("#name").val();
            var url = "/Admin1/Sum_UserScore_line/?start=" + start + "&end=" + end + "&name=" + name;
            window.location.href = url;
        }
        //聊天量
        function search2() {
            showLine555(data);
            $("#navigation").html("聊天量");
        }
        //普通黑圈
        function search3() {
            showLine666(data);
            $("#navigation").html("消黑圈");
        }

        //礼物比
        function search4() {
            showLine777(data);
            $("#navigation").html("礼物比");
        }

        //聊天总分
        function search5() {
            showLine888(data);
            $("#navigation").html("聊天总分");
        }

        //得分明细
        function search6() {
            showLine999(data);
            $("#navigation").html("得分明细");
        }

    </script>


    @*聊天量*@
    <script>
        function showLine555(data) {
            // 创建chart
            var chart = new AmCharts.AmSerialChart();
            chart.color = "#888888";
            chart.dataProvider = data;
            chart.categoryField = "dtm"; //横轴显示内容
            chart.startDuration = 1;

            // x轴
            var categoryAxis = chart.categoryAxis;
            categoryAxis.dashLength = 1;
            categoryAxis.fillColor = "#ffffff";
            categoryAxis.axisColor = "#888888";
            categoryAxis.labelRotation = 45; //横轴字体倾斜度数

            // x轴值
            var valueAxis = new AmCharts.ValueAxis();
            valueAxis.inside = false;
            valueAxis.axisColor = "#888888";
            chart.addValueAxis(valueAxis);

            // 图
            var graph = new AmCharts.AmGraph();
            graph.valueAxis = valueAxis;
            graph.bullet = "round"; //"none", "round", "square", "triangleUp", "triangleDown", "triangleLeft", "triangleRight", "bubble", "diamond", "xError", "yError" and "custom".
            graph.bulletSize = 8; //大小
            graph.bulletBorderColor = "#FFFFFF";

            graph.lineColor = "#0000FF"; //线条颜色 "00FF00" "0000FF"
            graph.valueField = "c_msg_suc"; //纵轴显示内容
            graph.title = "日聊天量";
            graph.balloonText = "[[category]]日聊天量<br><b><span style='font-size:14px;'>[[value]]</span></b>"; //提示信息
            chart.addGraph(graph);

            if (false) {
                //
                graph = new AmCharts.AmGraph();
                graph.valueAxis = valueAxis;
                graph.bullet = "round";//
                graph.bulletSize = 8;//
                graph.bulletBorderColor = "#FFFFFF";
                graph.lineColor = "#ff0099";//
                graph.valueField = "c_msg_suc"; //纵轴显示内容
                graph.title = "聊天量";
                graph.balloonText = "[[category]]聊天量<br><b><span style='font-size:14px;'>[[value]]</span></b>"; //提示信息
                chart.addGraph(graph);
            }

            if (false) {
                //
                graph = new AmCharts.AmGraph();
                graph.valueAxis = valueAxis;
                graph.bullet = "round";//
                graph.bulletSize = 8;//
                graph.bulletBorderColor = "#FFFFFF";
                graph.lineColor = "#7B7B7B";//
                graph.valueField = "s_msg"; //纵轴显示内容
                graph.title = "聊天量得分";
                graph.balloonText = "[[category]]聊天量得分<br><b><span style='font-size:14px;'>[[value]]</span></b>"; //提示信息
                chart.addGraph(graph);
            }
            if (false) {
                //
                graph = new AmCharts.AmGraph();
                graph.valueAxis = valueAxis;
                graph.bullet = "round";//
                graph.bulletSize = 8;//
                graph.bulletBorderColor = "#FFFFFF";
                graph.lineColor = "#5B5B5B";//
                graph.valueField = "s_blackq"; //纵轴显示内容
                graph.title = "消黑圈得分";
                graph.balloonText = "[[category]]消黑圈得分<br><b><span style='font-size:14px;'>[[value]]</span></b>"; //提示信息
                chart.addGraph(graph);
            }


            // 光标
            var chartCursor = new AmCharts.ChartCursor();
            chartCursor.cursorAlpha = 0;
            chartCursor.cursorPosition = "mouse";
            chartCursor.graphBulletSize = 1.5;
            chart.addChartCursor(chartCursor);
            chart.numberFormatter.precision = 0;

            //图例
            var legend = new AmCharts.AmLegend();
            legend.align = "center";
            chart.addLegend(legend);

            chart.write("divContainer");
        };
    </script>

