<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#" id="navigation">得分走势</a></li>
        </ul>
    </div>
    <form id="form1">
        <div style="padding:10px; margin-bottom:5px; border: solid 1px #dcdcdc;">
            开始日期: <input id="start" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["start"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            截止日期: <input id="end" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["end"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            <select id="name" style="height:24px;">
                <option value="" selected="selected">全部</option>
                @{
                    List<string> list = ViewBag.listMan;
                    string tie_man = string.Empty;
                    for (int i = 0; i < list.Count; i++)
                    {
                        tie_man = list[i];
                        <option value="@tie_man">@tie_man</option>
                    }
                }

            </select>&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" value="加载数据" class="sys-btn" onclick="loadData()" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" value="聊天总分" class="sys-btn" style="background-color:#009a44;" onclick="search5()" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" value="得分明细" class="sys-btn" style="background-color:#009a44;" onclick="search6()" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" value="礼物比" class="sys-btn" style="background-color:#009a44;" onclick="search4()" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" value="聊天量" class="sys-btn" style="background-color:#009a44;" onclick="search2()" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" value="消黑圈" class="sys-btn" style="background-color:#009a44;" onclick="search3()" />&nbsp;&nbsp;&nbsp;&nbsp;
        </div>

        <div style="padding:10px; margin-bottom:5px; border: solid 1px #dcdcdc;">
            <a class="mny">总得分:<a class="red" id="total"></a></a>
            <a class="mny mr-left">礼物分:<a class="red" id="gift"></a></a>
            <a class="mny mr-left">礼物比:<a class="blue" id="rate"></a></a>
        </div>

        <div id="divContainer" style="width: 100%; border: solid 1px #dcdcdc"></div>

    </form>
</body>
</html>


