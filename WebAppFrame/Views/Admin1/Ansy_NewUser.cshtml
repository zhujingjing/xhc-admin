

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=10"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .txt {
            height: 22px;
            line-height: 22px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding-left: 5px;
            width: 220px;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 18px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }

        .sum-desc {
            text-align: left;
            margin-left: 10px;
            border-left: 1px solid #dcdcdc;
            padding-left: 3px;
            color: #666;
            font-size: 10px;
        }

        .red2 {
            font-size: 28px;
            font-weight: bold;
            color: #f00;
        }

        .blue2 {
            font-size: 28px;
            font-weight: bold;
            color: blue;
        }
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            //grid.load();
            search();
            drawCell();

            init();
            bindEvent();
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml += '<a style="color:blue;" href="javascript:UserAllInfo(\'' + record.uid + '\')">全貌</a>';
                }

                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }

                if (column.name == "first_time") {
                    var dtm = record.first_time;
                    if (dtm == null) { dtm = ''; }
                    dtm = dtm.replace(' ', '<br/>');

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span>' + dtm + '</span>';
                }

                if (column.name == "sex") {
                    var txt = record.sex;
                    var c = '';
                    if (txt == "女生") { c = 'color:red;font-weight: bold;'; }
                    

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span style="'+c +'">' + txt + '</span>';
                }

            });
        }

    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 110);

            $("#sort").change(function () {
                conname();
            });
        }

        function bindEvent() {
        }


        function search() {
            var dtm_start = mini.get("dtm_start").getText();
            var dtm_end = mini.get("dtm_end").getText();
            var sort = $("#sort").val();

            grid.load({
                "start": dtm_start,
                "end": dtm_end,
                "sort": sort
            });
        }

        function conname() {
            search();
        }
    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">匹配明细</a></li>
        </ul>
    </div>
    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            起始时间: <input id="dtm_start" format="yyyy-MM-dd HH:mm:ss" class="mini-datepicker" style="width:180px;" value="@ViewData["start"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            截止时间: <input id="dtm_end" format="yyyy-MM-dd HH:mm:ss" class="mini-datepicker" style="width:180px;" value="@ViewData["end"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            排序:<select id="sort" style="height:24px;">
                   <option value="first_time desc" selected="selected">默认</option>
                   <option value="msg_count desc">消息次数</option>
                   <option value="match_count desc">匹配次数</option>
                   <option value="login_count desc">登录次数</option>
                </select>&nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Admin1/GeAnsy_NewUserData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[20,50,100]" pagesize="100">
            <div property="columns">
                <div field="xh" width="40" headeralign="center" align="center" allowsort="false">序号</div>
                <div name="first_time" width="60" headeralign="center" align="center" allowsort="false">注册时间</div>
                <div name="photo" width="60" renderer="onGenderRenderer" align="center" headeralign="center">头像</div>
                <div field="nick" width="60" headeralign="center" align="left" allowsort="false">昵称</div>
                <div field="sex" name="sex" width="50" headeralign="center" align="center" allowsort="false">性别</div>
                <div field="out_id" width="100" headeralign="center" align="center" allowsort="false">外部id</div>

                <div field="login_count" width="80" headeralign="center" align="center" allowsort="false">登录次数</div>
                <div field="match_count" width="80" headeralign="center" align="center" allowsort="false">匹配次数</div>
                <div field="msg_count" width="80" headeralign="center" align="center" allowsort="false">发送消息次数</div>

                <div field="comment2" width="40" headeralign="center" align="center" allowsort="false">备注</div>
                <div name="dtl" width="100" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>


