
<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <script src="~/Scripts/jquery-1.8.2.min.js?id=123"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/public.css" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=1"></script>

    <style>
        .ub {
            display: flex;
        }

        .ub-ver {
            flex-direction: column;
        }

        .ub-as {
            justify-content: flex-start;
        }

        .ub-ac {
            justify-content: center;
        }

        .ub-ac1 {
            justify-content: space-around;
        }

        .ub-ac2 {
            justify-content: space-between;
        }

        .ub-ac3 {
            justify-content: space-evenly;
        }

        .ub-ae {
            justify-content: flex-end;
        }

        .ub-ps {
            align-items: flex-start;
        }

        .ub-pc {
            align-items: center;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo {
            width: 100px;
            height: 100px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .lb {
            display: inline-block;
            width: 80px;
        }

        .bg {
            width: 100px;
            height: 100px;
        }

        .risk{
            background-color:#ff6a00;
        }
        .risk:hover{
            background-color:#ff0000;
        }
    </style>

    <script type="text/javascript">
        var data_ok = ["id", "uid", "openid", "tel", "name", "nick", "photo", "age_range", "sex", "loc_province", "loc_city", "loc_area", "loc_lng", "loc_lat", "inst_tag", "wx", "wx_check", "first_dtm", "remark", "coin_total", "coin", "score_total", "score", "show_score", "show_coin", "friend_num", "risk_tip"];
        var arr_ok = [];
        var arr_no = [];

        var uid = '@ViewData["id"]';
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        $(function () {
            var data = '@Html.Raw(ViewData["data"])';
            data = data.replace(/[\r\n]/g, "");
            data = JSON.parse(data);
            var dateRegex = /^\/Date\((-?\d+)\)\/$/;
            for (var key in data) {
                if (key == "reason") {
                    continue;
                }

                if (data[key] === null) {
                    data[key] = "";
                }

                if (dateRegex.test(data[key])) {
                    data[key] = formatTime(data[key]);
                }

                var keyValue = { [key]: data[key] };
                if (data_ok.includes(key)) {
                    var txt = data[key];
                    $("." + key).html(txt);
                    arr_ok.push(keyValue);
                } else {
                    arr_no.push(keyValue);
                }
                
            }
            
            var h = "";
            for (var i = 0; i < arr_no.length; i++) {
                var item = arr_no[i];
                var key = Object.keys(item)[0];
                var value = item[key];
                if (key !== "pic_back") {
                    h += `
                        <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                            <span class="lb">${key}</span>
                            <span class="ctxt" style="margin-left:50px;">${value}</span>
                        </div>
                    `;
                } else {
                    //处理一下图片地址
                    var arrT = value.split('photo');
                    value = servUrl_AppData + '/photo' +arrT[1];

                    h += `
                        <div class="ub ub-pc" style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                            <span class="lb">${key}</span>
                            <span class="ctxt" style="margin-left:50px;"><img  src="${value}" class="bg" /></span>
                        </div>
                    `;
                }
                
            }
            $("#other_data").html(h);

            $("#photo").attr("src", servUrl_AppData + '/photo/' + data["photo"]);


            var data2 = '@Html.Raw(ViewData["data2"])';
            data = data2.replace(/[\r\n]/g, "");
            data = JSON.parse(data);
            for (var key in data) {
                
                var txt = data[key];

                $("#" + key).html(txt);
            }
            $("#headimgurl").attr("src", data["headimgurl"]);

            if ($("#sex").html() == "2") {
                $("#sex").html("女生");
            }
            if ($("#sex").html() == "1") {
                $("#sex").html("男生");
            }
            if ($("#sex").html() == "0") {
                $("#sex").html("未知");
            }
        })


        function do_kill() {
            mini.open({
                url: "/Admin1/FengHao_Rst?uid=" + uid,
                showMaxButton: false,
                title: "封号",
                width: 800,
                height: 330,
                ondestroy: function (action) {

                }
            });
        }

        function update_sex() {
            mini.open({
                url: "/Admin1/UpDate_Sex/" + uid,
                showMaxButton: false,
                title: "修改性别",
                width: 700,
                height: 400,
                ondestroy: function (action) {

                }
            });
        }

        function bind_tel() {
            mini.open({
                url: "/Admin1/Bind_Tel/" + uid,
                showMaxButton: false,
                title: "绑定手机号码",
                width: 700,
                height: 400,
                ondestroy: function (action) {

                }
            });
        }
        function handle_coin() {
            mini.open({
                url: "/Admin1/Action_coin/" + uid,
                showMaxButton: false,
                title: "金币操作",
                width: 650,
                height: 560,
                ondestroy: function (action) {

                }
            });
        }
        function handle_score() {
            mini.open({
                url: "/Admin1/Action_score/" + uid,
                showMaxButton: false,
                title: "积分操作",
                width: 650,
                height: 560,
                ondestroy: function (action) {

                }
            });
        }

        function remark() {
            mini.open({
                url: "/Admin1/Remark/" + uid,
                showMaxButton: false,
                title: "添加备注",
                width: 650,
                height: 460,
                ondestroy: function (action) {

                }
            });
        }

        function risk_tip() {
            mini.open({
                url: "/Admin1/Risk_Tip/" + uid,
                showMaxButton: false,
                title: "标识风险",
                width: 650,
                height: 460,
                ondestroy: function (action) {

                }
            });
        }

        

        function cancel() {
            mini.open({
                url: "/Admin1/Cancel/" + uid,
                showMaxButton: false,
                title: "注销账号",
                width: 650,
                height: 460,
                ondestroy: function (action) {

                }
            });
        }
        function formatTime(dateString) {
            if (dateString.startsWith("/Date(") && dateString.endsWith(")/")) {
                const timestamp = parseInt(dateString.substring(6, dateString.length - 2), 10);
                const date = new Date(timestamp);

                var year = date.getFullYear();
                var month = String(date.getMonth() + 1).padStart(2, '0'); // 月份从0开始
                var day = String(date.getDate()).padStart(2, '0');
                var hours = String(date.getHours()).padStart(2, '0');
                var minutes = String(date.getMinutes()).padStart(2, '0');
                var seconds = String(date.getSeconds()).padStart(2, '0');

                return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;
            }
            return dateString;
        }
    </script>
</head>
<body>
    <form id="form1">

        <div style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc;">


            <div style="border:1px solid #dcdcdc;padding:12px">
                <span class="lb">操作</span>
                <span class="ctxt">
                    <input type="button" class="sys-btn" value="封杀" onclick="do_kill()" />&nbsp;&nbsp;&nbsp;&nbsp;
                </span>
                <span class="ctxt">
                    <input type="button" class="sys-btn" value="修改性别" onclick="update_sex()" />&nbsp;&nbsp;&nbsp;&nbsp;
                </span>
                <span class="ctxt">
                    <input type="button" class="sys-btn" value="修改手机号码" onclick="bind_tel()" />&nbsp;&nbsp;&nbsp;&nbsp;
                </span>
                <span class="ctxt">
                    <input type="button" class="sys-btn" value="金币操作" onclick="handle_coin()" />&nbsp;&nbsp;&nbsp;&nbsp;
                </span>
                <span class="ctxt">
                    <input type="button" class="sys-btn" value="积分操作" onclick="handle_score()" />&nbsp;&nbsp;&nbsp;&nbsp;
                </span>
                
