                </span>
            </div>

            <div style="padding:5px 3px;">
                <span class="risk_tip" style="color:red; font-weight:bold;"></span>
            </div>

            <div class="ub" style="margin-top:3px;">

                
                <div style="border:1px solid #dcdcdc;padding:0 12px;">
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">id</span>
                        <span class="ctxt id"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">uid</span>
                        <span class="ctxt uid"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">openid</span>
                        <span class="ctxt openid"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">姓名</span>
                        <span class="ctxt name"></span>
                    </div>
                    <div class="ub ub-pc" style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">头像</span>
                        <span class="ctxt"><img id="photo" src="" class="photo" /></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">昵称</span>
                        <span class="ctxt nick"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">标签</span>
                        <span class="ctxt inst_tag"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">性别</span>
                        <span class="ctxt sex"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">年龄段</span>
                        <span class="ctxt age_range"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">省份</span>
                        <span class="ctxt loc_province"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">市</span>
                        <span class="ctxt loc_city"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">区</span>
                        <span class="ctxt loc_area"></span>
                    </div>

                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">认证手机</span>
                        <span class="ctxt tel red"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">认证微信号</span>
                        <span class="ctxt wx red"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">微信审核状态</span>
                        <span class="ctxt wx_check red"></span>
                    </div>

                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">首次日期</span>
                        <span class="ctxt first_dtm"></span>
                    </div>

                    <div>
                        <span class="lb">备注信息</span>
                        <span class="ctxt remark"></span>
                    </div>
                </div>

                <div style="min-width:200px; border:1px solid #dcdcdc;padding:0 12px;margin-left:70px;">
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">总金币</span>
                        <span class="ctxt coin_total"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">可用金币</span>
                        <span class="ctxt coin"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">总积分</span>
                        <span class="ctxt score_total"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">可用积分</span>
                        <span class="ctxt score"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">对外魅力值</span>
                        <span class="ctxt show_score"></span>
                    </div>

                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">对外豪气值</span>
                        <span class="ctxt show_coin"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">好友数</span>
                        <span class="ctxt friend_num"></span>
                    </div>

                </div>

                <div style="border:1px solid #dcdcdc;padding:0 12px;margin-left:70px;">
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">昵称</span>
                        <span class="ctxt" id="nickname"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">性别</span>
                        <span class="ctxt" id="sex"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">语言</span>
                        <span class="ctxt" id="language"></span>
                    </div>
                    <div class="ub ub-pc" style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">头像</span>
                        <span class="ctxt"><img id="headimgurl" src="" class="photo" /></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">国家</span>
                        <span class="ctxt" id="country"></span>
                    </div>

                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">省份</span>
                        <span class="ctxt" id="province"></span>
                    </div>
                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">城市</span>
                        <span class="ctxt" id="city"></span>
                    </div>

                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">关注时长</span>
                        <span class="ctxt" id="subscribe_time"></span>
                    </div>

                    <div style="border-bottom:1px solid #f1f1f1;padding:4px 0;">
                        <span class="lb">最近修改时间</span>
                        <span class="ctxt" id="least_update_time"></span>
                    </div>
                    <div>
                        <span class="lb">取关时间</span>
                        <span class="ctxt" id="unsub_time"></span>
                    </div>

                </div>


                <div id="other_data" style="border:1px solid #dcdcdc;padding:0 12px;margin-left:70px;"></div>

            </div>
        </div>
    </form>
</body>
</html>
