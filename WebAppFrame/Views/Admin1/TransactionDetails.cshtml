<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>交易情况统计</title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/Global.js?id=1"></script>
    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=90"></script>
    <style>
        body {
            margin: 0;
            padding: 20px;
            box-sizing: border-box;
            width: 100%;
            overflow-x: hidden;
        }

        .form-item {
            margin: 15px 0;
            display: flex;
            align-items: flex-start;
        }

        .txt {
            height: 32px;
            line-height: 32px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding: 0 10px;
            width: 100%;
            box-sizing: border-box;
        }

        .txtarea {
            min-height: 120px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding: 10px;
            width: 100%;
            box-sizing: border-box;
            resize: vertical;
        }

        .btn {
            height: 32px;
            line-height: 32px;
            padding: 0 20px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            background-color: #f5f5f5;
            cursor: pointer;
        }

        .btn-primary {
            background-color: #1890ff;
            color: white;
            border-color: #1890ff;
        }

        .btn-success {
            background-color: #52c41a;
            color: white;
            border-color: #52c41a;
        }

        .panel {
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            margin-bottom: 20px;
        }

        .panel-header {
            padding: 10px 15px;
            border-bottom: 1px solid #dfdfdf;
            background-color: #f5f5f5;
            font-weight: bold;
        }

        .panel-body {
            padding: 15px;
        }

        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        .table th,
        .table td {
            border: 1px solid #dfdfdf;
            padding: 8px;
            text-align: left;
        }

        .table th {
            background-color: #f5f5f5;
            font-weight: bold;
        }

        .table tr:hover {
            background-color: #e6f7ff;
            cursor: pointer;
        }

        .table tr:active {
            background-color: #bae7ff;
        }

        .table tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .table tr:nth-child(even):hover {
            background-color: #e6f7ff;
        }

        .total-row {
            font-weight: bold;
            background-color: #f0f0f0 !important;
        }

        .section {
            margin-bottom: 30px;
        }

        .section-title {
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 15px;
            color: #333;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .stat-card {
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding: 15px;
            text-align: center;
            background-color: #f9f9f9;
        }

        .stat-value {
            font-size: 24px;
            font-weight: bold;
            color: #1890ff;
            margin: 10px 0;
        }

        .stat-label {
            font-size: 14px;
            color: #666;
        }

        .coin-value {
            color: #ff0000;
        }

        .score-value {
            color: #1890ff;
        }

        .transaction-row {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .transaction-col {
            flex: 1;
        }

        .number-format {
            text-align: right;
        }

        .stat-card {
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding: 15px;
            text-align: center;
            background-color: #f9f9f9;
            margin-bottom: 15px;
        }

        .transaction-title {
            font-size: 14px;
            font-weight: bold;
            margin-bottom: 10px;
            color: #333;
        }
    </style>
</head>
<body>
    <form id="form1">
        <div class="transaction-row">
            <div class="transaction-col">
                <div class="transaction-title">积分增加</div>
                
                <div class="stat-card">
                    <div class="stat-value score-value" id="scoreAtoBTotal">0</div>
                    <div class="stat-value score-value" id="scoreBtoATotal">0</div>
                </div>
                <table class="table" id="scoreAtoBTable">
                    <thead>
                        <tr>
                            <th>活动类型</th>
                            <th>积分</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>

         
                <table class="table" id="scoreBtoATable">
                    <thead>
                        <tr>
                            <th>活动类型</th>
                            <th>积分</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>

            <div class="transaction-col">
                <div class="transaction-title">金币消耗</div>
                
                <div class="stat-card">
                    <div class="stat-value coin-value" id="coinAtoBTotal">0</div>
                    <div class="stat-value coin-value" id="coinBtoATotal">0</div>
                </div>
                <table class="table" id="coinAtoBTable">
                    <thead>
                        <tr>
                            <th>交易类型</th>
                            <th>金额</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>

                <table class="table" id="coinBtoATable">
                    <thead>
                        <tr>
                            <th>交易类型</th>
                            <th>金额</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="section">
            <div class="section-title">按日期统计</div>
            <table class="table" id="dateTable" style="height: 200px; overflow-y: auto; display: block;">
                <thead>
                    <tr>
                        <th>日期</th>
                        <th>金币消耗</th>
                        <th>积分产生</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </form>

    <script type="text/javascript">
        $(function () {
            // 获取URL参数
            var userA = getUrlParam('userA');
            var userB = getUrlParam('userB');

            console.log('URL参数:', { userA: userA, userB: userB });

            $('#userA').text(userA);
            $('#userB').text(userB);

            // 加载金币交易数据
            console.log('开始加载金币交易数据');
            loadCoinTransaction(userA, userB);

            // 加载积分交易数据
            console.log('开始加载积分交易数据');
            loadScoreTransaction(userA, userB);

            // 加载按日期统计数据
            console.log('开始加载按日期统计数据');
            loadTransactionByDate(userA, userB);
        });

        function getUrlParam(name) {
            var reg = new RegExp("(^|&)" + name + "=([^&]*)(&|$)");
            var r = window.location.search.substr(1).match(reg);
            if (r != null) return unescape(r[2]);
            return null;
        }

        function formatNumber(num) {
            if (num === 0 || num === '0') return '0';
            var numStr = num.toString();
            if (numStr.length > 3) {
                return numStr.replace(/\B(?=(\d{3})+$)/g, ',');
            }
            return numStr;
        }

        function loadCoinTransaction(userA, userB) {
            var url = "/Admin1/GetCoinTransaction?userA=" + userA + "&userB=" + userB;
            console.log('金币交易请求URL:', url);
            
            $.ajax({
                type: "GET",
                url: url,
                data: { "userA": userA, "userB": userB },
                success: function (data) {
                    console.log('金币交易返回数据:', data);
                    
                    // 解析JSON字符串
                    var coinAtoB = JSON.parse(data.AtoB);
                    console.log('A到B的金币数据:', coinAtoB);
                    // 计算总额
                    var totalAtoB = 0;
                    coinAtoB.forEach(function (item) {
                        totalAtoB += item.amount;
                    });
                    console.log('A到B的金币总额:', totalAtoB);
                    $('#coinAtoBTotal').text(formatNumber(totalAtoB));
                    
                    var coinAtoBTable = $('#coinAtoBTable tbody');
                    coinAtoBTable.empty();
                    
                    if (coinAtoB.length === 0) {
                        $('#coinAtoBTable').hide();
                    } else {
                        $('#coinAtoBTable').show();
                        coinAtoB.forEach(function (item) {
                            coinAtoBTable.append('<tr><td>' + item.transaction_type + '</td><td class="coin-value number-format">' + formatNumber(item.amount) + '</td></tr>');
                        });
                    }

                    // 处理B到A的金币数据
                    var coinBtoA = JSON.parse(data.BtoA);
                    console.log('B到A的金币数据:', coinBtoA);
                    // 计算总额
                    var totalBtoA = 0;
                    coinBtoA.forEach(function (item) {
                        totalBtoA += item.amount;
                    });
                    console.log('B到A的金币总额:', totalBtoA);
                    $('#coinBtoATotal').text(formatNumber(totalBtoA));
                    
                    var coinBtoATable = $('#coinBtoATable tbody');
                    coinBtoATable.empty();
                    
                    if (coinBtoA.length === 0) {
                        $('#coinBtoATable').hide();
                    } else {
                        $('#coinBtoATable').show();
                        coinBtoA.forEach(function (item) {
                            coinBtoATable.append('<tr><td>' + item.transaction_type + '</td><td class="coin-value number-format">' + formatNumber(item.amount) + '</td></tr>');
                        });
                    }
                },
                error: function (xhr, status, error) {
                    console.error('金币交易请求失败:', status, error);
                }
            });
        }

        function loadScoreTransaction(userA, userB) {
            var url = "/Admin1/GetScoreTransaction?userA=" + userA + "&userB=" + userB;
            console.log('积分交易请求URL:', url);
            
            $.ajax({
                type: "GET",
                url: url,
                data: { "userA": userA, "userB": userB },
                success: function (data) {
                    console.log('积分交易返回数据:', data);
                    
                    // 解析JSON字符串
                    var scoreAtoB = JSON.parse(data.AtoB);
                    console.log('A到B的积分数据:', scoreAtoB);
                    // 计算总额
                    var totalAtoB = 0;
                    scoreAtoB.forEach(function (item) {
                        totalAtoB += item.amount;
                    });
                    console.log('A到B的积分总额:', totalAtoB);
                    $('#scoreAtoBTotal').text(formatNumber(totalAtoB));
                    
                    var scoreAtoBTable = $('#scoreAtoBTable tbody');
                    scoreAtoBTable.empty();
                    
                    if (scoreAtoB.length === 0) {
                        $('#scoreAtoBTable').hide();
                    } else {
                        $('#scoreAtoBTable').show();
                        scoreAtoB.forEach(function (item) {
                            scoreAtoBTable.append('<tr><td>' + item.transaction_type + '</td><td class="score-value number-format">' + formatNumber(item.amount) + '</td></tr>');
                        });
                    }

                    // 处理B到A的积分数据
                    var scoreBtoA = JSON.parse(data.BtoA);
                    console.log('B到A的积分数据:', scoreBtoA);
                    // 计算总额
                    var totalBtoA = 0;
                    scoreBtoA.forEach(function (item) {
                        totalBtoA += item.amount;
                    });
                    console.log('B到A的积分总额:', totalBtoA);
                    $('#scoreBtoATotal').text(formatNumber(totalBtoA));
                    
                    var scoreBtoATable = $('#scoreBtoATable tbody');
                    scoreBtoATable.empty();
                    
                    if (scoreBtoA.length === 0) {
                        $('#scoreBtoATable').hide();
                    } else {
                        $('#scoreBtoATable').show();
                        scoreBtoA.forEach(function (item) {
                            scoreBtoATable.append('<tr><td>' + item.transaction_type + '</td><td class="score-value number-format">' + formatNumber(item.amount) + '</td></tr>');
                        });
                    }
                },
                error: function (xhr, status, error) {
                    console.error('积分交易请求失败:', status, error);
                }
            });
        }

        function loadTransactionByDate(userA, userB) {
            var url = "/Admin1/GetTransactionByDate?userA=" + userA + "&userB=" + userB;
            console.log('按日期统计请求URL:', url);
            
            $.ajax({
                type: "GET",
                url: url,
                data: { "userA": userA, "userB": userB },
                success: function (data) {
                    console.log('按日期统计返回数据:', data);
                    
                    var dateTable = $('#dateTable tbody');
                    dateTable.empty();
                    
                    if (data.length === 0) {
                        console.log('没有按日期统计数据');
                        dateTable.append('<tr><td colspan="3">暂无数据</td></tr>');
                    } else {
                        data.forEach(function (item) {
                            dateTable.append('<tr><td>' + item.date + '</td><td class="coin-value number-format">' + formatNumber(item.金币消耗) + '</td><td class="score-value number-format">' + formatNumber(item.积分产生) + '</td></tr>');
                        });
                    }
                },
                error: function (xhr, status, error) {
                    console.error('按日期统计请求失败:', status, error);
                }
            });
        }
    </script>
</body>
</html>