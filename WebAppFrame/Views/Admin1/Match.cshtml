

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=10"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .txt {
            height: 22px;
            line-height: 22px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding-left: 5px;
            width: 220px;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 18px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }

        .sum-desc {
            text-align: left;
            margin-left: 10px;
            border-left: 1px solid #dcdcdc;
            padding-left:3px;
            color:#666;
            font-size:10px;
        }

        .red2 {
            font-size: 28px;
            font-weight: bold;
            color: #f00;
        }

        .blue2 {
            font-size: 28px;
            font-weight: bold;
            color: blue;
        }
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            //grid.load();
            search();
            drawCell();

            init();
            bindEvent();
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详 情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml += '<a style="color:blue;" href="javascript:UserAllInfo(\'' + record.uid + '\')">全貌</a>';
                    e.cellHtml += '&nbsp;&nbsp;&nbsp;&nbsp;';
                }

                if (column.name == "photo_from") {
                    var photo = servUrl_AppData + '/photo/' + record.photo_from;
                    var nick = record.nick_from;
                    var sex = record.sex_from;
                    
                    var cls = "blue";
                    if (sex == "女生") {
                        cls = "red";
                    }

                    var zctime = DateDiff_Txt(record.first_time_from, new Date().toString());
                    var totalcoin = record.totalcoin_from;
                    var totalscore = record.totalscore_from;

                    //聊天情况
                    var today_send_suc = 20;
                    var today_send_fail = 10;
                    var today_rece_suc = 15;
                    var today_rece_fail = 16;

                    var yes_send_suc = 200;
                    var yes_send_fail = 100;
                    var yes_rece_suc = 150;
                    var yes_rece_fail = 160;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<div class="ub">';
                    e.cellHtml += '<div style="width:150px;"><img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "<br/><span class='" + cls + "'>" + nick + "</span></div>";
                    e.cellHtml += '<div class="sum-desc">';
                    e.cellHtml += '<span>注册时长:<span class="blue">' + zctime + '</span></span> <br/>';
                    if (sex == "男生")
                    {
                        e.cellHtml += '<span>豪气值:<span class="red">' + totalcoin + '</span></span> <br/>';
                    }
                    else {
                        e.cellHtml += '<span>魅力值:<span class="blue">' + totalscore + '</span></span> <br/>';
                    }
                    
                    
                    //e.cellHtml += '<hr>';
                    //e.cellHtml += '<span>今日--><span>发送成功:</span><span class="blue">' + today_send_suc + '</span><span>； 失败:</span><span class="red">' + today_send_fail + '</span></span> <br/>';
                    //e.cellHtml += '<span>今日--><span>接收成功:</span><span class="blue">' + today_rece_suc + '</span><span>； 失败:</span><span class="red">' + today_rece_fail + '</span></span> <br/>';

                    //e.cellHtml += '<span>历史--><span>发送成功:</span><span class="blue">' + yes_send_suc + '</span><span>； 失败:</span><span class="red">' + yes_send_fail + '</span></span> <br/>';
                    //e.cellHtml += '<span>历史--><span>接收成功:</span><span class="blue">' + yes_rece_suc + '</span><span>； 失败:</span><span class="red">' + yes_rece_fail + '</span></span> <br/>';
                    
                    e.cellHtml += '</div>';
                }

                if (column.name == "photo_to") {
                    var photo = servUrl_AppData + '/photo/' + record.photo_to;
                    var nick = record.nick_to;
                    var sex = record.sex_to;
                    var cls = "blue";
                    if (sex == "女生") {
                        cls = "red";
                    }

                    var zctime = DateDiff_Txt(record.first_time_to, new Date().toString());
                    var totalcoin = record.totalcoin_to;
                    var totalscore = record.totalscore_to;


                    //聊天情况
                    var today_send_suc = 20;
                    var today_send_fail = 10;
                    var today_rece_suc = 15;
                    var today_rece_fail = 16;

                    var yes_send_suc = 200;
                    var yes_send_fail = 100;
                    var yes_rece_suc = 150;
                    var yes_rece_fail = 160;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<div class="ub">';
                    e.cellHtml += '<div style="width:150px;"><img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "<br/><span class='" + cls + "'>" + nick +  "</span></div>";
                    e.cellHtml += '<div class="sum-desc">';
                    e.cellHtml += '<span>注册时长:<span class="blue">' + zctime + '</span></span> <br/>';
                    if (sex == "男生") {
                        e.cellHtml += '<span>豪气值:<span class="red">' + totalcoin + '</span></span> <br/>';
                    }
                    else {
                        e.cellHtml += '<span>魅力值:<span class="blue">' + totalscore + '</span></span> <br/>';
                    }

                    //e.cellHtml += '<hr>';
                    //e.cellHtml += '<span>今日--><span>发送成功:</span><span class="blue">' + today_send_suc + '</span><span>； 失败:</span><span class="red">' + today_send_fail + '</span></span> <br/>';
                    //e.cellHtml += '<span>今日--><span>接收成功:</span><span class="blue">' + today_rece_suc + '</span><span>； 失败:</span><span class="red">' + today_rece_fail + '</span></span> <br/>';

                    //e.cellHtml += '<span>历史--><span>发送成功:</span><span class="blue">' + yes_send_suc + '</span><span>； 失败:</span><span class="red">' + yes_send_fail + '</span></span> <br/>';
                    //e.cellHtml += '<span>历史--><span>接收成功:</span><span class="blue">' + yes_rece_suc + '</span><span>； 失败:</span><span class="red">' + yes_rece_fail + '</span></span> <br/>';

                    e.cellHtml += '</div>';
                }

                if (column.name == "dtm") {
                    var dtm = record.dtm;
                    var dtm_now = new Date().toString();
                    var txt = DateDiff_Txt(dtm, dtm_now);
                    var cls = "";

                    e.cellStyle = "text-align:center";
                    e.cellHtml = "<span class='" + cls + "'>" + txt + "前</span>";
                }

                if (column.name == "msg_count_suc") {
                    var msg_count_suc = record.msg_count_suc;
                    var msg_count_fail = record.msg_count_fail;
                    var msg_count_suc_today = record.msg_count_suc_today;
                    var msg_count_fail_today = record.msg_count_fail_today;

                    e.cellStyle = "text-align:left";
                    e.cellHtml = "<span class='blue2'>" + msg_count_suc + "</span>";
                    e.cellHtml += " - <span class='red2'>" + msg_count_fail + "</span>";

                    e.cellHtml += " ---(<span class='blue'>" + msg_count_suc_today + "</span>";
                    e.cellHtml += " - <span class='red'>" + msg_count_fail_today + "</span>)";
                }

            });
        }
    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 110);
        }

        function bindEvent() {
        }


        function search() {
            var uid = $("#uid").val();
            var dtm_start = mini.get("dtm_start").getText();
            var dtm_end = mini.get("dtm_end").getText();

            grid.load({
                "start": dtm_start,
                "end": dtm_end,
                "id": uid
            });
        }

    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">匹配明细</a></li>
        </ul>
    </div>
    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            起始时间: <input id="dtm_start" format="yyyy-MM-dd HH:mm:ss" class="mini-datepicker" style="width:180px;" value="@ViewData["start"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            截止时间: <input id="dtm_end" format="yyyy-MM-dd HH:mm:ss" class="mini-datepicker" style="width:180px;" value="@ViewData["end"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            uid:<input type="text" class="txt" id="uid" />&nbsp;&nbsp;&nbsp;&nbsp;

            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Admin1/GetMatchData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[20,50,100]" pagesize="50">
            <div property="columns">
                <div field="xh" width="40" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="uid" width="100" renderer="onGenderRenderer" align="left" headeralign="center">uid</div>
                <div name="dtm" width="40" renderer="onGenderRenderer" align="left" headeralign="center">dtm</div>
                <div name="photo_from" width="240" renderer="onGenderRenderer" align="center" headeralign="center">发起匹配者</div>
                <div name="photo_to" width="240" renderer="onGenderRenderer" align="center" headeralign="center">被匹配者</div>

                <div name="msg_count_suc" width="240" renderer="onGenderRenderer" align="center" headeralign="center">聊天量</div>
               
                <div name="dtl" width="100" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>


