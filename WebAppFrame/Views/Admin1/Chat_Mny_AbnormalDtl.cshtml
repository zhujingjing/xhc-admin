
<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>

    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/Style_chart.css" rel="stylesheet" />
    <link href="~/Styles/public.css" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=77"></script>
    <style>
        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        #chat_dtl {
            overflow-x: hidden;
            border: solid 1px #dcdcdc;
            background-color: RGB(239,239,244);
        }

        .font-bold {
            font-weight: bold;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
        }

        .size-x {
            font-size: 14px;
            color: blue;
        }

        .size-xx {
            font-size: 14px;
            font-weight: bold;
            color: blue;
        }

        .size-xxx {
            font-size: 18px;
            font-weight: bold;
            color: blue;
        }

        .gray {
            color: red;
        }

        .msg-rece {
            display: flexbox;
            border: solid 1px red;
            padding: 8px;
            color: white;
            background-color: black;
            font-size: 18px;
            font-weight: bold;
        }

        .lb {
            color: #666;
            margin-left: 20px;
        }

        .txt {
            margin-left: 6px;
            font-weight: bold;
            font-size: 18px;
        }

        .right {
            display: flex;
            justify-content: flex-end;
            align-items: center;
        }

        .left {
            display: flex;
            justify-content: flex-start;
            align-items: center;
        }

        .off {
            position: fixed;
            bottom: 30px;
            right: 80px;
            padding: 5px 10px;
            background-color: #e92162;
            color: #fff;
            border-radius: 5px;
            width: 400px;
            text-align: center;
        }

        .msg-more {
            text-align: center;
            color: blue;
            cursor: pointer;
        }

        .message-text {
            margin-left: 5px;
            margin-right: 5px;
        }

        .fg-line {
            text-align: center;
            color: #808080;
            background: #dcdcdc;
        }
    </style>

    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var uid_from = '@ViewData["uid_from"]';
        var uid_to = '@ViewData["uid_to"]';
        var dtm = '@ViewData["dtm"]';
        var photo_from = "";
        var photo_to = "";
        var grid;

        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent).height();
            $("#datagrid1,#chat_dtl").height(parentHeight - 200);
            mini.parse();
            grid = mini.get("datagrid1");
            //grid.load();
            drawCell();
            setTimeout(() => {
                init_chat();
            },500)
            search();
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;
                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;
                    //聊天头像
                    var from_uid = record.uid_from;
                    if (from_uid == uid_from) {
                        photo_from = photo;
                    }
                    if (from_uid == uid_to) {
                        photo_to = photo;
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid_from + '\')"><img src="' + photo + '" class="photo-img" /></a>';
                }

                if (column.field == "msg_type") {
                    var msg_type = record.msg_type;
                    if (msg_type == "收入") {
                        e.rowStyle = 'background-color:#fcc;';
                    }
                }

                if (column.name == "dtm") {
                    var dtm = record.dtm;
                    dtm = formatTimestamp(dtm);
                    dtm = dtm.replace(' ', '<br/>');
                    e.cellHtml = '<span>' + dtm + '</span>';
                }

            });
        }

        function init_chat() {
            var start = dtm + " 00:00:00";
            var end = dtm + " 23:59:59";
           
            $.ajax({
                type: "GET",
                url: "/Admin1/GetChartA_B",
                data: { "start": start, "end": end, "from": uid_from, "to": uid_to },
                success: function (data) {
                    data = JSON.parse(data);
                    show_msg(data);
                }
            });
        }

        function search() {
           
            grid.load({
                "dtm": dtm,
                "uid_from": uid_from,
                "uid_to": uid_to
            });
        }

        function onValueChanged() {
         
        }
    </script>

    <script type="text/javascript">

        function show_msg(data) {
            for (var i = 0; i < data.length; i++) {
                if (data[i].uid_to == uid_from) {
                    appendHistory("3", data[i], 1);
                }
                if (data[i].uid_to == uid_to) {
                    appendHistory("2", data[i], 1);
                }

            }
        }

        function appendHistory(txtType, data, pos) {
            var txt = data.txt;
            var msg_type = data.type;
            if (msg_type == "gif" || msg_type == "emoji" || msg_type == "gift") {
                txt = "<img src='" + txt + "' style='width:100px;' />";
            }
            if (msg_type == "pic") {
                txt = "<span style='color: blue;' onclick='show_pic(\"" + txt + "\")'>【图片】-详情</span>";
            }

            var id = '';
            var htmlTxt = '';
            var iwidth;

            var font_wt = "";
            var time_ss = "";

            if (pos == 1) {
                var timestamp = parseInt(data.dtm.match(/\d+/)[0], 10);
                var dtm = new Date(timestamp);
                time_ss = formatTimestamp(dtm);
            }
            if (pos == -1) {
                time_ss = data.dtm;
                if (data.dtm.startsWith('/Date')) {
                    var timestamp = parseInt(data.dtm.match(/\d+/)[0], 10);
                    var dtm = new Date(timestamp);
                    time_ss = formatTimestamp(dtm);
                }
                //time_ss = data.dtm.substr(10, 10); //data.dtm.replace(" ", "<br/>");
            }
            time_ss = time_ss.substr(10, 10);

            switch (txtType) {

                case "2":
                    id = Math.floor(Math.random() * 100000);

                    htmlTxt = '<div id="m' + id + '" class="message right" style="max-width: 45rem;"><div class="" style="">' + time_ss + '</div> <div class="message-text' + font_wt + '" style="max-width: 30rem;">' + txt + '</div><img id="photo_to" style="width:50px; height:50px; border-radius:50%;" src="' + photo_from + '"/></div>';
                    if (pos == 1) {
                        $(".messages").append(htmlTxt);
                    }
                    if (pos == -1) {
                        $(".messages").prepend(htmlTxt);
                    }

                    iwidth = $("#m" + id + " .message-text").width() + 60;
                    $("#m" + id + " .readSign").css({ "right": iwidth.toString() + "px", "visibility": "visible" });
                    break;
                //对方说话
                case "3":
                    id = Math.floor(Math.random() * 100000);
                    htmlTxt = '<div id="m' + id + '" class="message left" style="max-width: 45rem;"> <img id="photo_to" style="width:50px; height:50px; border-radius:50%;" src="' + photo_to + '"/> <div class="message-text' + font_wt + '" style="max-width: 30rem; margin-right: 10px;" >' + txt + '</div><div class="" style="">' + time_ss + '</div></div>';

                    if (pos == 1) {
                        $(".messages").append(htmlTxt);
                    }
                    if (pos == -1) {
                        $(".messages").prepend(htmlTxt);
                    }
                    break;

            }
        }

        function show_pic(url) {
            document.getElementById("img-album").src = url;
            document.getElementById("popup").style.display = 'flex';
        }
        function closePopup() {
            document.getElementById("popup").style.display = 'none';
        }

    </script>
</head>
<body>
    <div id="popup" class="ub ub-pc ub-ac" style="display: none; justify-content:center; align-items:center; position: fixed; top: 0; right: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.9); z-index: 99;" onclick="closePopup()">
        <img id="img-album" style="width: auto; height: 80%;" src="" />
    </div>
    <form id="form1">
        <table>
            <tr>
                <td style="display: flex; justify-content: space-between;">
                    <div style="width: 49%;">
                        <div id="chat_dtl">

                            <div class="content-inner" style="height:100%; margin-top: 0; transition-timing-function: cubic-bezier(0.1, 0.57, 0.1, 1); transition-duration: 0ms; transform: translate(0px, 0px) translateZ(0px);">
                                <div id="contMsg" class="messages"></div>
                            </div>
                        </div>
                    </div>

                    <div id="datagrid1" class="mini-datagrid" style="width:49%;"
                         url="/Admin1/GetAbnormalDtlData" idfield="id" allowresize="true"
                         showsummaryrow="true"
                         sizelist="[50,100,200]" pagesize="100">
                        <div property="columns">

                            <div field="xh" name="xh" width="30" headeralign="center" align="center" allowsort="false">序号</div>
                            <div field="dtm" name="dtm" width="50" align="center" headeralign="center">时间</div>
                            <div name="photo" field="photo" width="30" align="center" headeralign="center">头像</div>
                            <div field="sex" width="30" align="center" headeralign="center">性别</div>
                            <div field="nick" width="30" align="center" headeralign="center">昵称</div>
                            <div field="msg_type" width="30" align="center" headeralign="center">类型</div>
                            <div field="amount" width="30" align="center" headeralign="center">积分/金币</div>
                            <div field="uid_from" width="30" align="center" headeralign="center">uid_from</div>
                            <div field="uid_to" width="30" align="center" headeralign="center">uid_to</div>



                        </div>
                    </div>


                </td>
            </tr>
        </table>

    </form>
</body>
</html>
