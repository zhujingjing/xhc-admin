
<!DOCTYPE HTML PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>小火柴管理员后台</title>

    <link href="~/Styles/style.css" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/cloud.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <script language="javascript">
        $(function () {
            $('.loginbox').css({ 'position': 'absolute', 'left': ($(window).width() - 692) / 2 });
            $(window).resize(function () {
                $('.loginbox').css({ 'position': 'absolute', 'left': ($(window).width() - 692) / 2 });
            })
        });
    </script>

</head>

<body style="background-color:#1c77ac; background-repeat:no-repeat; background-position:center top; overflow:hidden;">
    <div id="mainBody">
        <div id="cloud1" class="cloud"></div>
        <div id="cloud2" class="cloud"></div>
    </div>

    <div>
        <input type="hidden" id="sys_type" value="admin1" />
    </div>

    <div class="logintop">
        <span>欢迎登录 小火柴管理员后台</span>
        <ul>
            <li><a href="/Admin1/Login">回首页</a></li>
            <li><a href="#">帮助</a></li>
            <li><a href="#">关于</a></li>
        </ul>
    </div>

    <div class="loginbody">
        <span class="systemlogo"></span>
        <div class="loginbox">
            <ul>
                <li><input name="" id="name" type="text" class="loginuser" placeholder="请输入账号" /></li>
                <li><input name="" id="password" type="password" class="loginpwd" placeholder="请输入密码" /></li>
                <li><input name="" id="button" type="button" class="loginbtn" value="登录" /></li>
            </ul>
        </div>
    </div>

    <div class="loginbm">版权所有  武汉锦盛长欣科技有限公司  <a href="http://www.zhuochuangzb.com/"></a> 未经同意，严禁使用</div>
</body>

</html>

<script>
    //回车键
    document.onkeydown = function (e) {
        if (!e) e = window.event; //火狐中是 window.event
        if ((e.keyCode || e.which) == 13) {
            var btlogin = document.getElementById("button");
            btlogin.focus();
            btlogin.click();
        }
    }

    $(function () {
        //绑定按钮点击事件
        $("#button").bind("click", function () {
            //window.location.href = "/Admin1/Frame_Main";
            //return;

            bindUser();
            return false;
        });
    });
    //绑定
    function bindUser() {
        //按钮处理
        $("#button").val("正在登录...");
        $("#button").attr("disabled", "disabled");

        //获取表单数据
        var name = $("#name").val();
        var password = $("#password").val();

        //检查数据
        if (name == "") {
            alert("用户名不能为空");
            $("#button").val("登录");
            $("#button").removeAttr("disabled");
            $("#name").focus();
            return false;
        }
        if (password == "") {
            alert("密码不能为空");
            $("#button").val("登录");
            $("#button").removeAttr("disabled");
            $("#password").focus();
            return false;
        }

        $.ajax({
            type: "POST",
            url: "/Admin1/SysLogin",
            data: { "user_name": name, "pwd": password },
            success: function (data) {
                //alert(data);
                data = strToJson(data);
                if (data.state == "1") {
                    window.location.href = "/Admin1/Frame_Main/" + data.msg;
                }
                else {
                    alert(data.msg);
                    $("#button").removeAttr("disabled");
                    $("#button").val("登录");
                }
            }
        });

    }

</script>