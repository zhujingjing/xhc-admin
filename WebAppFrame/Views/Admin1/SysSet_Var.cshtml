

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=9"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 18px;
            font-weight: bold;
            color: blue;
        }
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 100);

            mini.parse();

            grid = mini.get("datagrid1");

            grid.load();
            //search();

            drawCell();

            init();
        })

        function init() {

        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;
                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:left";
                    e.cellHtml = '<a style="color:blue;" href="javascript:Add(\'' + record.id + '\')">&nbsp;&nbsp;修改</a>';
                }
            });
        }

        function Add(id) {
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            var parentWidth = $(window.parent.document).find("#rightFrame").width();

            mini.open({
                url: "/Admin1/SysSet_VarAdd/" + id,
                showMaxButton: false,
                title: "添加系统参数",
                width: 600,
                height: 550,
                ondestroy: function (action) {
                    if (action == "ok") {
                        grid.reload();
                    }
                    else if (action == "cancel") {

                    }
                }
            });
        }



    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">签约用户管理</a></li>
        </ul>
    </div>

    <form id="form1">

        <div class="tools">
            <ul class="toolbar">
                <li class="click" onclick="Add('')"><span><img src="/Images/frame/t01.png" /></span>添加</li>
            </ul>
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Admin1/GetSysSetParm" idfield="id" allowresize="true" multiselect="true"
             sizelist="[50,100]" pagesize="50">
            <div property="columns">
                <div field="xh" width="20" renderer="onGenderRenderer" align="center" headeralign="center">序号</div>
                <div field="key" width="60" renderer="onGenderRenderer" align="left" headeralign="center">key</div>
                <div field="value" width="180" renderer="onGenderRenderer" align="left" headeralign="center">value</div>
                <div field="type" width="60" headeralign="center" align="left" allowsort="false">type</div>
                <div field="comment" width="200" headeralign="center" align="left" allowsort="false">备注</div>

                <div name="dtl" width="100" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>
