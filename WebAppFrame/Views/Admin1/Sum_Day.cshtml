<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>日统计</title>

    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/public.css" rel="stylesheet" />
    <link href="~/Styles/style.css" rel="stylesheet" />

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }
    </style>


    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var grid;

        var left_count = 0;
        var left_vip_count = 0;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#datagrid1").height(parentHeight - 80);

            mini.parse();

            grid = mini.get("datagrid1");

            search();

            drawCell();

            init();
        })

        function init() {

        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                if (column.field == "mny") {
                   var txt = record.mny;
                   txt = txt.toFixed(2);
                   e.cellHtml = '<span>' + txt + '</span>';
                }
                if (column.field == "mny_coin") {
                    var txt = record.mny_coin;
                    txt = txt.toFixed(2);
                    e.cellHtml = '<span>' + txt + '</span>';
                }
                if (column.field == "mny_mem") {
                    var txt = record.mny_mem;
                    txt = txt.toFixed(2);
                    e.cellHtml = '<span>' + txt + '</span>';
                }
                if (column.field == "new_mny") {
                    var txt = record.new_mny;
                    txt = txt.toFixed(2);
                    e.cellHtml = '<span>' + txt + '</span>';
                }
                if (column.field == "old_mny") {
                    var txt = record.old_mny;
                    txt = txt.toFixed(2);
                    e.cellHtml = '<span>' + txt + '</span>';
                }
                if (column.field == "r1") {
                    var txt = record.r1;
                    txt = txt.toFixed(2);
                    e.cellHtml = '<span>' + txt + '%</span>';
                }
                if (column.field == "r2") {
                    var txt = record.r2;
                    txt = txt.toFixed(2);
                    e.cellHtml = '<span>' + txt + '%</span>';
                }

               
            });
        }

        function search() {
            var start = mini.get("start").getText();
            var end = mini.get("end").getText();
            grid.load({
                "start": start,
                "end":end
            });
        }

    </script>

</head>
<body>
    <form id="form1">
        <div style="padding:10px; margin-bottom:5px; border: solid 1px #dcdcdc;">
            开始日期:<input id="start"  format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["start"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            截止日期<input id="end"  format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["end"]" /> &nbsp;&nbsp;&nbsp;&nbsp;

            <!--<input type="button" value="查询" class="sys-btn" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;-->
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px;"
             url="/Admin1/GetSumDayData" idfield="id" allowresize="true"
             sizelist="[50, 100,300]" pagesize="300">
            <div property="columns">
                <div field="dtm" width="90" renderer="onGenderRenderer" align="center" headeralign="center">日期</div>
                <div field="new_count" width="80" headeralign="center" align="center" allowsort="false">新增用户</div>
                <div field="new_count_self" width="100" headeralign="center" align="center" allowsort="false">新增用户(过滤渠道)</div>
                <div field="act_count" width="80" headeralign="center" align="center" allowsort="false">日活用户</div>
                <div field="men_count" width="80" headeralign="center" align="center" allowsort="false">付费人数</div>
                <div field="order_count" width="80" headeralign="center" align="center" allowsort="false">订单总数</div>
                <div field="mny" width="80" headeralign="center" align="center" allowsort="false">总付费金额</div>
                <div field="mny_coin" width="80" headeralign="center" align="center" allowsort="false">金额(金币)</div>
                <div field="mny_mem" width="80" headeralign="center" align="center" allowsort="false">金额(会员)</div>
                <div field="newmen_count" width="80" headeralign="center" align="center" allowsort="false">新用户付费人数</div>
                <div field="new_mny" width="80" headeralign="center" align="center" allowsort="false">新用户付费金额</div>
                <div field="oldmen_count" width="80" headeralign="center" align="center" allowsort="false">老用户付费人数</div>
                <div field="old_mny" width="80" headeralign="center" align="center" allowsort="false">老用户付费金额</div>
                <div field="r1" width="80" headeralign="center" align="center" allowsort="false">新用户付费比</div>
                <div field="r2" width="80" headeralign="center" align="center" allowsort="false">老用户付费比</div>
               
                <div name="dtl" width="80" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>

    </form>
</body>
</html>


