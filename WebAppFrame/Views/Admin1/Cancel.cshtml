
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/demo.css" rel="stylesheet" type="text/css" />
    <style>
        .btn {
            margin-top: 20px;
            color: white;
            font-weight: 500;
            font-size: 18px;
            line-height: 30px;
            bottom: 0;
            border: 1px solid RGB(62,175,224);
            border-radius: 5px;
            width: 40%;
            cursor: pointer;
        }

        .ok {
            background-color: RGB(62,175,224);
        }

        .main {
            margin-top: 100px;
            display: flex;
            justify-content: center;
        }

        #form1 {
            text-align: center;
        }

        
    </style>
</head>
<body>
    <div class="main">
        <form id="form1">
            <span>输入密码:</span>
            <input type="password" id="password" style="width:200px; height:28px; line-height:28px;" />
            <br />
            <input type="button" id="btn_ok" class="btn ok" value="确定" />
        </form>
    </div>
</body>
</html>

<script src="~/Scripts/jquery-1.8.2.min.js"></script>

<script type="text/javascript">
    $(function () {

        $("#btn_ok").bind("click", function () {
            var uid = "@ViewData["uid"]";
            var zhuxiao_pwd = "@ViewData["zhuxiao_pwd"]"
            var password = $("#password").val();
            if (password == "") {
                alert("密码不能为空");
                $("#password").focus();
                return false;
            }
            if (password == zhuxiao_pwd) {
                $.ajax({
                    type: "POST",
                    url: "/Admin1/Do_Cancel/"+ uid,
                    success: function (data) {
                        var data = JSON.parse(data);
                        if (data.state == "1") {
                            alert("注销成功");
                            CloseWindow("ok");
                        }
                        if (data.state == "0") {
                            alert(data.msg);
                        }
                    }
                });
            } else {
                alert("密码错误");
                $("#password").val("");
                $("#password").focus();
            }


        });

    });


    function CloseWindow(action) {
        if (window.CloseOwnerWindow) return window.CloseOwnerWindow(action);
        else window.close();
    }
</script>