
<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>

    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/Style_chart.css?id=1" rel="stylesheet" />
    <link href="~/Styles/public.css" rel="stylesheet" />
    <style>
        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        #chat_dtl {
            overflow-x: hidden;
            overflow-y: scroll;
            border: solid 1px #dcdcdc;
            background-color: RGB(239,239,244);
        }

        .font-bold {
            font-weight: bold;
        }

        .photo-img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
        }
        .right{
           display:flex;
           justify-content:flex-end;
           align-items:center;
        }
        .left{
            display:flex;
           justify-content:flex-start;
           align-items:center;
        }
        .off{
             position: fixed;
             bottom:30px;
             right:80px;
             padding:5px 10px;
             background-color:#e92162;
             color:#fff;
             border-radius:5px;
             width:400px;
             text-align:center;
        }
        .msg-more{
            text-align:center;
            color:blue;
            cursor:pointer;
        }

        .message-text{
            margin-left:5px;
            margin-right:5px;
        }

        .fg-line{
            text-align:center;
            color:#808080;
            background:#dcdcdc;
        }

        .alert_json {
            display: none;
            position: fixed;
            margin: auto;
            left: 0;
            right: 0;
            top: 0;
            bottom: 0;
            width: 550px;
            height: 700px;
            background-color: #E3E6E8;
            border: 1px solid #999999;
            z-index: 99;
        }

        .close {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 10px;
            height: 30px;
        }

            .close span {
                font-size: 14px;
            }
    </style>

    <script type="text/javascript">

        var msg_dtl = "@ViewData["msg_dtl"]";

        var servUrl_AppData ="@ViewData["servUrl_AppData"]";
        var photo_from =servUrl_AppData+"/photo/"+"@ViewData["photo_from"]";
        var photo_to =servUrl_AppData+"/photo/"+"@ViewData["photo_to"]";

        var dtm_pre = '@ViewData["dtm"]';

        var uid_to = '@ViewData["to"]';
        var uid_from = '@ViewData["from"]';

        var pre_time = '@ViewData["start"]';
        var after_time = '@ViewData["end"]';

        $(function () {
            if(msg_dtl != "1"){
                $("#chat_dtl").hide();
                return false;
            }

            init();

            $("#off").bind("click",function(){
                CloseWindow("ok");
            })

        })

        function CloseWindow(action) {
            if (window.CloseOwnerWindow) return window.CloseOwnerWindow(action);
            else window.close();
        }

        function init() {
            var data = @Html.Raw(ViewData["data"]);

            //清空上次内容
            //增加一个分割线
            var htmlTxt = '<div class="fg-line">' + dtm_pre.substr(0, 10) + '</div>';
            $(".messages").prepend(htmlTxt);
            dtl(data);
        }

        //前一天
        function history_msg_front() {
            //后台
            var start = pre_time;
            var time = get_dtm(start,"front");
            pre_time = time;
            $.ajax({
                type: "GET",
                url: "/Admin1/GetChartA_B",
                data: { "start": time + " 00:00:00", "end": time +" 23:59:59", "from": uid_from, "to": uid_to },
                success: function (data) {
                    console.log(data);
                    data = JSON.parse(data);
                    dtl_history(data, uid_to, uid_from, -1);
                    //增加一个分割线
                    var htmlTxt = '<div class="fg-line">' + time.substr(0, 10) + '</div>';
                    $(".messages").prepend(htmlTxt);
                }
            });

        }

        //后一天
        function history_msg_after() {
            //后台
            var start = after_time;
            var time = get_dtm(start, "after");
            after_time = time;
            $.ajax({
                type: "GET",
                url: "/Admin1/GetChartA_B",
                data: { "start": time + " 00:00:00", "end": time + " 23:59:59", "from": uid_from, "to": uid_to },
                success: function (data) {
                    data = JSON.parse(data);
                    //增加一个分割线
                    var htmlTxt = '<div class="fg-line">' + time.substr(0, 10) + '</div>';
                    $(".messages").append(htmlTxt);
                    var reversedData = data.reverse(); //处理后一天消息倒排
                    dtl_history(reversedData, uid_to, uid_from, 1);

                }
            });
        }

        function dtl_history(data, uid_to, uid_from ,pos) {
            for (var i = data.length - 1; i >= 0; i--) {
                if (data[i].type == "sys_probe") {
                    continue;
                }
                if (data[i].uid_to == uid_to) {
                    appendHistory("3", data[i], pos);
                }
                if (data[i].uid_to == uid_from) {
                    appendHistory("2", data[i], pos);
                }
            }
        }

        function get_dtm(dtm, type) {
            var [datePart, timePart] = dtm.split(" ");
            var dateParts = datePart.split("-");
            var year = parseInt(dateParts[0], 10);
            var month = parseInt(dateParts[1], 10) - 1; // 月份从0开始
            var day = parseInt(dateParts[2], 10);
            var date = new Date(year, month, day);
            date.setDate(date.getDate());
            if (type == "after") {
                date.setDate(date.getDate() + 2);
            }
            var newDate = date.toISOString().split("T")[0];
            return newDate;
        }

        function dtl(data) {

            var to = '@ViewData["to"]';
            var from = '@ViewData["from"]';

            for (var i = 0; i < data.length; i++) {
                if (data[i].uid_from == to) {
                    appendHistory("3", data[i],1);
                }
                if (data[i].uid_from == from) {
                    appendHistory("2", data[i],1);
                }
            }
        }

        function appendHistory(txtType, data, pos) {
            var txt = data.txt;
            var msg_type = data.type;
            if (msg_type == "gif" || msg_type == "emoji" || msg_type == "gift") {
                txt = "<img src='" + txt + "' style='width:100px;' />";
            }
            if (msg_type == "pic") {
                txt = "<span style='color: blue;' onclick='show_pic(\"" + txt + "\")'>【图片】-详情</span>";
            }
            if (msg_type == "voice") {
                var msg = JSON.parse(txt);
                txt = "<span style='color: blue;' onclick='show_vouce(" + JSON.stringify(msg) + ")'>【语音】" + msg.time + "''-" + msg.coin + "金币-详情</span>";
            }
            var id = '';
            var htmlTxt = '';
            var iwidth;

            var font_wt = "";
            var time_ss = "";

            if(pos == 1){
                time_ss = data.sj;
            }
            if(pos==-1){
                time_ss = data.dtm.substr(10,10); //data.dtm.replace(" ", "<br/>");
            }

            if (data.dtm.startsWith('/Date')) {
                var timestamp = parseInt(data.dtm.match(/\d+/)[0], 10);
                var dtm = new Date(timestamp);
                time_ss = formatTimestamp(dtm);
                time_ss = time_ss.substr(10, 10);
            }


            switch (txtType) {
                //自己说话
                case "2":
                    id = Math.floor(Math.random() * 100000);

                    htmlTxt = '<div id="m' + id + '" class="message right"><div class="" style="">' + time_ss + '</div> <div class="message-text ' + font_wt + '">' + txt + '</div> <img style="width:50px;border-radius:50%;" src="'+ photo_from +'"/> </div>';
                    if(pos == 1){
                        $(".messages").append(htmlTxt);
                    }
                    if(pos==-1){
                        $(".messages").prepend(htmlTxt);
                    }

                    iwidth = $("#m" + id + " .message-text").width() + 60;
                    $("#m" + id + " .readSign").css({ "right": iwidth.toString() + "px", "visibility": "visible" });
                    break;
                    //对方说话
                case "3":
                    id = Math.floor(Math.random() * 100000);
                    htmlTxt = '<div id="m' + id + '" class="message left"> <img id="photo_to" style="width:50px;border-radius:50%;" src="'+ photo_to +'"/> <div class="message-text' + font_wt + '">' + txt + '</div><div class="" style="">' + time_ss + '</div></div>';
                    if(pos == 1){
                        $(".messages").append(htmlTxt);
                    }
                    if(pos==-1){
                        $(".messages").prepend(htmlTxt);
                    }
                    break;

            }
        }

        function show_pic(url) {
            document.getElementById("img-album").src = url;
            document.getElementById("popup").style.display = 'flex';
        }
        function closePopup() {
            document.getElementById("popup").style.display = 'none';
            document.getElementById("alert_json").style.display = 'none';
        }

        function show_vouce(json_data) {
            json_data = JSON.stringify(json_data);
            document.getElementById("alert_json").style.display = 'flex';
            document.getElementById("alert_json").style.flexDirection = 'column';
            document.getElementById("alert_json").style.justifyContent = 'center';
            $("#json_data").html(json_data);
        }

    </script>
</head>
<body>
    <div id="popup" class="ub ub-pc ub-ac" style="display: none; justify-content:center; align-items:center; position: fixed; top: 0; right: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.9); z-index: 99;" onclick="closePopup()">
        <img id="img-album" style="width: auto; height: 80%;" src="" />
    </div>
    <div id="alert_json" class="alert_json">
        <div class="close">
            <span>json数据</span>
            <span style="font-size: 16px;" onclick="closePopup()">关闭</span>
        </div>
        <textarea id="json_data" style="height: 95%; background: white; resize: none;padding:3px;"></textarea>
    </div>

    <form id="form1">

        <div id="chat_dtl" style="width: 500px; height:720px;">

            <div class="content-inner" style="height:90%; transition-timing-function: cubic-bezier(0.1, 0.57, 0.1, 1); transition-duration: 0ms; transform: translate(0px, 0px) translateZ(0px);">
                <div id="btn_msg_more" class="msg-more" onclick="history_msg_front()">--- 前一天 ---</div>
                <div id="contMsg" class="messages"></div>
                <div id="btn_msg_more_after" class="msg-more" onclick="history_msg_after()">--- 后一天 ---</div>
            </div>
        </div>

    </form>
</body>
</html>
