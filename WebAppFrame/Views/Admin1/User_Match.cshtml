<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>

    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/public.css" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=77"></script>

    <style>
        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 30px;
            height: 30px;
            border-radius: 50%;
        }

        .gray {
            color: #808080;
        }

        .mny {
            display: inline-block;
            min-width: 120px;
            height: 40px;
            line-height: 40px;
            font-size: 16px;
            text-align: center;
            margin-left: 8px;
        }

        .blue {
            color: blue;
        }

        .red {
            color: red;
        }

        .bold {
            font-size: 22px;
            font-weight: bold;
        }
    </style>

    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var grid;

        var left_count = 0;
        var left_vip_count = 0;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#datagrid1").height(parentHeight - 100);

            mini.parse();

            grid = mini.get("datagrid1");

            search();

            drawCell();

            init();
        })

        function init() {

        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.to_uid + '\',500,1300)"><img src="' + photo + '" class="photo-img" /></a>';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }

                if (column.name == "nick") {
                    var nick = record.nick;
                    var inner_name = record.inner_name;

                    var bold = '';
                    if (inner_name) {
                        bold = "red";
                    }

                    e.cellHtml = '<span title="'+ inner_name +'" class="' + bold + '">' + nick + '</span>';
                }

                if (column.name == "sex") {
                    var sex = record.sex;
                    
                    var bold = '';
                    if (sex == "女生") {
                        bold = "blue bold";
                    }

                    e.cellHtml = '<span class="' + bold + '">' + sex + '</span>';
                }
                

                if (column.name == "total_coin") {
                    var total_coin = record.total_coin;
                    e.cellHtml = '<span class="red">' + total_coin + '</span>';
                }
                if (column.name == "total_score") {
                    var total_score = record.total_score;
                    e.cellHtml = '<span class="blue">' + total_score + '</span>';
                }


                if (column.name == "send_info") {
                    var send_count = record.send_count;
                    var send_count_suc = record.send_count_suc;
                    var send_count_fail = record.send_count_fail;

                    var bold = '';
                    if (send_count > 0) {
                        bold = "bold";
                    }

                    e.cellHtml = '<a href="javascript:dtl(\'' + record.to_uid + '\')"><span class="blue ' + bold + '">' + send_count + '</span>';
                    e.cellHtml += ' ( ';
                    e.cellHtml += '<span class="blue ' + bold + '">' + send_count_suc + '</span>';
                    e.cellHtml += ' - ';
                    e.cellHtml += '<span class="red ' + bold + '">' + send_count_fail + '</span>';
                    e.cellHtml += ' ) 详情</a>';
                }
                if (column.name == "rece_info") {
                    var rece_count = record.rece_count;
                    var rece_count_suc = record.rece_count_suc;
                    var rece_count_fail = record.rece_count_fail;

                    var bold = '';
                    if (rece_count > 0) {
                        bold = "bold";
                    }

                    e.cellHtml = '<span class="blue ' + bold + '">' + rece_count + '</span>';
                    e.cellHtml += ' ( ';
                    e.cellHtml += '<span class="blue ' + bold + '">' + rece_count_suc + '</span>';
                    e.cellHtml += ' - ';
                    e.cellHtml += '<span class="red ' + bold + '">' + rece_count_fail + '</span>';
                    e.cellHtml += ' ) ';
                }

                if (column.name == "send_info") {
                    var send_count_suc = record.send_count;
                    var rece_count_suc = record.rece_count;

                    if (send_count_suc > 0 && rece_count_suc > 0) {
                        e.rowStyle = 'background-color:#F5F5F5;';
                    }
                    //if (rece_msg_count_fail > 0) {
                    //    e.rowStyle = 'background-color:#ffd800;';
                    //}
                }
                
            });
        }

        function dtl(to) {

            var dtm = mini.get("dtm_chart").getText();

            var from = '@ViewData["id"]';

            ChartAB(dtm, from, to);
        }

        function search() {
            var dtm = mini.get("dtm_chart").getText();
            grid.load({
                "dtm": dtm
            });
        }

        function jump_date(num) {
            var d = new Date(mini.get("dtm_chart").getText());

            d.setDate(d.getDate() + num);
            var dtm = formatTime(d);


            mini.get("dtm_chart").setValue(dtm);

            search();
        }

        function formatTime(date) {
            var year = date.getFullYear();
            var month = date.getMonth() + 1, month = month < 10 ? '0' + month : month;
            var day = date.getDate(), day = day < 10 ? '0' + day : day;
            return year + '-' + month + '-' + day;
        }

    </script>

</head>
<body>
    <form id="form1">
        <div style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc;">
            <input id="dtm_chart" format="yyyy-MM-dd" class="mini-datepicker" style="width:110px;" value="@ViewData["dtm"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" class="sys-btn" value="查找" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" class="sys-btn" style="background-color:forestgreen" value="前一天" onclick="jump_date(-1)" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" class="sys-btn" style="background-color:orange" value="后一天" onclick="jump_date(1)" />&nbsp;&nbsp;&nbsp;&nbsp;
        </div>
        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px;"
             url="/Admin1/GetUserMatchDtl/@ViewData["id"]" idfield="id" allowresize="true"
             sizelist="[50,100,300]" pagesize="300">
            <div property="columns">
                <div field="xh" width="30" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="dtm" width="120" headeralign="center" align="center" allowsort="false">时间</div>

                <div name="photo" width="40" headeralign="center" align="center" allowsort="false">对方头像</div>
                <div name="nick" width="60" headeralign="center" align="left" allowsort="false">昵称</div>
                <div name="sex" width="50" headeralign="center" align="center" allowsort="false">性别</div>

                <div name="total_coin" width="80" headeralign="center" align="left" allowsort="false">豪气值</div>
                <div name="total_score" width="80" headeralign="center" align="left" allowsort="false">魅力值</div>

                <div name="send_info" width="120" headeralign="center" align="left" allowsort="false">发给ta的消息</div>
                <div name="rece_info" width="120" headeralign="center" align="left" allowsort="false">收到ta的消息</div>

                <div name="dtl" width="200" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>


