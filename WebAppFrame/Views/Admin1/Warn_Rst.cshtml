<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/demo.css" rel="stylesheet" type="text/css" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/public.js"></script>
    <style>
        .btn {
            margin-top: 20px;
            color: white;
            font-weight: 500;
            font-size: 18px;
            line-height: 30px;
            bottom: 0;
            border: 1px solid RGB(62,175,224);
            border-radius: 5px;
            width: 40%;
            cursor: pointer;
        }

        .ok {
            background-color: RGB(62,175,224);
        }

        .no {
            background-color: #f00;
        }
    </style>
</head>
<body>
    <div class="main">
        <div class="">
            <form id="form1">
                <div style="height:40px; line-height:40px;">
                    <select id="warn_sec" style="width:100%; height:28px; line-height:28px;">
                        <option value="">请选择</option>
                    </select>
                </div>
                <select id="warn_reason" style="width:100%; height:28px; line-height:28px; display:none;">
                    <option value="">请选择</option>
                </select>

                <input type="button" id="btnok" class="btn ok" value="警告" />
            </form>
        </div>
    </div>
</body>
</html>

<script type="text/javascript">
    $(function () {
        // 批量加载下拉框数据
        var categories = ["warn_seconds", "warn_reason"];
        loadBatchDropdownOptions(categories, function(data) {
            // 更新下拉框选项
            updateDropdown("warn_sec", data["warn_seconds"], true);
            updateDropdown("warn_reason", data["warn_reason"], false);
        });
        
        $("#btnok").bind("click", function () {
            var uid = "@ViewData[\"uid\"]";
            var warn_sec = $("#warn_sec").val();
            var warn_reason = $("#warn_reason").val();
            $.ajax({
                type: "POST",
                url: "/Admin1/Warn",
                data: { "uid": uid, "sec": warn_sec, "reason": warn_reason },
                success: function (data) {
                    data = JSON.parse(data);
                    if (data.state == "1") {
                        //alert("警告成功！");
                        docheck();
                    }
                }
            });
        });
    });

    function docheck() {
        var id = '@ViewData["id"]';
        $.ajax({
            type: "get",
            url: "/Admin1/Update_Check_Complain",
            data: { "id": id, "rst_check": "已警告", "rst": "成功" },
            success: function (data) {
                CloseWindow("ok");
            }
        });
    }

    function CloseWindow(action) {
        if (window.CloseOwnerWindow) return window.CloseOwnerWindow(action);
        else window.close();
    }
</script>