

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>

    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <script src="~/Scripts/public.js?id=12"></script>

    <style>
        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
        }

        .gray {
            color: #f30f86;
        }

        .blue {
            color: blue;
        }

        .red {
            color: red;
        }

        .bold {
            font-size: 22px;
            font-weight: bold;
        }

        .mny {
            display: inline-block;
            width: 120px;
            height: 40px;
            line-height: 40px;
            font-size: 18px;
            font-weight: bold;
            text-align: center;
        }

        .watit {
            color: gray;
        }
    </style>

    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window).height();
            var width = $("#desc").width();
            $("#datagrid1").height(parentHeight - 130);

            mini.parse();

            grid = mini.get("datagrid1");

            //grid.load();
            search();

            drawCell();

            init();
        })

        function init() {

        }

        function search() {
            var uid = '@ViewData["uid"]';
            var dtm_start = '@ViewData["dtm_start"]';
            var dtm_end = '@ViewData["dtm_end"]';
            
            grid.load({
                "uid":uid,
                "dtm_start": dtm_start,
                "dtm_end": dtm_end
            });
        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml += '<a style="color:blue;" href="javascript:UserAllInfo(\'' + record.uid + '\')">全貌</a>';
                }

                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }

                if (column.name == "nick") {
                    var nick = record.nick;
                    e.cellHtml = '<span>' + nick + '</span>';
                }

                if (column.name == "sex") {
                    var sex = record.sex;

                    var bold = '';
                    if (sex == "女生") {
                        bold = "blue bold";
                    }

                    e.cellHtml = '<span class="' + bold + '">' + sex + '</span>';
                }


                if (column.name == "total_coin") {
                    var total_coin = record.total_coin;
                    e.cellHtml = '<span class="red">' + total_coin + '</span>';
                }
                if (column.name == "total_score") {
                    var total_score = record.total_score;
                    e.cellHtml = '<span class="blue">' + total_score + '</span>';
                }
                if (column.name == "reg_time") {
                    var reg_time = record.reg_time;
                    var txt = reg_time + '分钟';
                    if (reg_time > 60) {
                        var hour = parseInt(reg_time / 60);
                        var min = reg_time % 60;
                        txt = hour + "小时" + min + "分钟";
                    }
                    if (reg_time > 60 * 24) {
                        var day = parseInt(reg_time / (60 * 24));
                        var hour = parseInt((reg_time % (60*24)) / 60);
                        txt = day + "天" +  hour + "小时"
                    }
                    e.cellHtml = '<span title="' + reg_time + '分钟" class="blue bold">' + txt + '</span>';
                }
                

                if (column.name == "send_info") {
                    var send_count = record.send_count;
                    var send_count_suc = record.send_count_suc;
                    var send_count_fail = record.send_count_fail;

                    var bold = '';
                    if (send_count > 0) {
                        bold = "bold";
                    }

                    e.cellHtml = '<span class="blue ' + bold + '">' + send_count + '</span>';
                    e.cellHtml += ' ( ';
                    e.cellHtml += '<span class="blue ' + bold + '">' + send_count_suc + '</span>';
                    e.cellHtml += ' - ';
                    e.cellHtml += '<span class="red ' + bold + '">' + send_count_fail + '</span>';
                    e.cellHtml += ' ) ';
                }
                if (column.name == "rece_info") {
                    var rece_count = record.rece_count;
                    var rece_count_suc = record.rece_count_suc;
                    var rece_count_fail = record.rece_count_fail;

                    var bold = '';
                    if (rece_count > 0) {
                        bold = "bold";
                    }

                    e.cellHtml = '<span class="blue ' + bold + '">' + rece_count + '</span>';
                    e.cellHtml += ' ( ';
                    e.cellHtml += '<span class="blue ' + bold + '">' + rece_count_suc + '</span>';
                    e.cellHtml += ' - ';
                    e.cellHtml += '<span class="red ' + bold + '">' + rece_count_fail + '</span>';
                    e.cellHtml += ' ) ';
                }

                if (column.name == "send_info") {
                    var send_count_suc = record.send_count;
                    var rece_count_suc = record.rece_count;

                    if (send_count_suc == 0 && rece_count_suc > 0) {
                        e.rowStyle = 'background-color:#FFDDAA;';
                    }
                    //if (rece_msg_count_fail > 0) {
                    //    e.rowStyle = 'background-color:#ffd800;';
                    //}
                }

            });
        }
    </script>

    <script>

        function onDrawSummaryCell(e) {
            var result = e.result;
            var grid = e.sender;

            //客户端汇总计算
            if (e.field == "match_count") {
                e.cellStyle = "text-align:center";
                e.cellHtml = '<span class="blue">' + e.cellHtml + '</span>';
            }
        }

    </script>

</head>
<body>
    <form id="form1">
        <div id="desc" style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc;">
            <span class="mny">xxx:<br /><span class="blue">xxx</span></span>

            <span class="mny">xxx:<br /><span class="red">￥</span></span>
            <span class="mny">xxx:<br /><span class="red">￥</span></span>
            <span class="mny">xxx:<br /><span class="red">￥</span></span>

            <span class="mny">xxx:<br /><span class="blue">0</span></span>
            <span class="mny">xxx:<br /><span class="blue">0</span></span>
            <span class="mny">xxx:<br /><span class="blue">0</span></span>

            <span class="mny">xxx:<br /><span class="gray">0</span></span>
            <span class="mny">xxx:<br /><span class="gray">0</span></span>
            <span class="mny">xxx:<br /><span class="gray">0</span></span>

        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px;"
             url="/Admin1/GetUserReceMatchDtl" idfield="id" allowresize="true"
             showsummaryrow="true" ondrawsummarycell="onDrawSummaryCell"
             sizelist="[20,50,100]" pagesize="100">
            <div property="columns">
                <div field="xh" width="40" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="dtm" width="120" headeralign="center" align="center" allowsort="false">时间</div>

                <div name="photo" width="80" headeralign="center" align="center" allowsort="false">匹配者头像</div>
                <div name="nick" width="60" headeralign="center" align="left" allowsort="false">昵称</div>
                <div name="sex" width="50" headeralign="center" align="center" allowsort="false">性别</div>

                <div field="match_count" width="50" headeralign="center" align="center" allowsort="false" summarytype="sum">匹配次数</div>

                <div name="reg_time" width="120" headeralign="center" align="left" allowsort="false">注册时间</div>
                <div name="total_coin" width="50" headeralign="center" align="left" allowsort="false">豪气值</div>
                <div name="total_score" width="50" headeralign="center" align="left" allowsort="false">魅力值</div>


                <div name="rece_info" width="120" headeralign="center" align="left" allowsort="false">消息-发送情况</div>
                <div name="send_info" width="120" headeralign="center" align="left" allowsort="false">消息-接收情况</div>
                
                <div name="dtl" width="200" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>
