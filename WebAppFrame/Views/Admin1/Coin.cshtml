
<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>

    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=6"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .txt {
            height: 22px;
            line-height: 22px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding-left: 5px;
            width: 180px;
        } 

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
        }

        .gray {
            color: #808080;
        }

        .blue {
            font-size:18px;
            color: blue;
        }

        .red {
            font-size: 18px;
            color: red;
        }
    </style>

    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 125);

            mini.parse();

            grid = mini.get("datagrid1");

            //grid.load();
            search();

            drawCell();

            init();
        })

        function init() {
            $("#conname").change(function () {
                conname();
            });
        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";

                    e.cellHtml = '---';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                   
                }
                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;
                    var nick = record.nick;
                    var sex = record.sex;
                    var color = "";
                    if (sex == "男生") {
                        color = "blue";
                    } else
                    {
                        color = "red";
                    }

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid_from + '\')"><img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "<br/>";
                    e.cellHtml += "<span style='color:" + color + "'>" + nick + "(" + sex + ")" + "</span></a>";
                }
                if (column.name == "photo2") {

                    if (record.photo2) {
                        var photo = servUrl_AppData + '/photo/' + record.photo2;
                        var nick = record.nick2;
                        var sex = record.sex2;
                        var color = "";
                        if (sex == "男生") {
                            color = "blue";
                        } else {
                            color = "red";
                        }

                        e.cellStyle = "text-align:center";
                        e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid_to + '\')"><img src="' + photo + '" class="photo-img" />';
                        e.cellHtml += "<br/>";
                        e.cellHtml += "<span style='color:" + color + "'>" + nick + "(" + sex + ")" + "</span></a>";
                    }
                }

                if (column.name == "dir") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '--->';
                }

                if (column.name == "dtm") {
                    var dtm = record.dtm;
                    if (dtm == null) { dtm = ''; }
                    else { dtm = dtm.replace(' ', '<br/>'); }

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="blue">' + dtm + '</span>';
                }


                if (column.name == "amount") {
                    var amount = record.amount;
                    var cls = 'red';
                    e.cellStyle = "text-align:right";
                    e.cellHtml = '<span class="' + cls + '" style="font-size:18px;">' + amount + '</span>';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }
                if (column.name == "type") {
                    var type = record.type;
                    var type_dtl = record.type_dtl;

                    var cls = 'gray';
                    if (type == "减少") {
                        cls = 'blue';
                    }
                    if (type_dtl == "购买") {
                        cls = 'red';
                    }

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '" style="font-size:18px;">' + type + '</span>';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }
                

            });
        }

        function search() {
            var type_dtl = $("#conname").val();
            var key = $("#key").val();
            var dtm = mini.get("dtm").getText();
            grid.load({
                "key": key,
                "type_dtl": type_dtl,
                "dtm": dtm
            });
        }

        function conname() {
            search();
        }
    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">金币明细</a></li>
        </ul>
    </div>
    <form id="form1">
       
        <div style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc;">
            查询关键词:<input type="text" class="txt" id="key" />&nbsp;(uid)&nbsp;&nbsp;&nbsp;&nbsp;
            日期:<input id="dtm" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["dtm"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
           
         

            类型详情:<select id="conname" style="height:24px;width:120px;">
                <option value="" selected="selected">默认</option>
                     <option value="购买">购买</option>
                     <option value="签到">签到</option>
                     <option value="积分兑换">积分兑换</option>

                     <option value="发送礼物">发送礼物</option>
                     <option value="添加好友">添加好友</option>
                     <option value="发送图片">发送图片</option>
                     <option value="打招呼">打招呼</option>

                     <option value="自己花金币解封">自己花金币解封</option>
                     <option value="解除师徒关系">解除师徒关系</option>
                     <option value="修改性别">修改性别</option>
                    
                     <option value="发布寻人贴">发布寻人贴</option>
                     <option value="顶帖">顶帖</option>
                     <option value="寻人区聊天">寻人区聊天</option>
                     <option value="寻人区查看微信">寻人区查看微信</option>
                     
                     <option value="平台操作-增加">平台操作-增加</option>
                     <option value="平台操作-减少">平台操作-减少</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;

            <input type="button" class="sys-btn" value="查找" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;

        </div>
        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px;"
             url="/Admin1/GetCoinList" idfield="id" allowresize="true" multiselect="true"
             sizelist="[20]" pagesize="20">
            <div property="columns">
                
                <div field="xh" width="40" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="uid_from" width="120" renderer="onGenderRenderer" align="left" headeralign="left">uid</div>
                <div name="photo" width="100" headeralign="center" align="center" allowsort="false">头像</div>
                <div name="dir" width="60" headeralign="center" align="left" allowsort="false">---></div>
                <div name="photo2" width="100" headeralign="center" align="center" allowsort="false">头像2</div>

                <div name="dtm" width="80" renderer="onGenderRenderer" align="center" headeralign="center">操作时间</div>
                <div name="amount" width="80" renderer="onGenderRenderer" align="center" headeralign="center">金币</div>
                <div name="type" width="80" renderer="onGenderRenderer" align="center" headeralign="center">类型</div>
                <div field="type_dtl" width="80" renderer="onGenderRenderer" align="center" headeralign="center">类型详情</div>
                <div field="comment" width="80" renderer="onGenderRenderer" align="center" headeralign="center">备注</div>

                <div name="dtl" width="100" headeralign="center" align="center" allowsort="false">操作</div>

            </div>
        </div>
    </form>
</body>
</html>
