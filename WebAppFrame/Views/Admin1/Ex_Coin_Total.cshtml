
<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=5"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 20px;
            font-weight: bold;
            color: red;
            height: 38px;
            line-height: 38px;
        }

        .blue {
            font-size: 18px;
            font-weight: bold;
            color: blue;
            height: 38px;
            line-height: 38px;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }

        .mny {
            display: inline-block;
            min-width: 100px;
            height: 40px;
            line-height: 40px;
            font-size: 18px;
            font-weight: bold;
            text-align: center;
            margin-left: 3px;
        }
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 65);

            mini.parse();
            grid = mini.get("datagrid1");

            grid.load();
            //search();

            drawCell();

            init();
        })

        function init() {

        }
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;
                //详情
                if (column.name == "dtl") {
                    
                    e.cellStyle = "text-align:left";
                    e.cellHtml = '<a style="color:blue;" href="javascript:UserAllInfo(\'' + record.uid + '\')">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;全貌</a>';
                }
                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;
                    
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }
                if (column.name == "c_add") {
                    var dtm = record.c_add;

                    e.cellHtml = '<span class="red">' + dtm + '</span>';
                }
                if (column.name == "c_sub") {
                    var dtm = record.c_sub;

                    e.cellHtml = '<span class="red">' + dtm + '</span>';
                }
                if (column.name == "c_diff") {
                    var dtm = record.c_diff;

                    e.cellHtml = '<span class="blue">' + dtm + '</span>';
                }
            });
        }

        function Add(id) {
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            var parentWidth = $(window.parent.document).find("#rightFrame").width();

            mini.open({
                url: "/Admin1/SysUser_Add/" + id,
                showMaxButton: false,
                title: "添加用户",
                width: 600,
                height: 400,
                ondestroy: function (action) {
                    if (action == "ok") {
                        grid.reload();
                    }
                    else if (action == "cancel") {

                    }
                }
            });
        }
    </script>


</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">总金币</a></li>
        </ul>
    </div>
    <form id="form1">
      
        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px;"
             url="/Admin1/GetCoinTotalData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[50,100,200]" pagesize="50">
            <div property="columns">
                <div field="xh" width="10" renderer="onGenderRenderer" align="center" headeralign="center">序号</div>
                <div field="uid" width="35" renderer="onGenderRenderer" align="left" headeralign="center">uid</div>
                <div name="photo" width="20" renderer="onGenderRenderer" align="left" headeralign="center">头像</div>
                <div field="nick" width="25" headeralign="center" align="left" allowsort="false">昵称</div>
                <div field="sex" width="10" headeralign="center" align="center" allowsort="false">性别</div>
                <div field="c_add" name="c_add" width="25" headeralign="center" align="right" allowsort="false">总金币</div>
                <div field="c_sub" name="c_sub" width="25" headeralign="center" align="right" allowsort="false">已消费</div>
                <div field="c_diff" name="c_diff" width="25" headeralign="center" align="right" allowsort="false">差值</div>

                <div name="dtl" width="100" headeralign="center" align="center" allowsort="false">全貌</div>
            </div>
        </div>
    </form>
</body>
</html>
