<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>

    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/public.css" rel="stylesheet" />

    <style>
        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 30px;
            height: 30px;
            border-radius: 50%;
        }

        .gray {
            color: #808080;
        }

        .mny {
            display: inline-block;
            min-width: 120px;
            height: 40px;
            line-height: 40px;
            font-size: 16px;
            text-align: center;
            margin-left: 8px;
        }

        .blue {
            color: blue;
        }

        .red {
            color: red;
        }

        .bold {
            font-size: 18px;
            font-weight: bold;
        }
    </style>

    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var grid;

        var left_count = 0;
        var left_vip_count = 0;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#datagrid1").height(parentHeight - 100);

            mini.parse();

            grid = mini.get("datagrid1");

            search();

            drawCell();

            init();
        })

        function init() {

        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                if (column.name == "txt") {
                    var txt = record.txt;
                    var msg_type = record.type;
                    if (msg_type == "text") {
                        txt = "<span style='font-size:22px; font-weight: bold; color:#f33;'>" + txt + "</span>";
                    }
                    if (msg_type == "pic" || msg_type == "gif" || msg_type == "emoji" || msg_type == "gift") {
                        txt = "<img src='" + txt + "' style='width:100px;' />";
                    }
                    e.cellHtml = txt;
                }

                if (column.name == "state") {
                    var state = record.state;
                    var txt = '成功';
                    var cls = 'blue';
                    if (state == "success") {
                        txt = '成功';
                        cls = 'blue';
                    }
                    else if (state == "fail") {
                        txt = '失败';
                        cls = 'red';
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';
                }

                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }
            });
        }

        function search() {
            var dtm = mini.get("dtm_chart").getText();
            grid.load({
                "dtm": dtm
            });
        }

        function jump_date(num) {
            var d = new Date(mini.get("dtm_chart").getText());

            d.setDate(d.getDate() + num);
            var dtm = formatTime(d);


            mini.get("dtm_chart").setValue(dtm);

            search();
        }

        function formatTime(date) {
            var year = date.getFullYear();
            var month = date.getMonth() + 1, month = month < 10 ? '0' + month : month;
            var day = date.getDate(), day = day < 10 ? '0' + day : day;
            return year + '-' + month + '-' + day;
        }

    </script>

</head>
<body>
    <form id="form1">
        <div style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc;">
            <input id="dtm_chart" format="yyyy-MM-dd" class="mini-datepicker" style="width:110px;" value="@ViewData["dtm"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" class="sys-btn" value="查找" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" class="sys-btn" style="background-color:forestgreen" value="前一天" onclick="jump_date(-1)" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" class="sys-btn" style="background-color:orange" value="后一天" onclick="jump_date(1)" />&nbsp;&nbsp;&nbsp;&nbsp;
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px;"
             url="/Admin1/GetUserLoginDtl/@ViewData["id"]" idfield="id" allowresize="true"
             sizelist="[50, 100,300]" pagesize="300">
            <div property="columns">
                <div field="xh" width="30" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="dtm" width="90" renderer="onGenderRenderer" align="center" headeralign="center">登录时间</div>
                <div field="sex" width="40" headeralign="center" align="center" allowsort="false">性别</div>
                <div field="inst_tag" width="80" headeralign="center" align="left" allowsort="false">标签</div>
                <div field="loc_province" width="60" headeralign="center" align="left" allowsort="false">省</div>
                <div field="loc_city" width="60" headeralign="center" align="left" allowsort="false">市</div>
                <div field="loc_area" width="60" headeralign="center" align="left" allowsort="false">县</div>
                <div name="dtl" width="300" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
        
    </form>
</body>
</html>


