                graph.title = "登录次数";
                graph.balloonText = "[[category]]登录次数<br><b><span style='font-size:14px;'>[[value]]</span></b>"; //提示信息
                chart.addGraph(graph);
            }
            if (true) {
                graph = new AmCharts.AmGraph();
