                graph.bulletSize = 8;//
                graph.bulletBorderColor = "#FFFFFF";
                graph.lineColor = '#FF00FF';//
                graph.valueField = "c_match"; //纵轴显示内容
                graph.title = "匹配次数";
                graph.balloonText = "[[category]]匹配次数<br><b><span style='font-size:14px;'>[[value]]</span></b>"; //提示信息
                chart.addGraph(graph);
            }
            if (true) {
                graph = new AmCharts.AmGraph();
                graph.valueAxis = valueAxis;
                graph.bullet = "round";//
                graph.bulletSize = 8;//
                graph.bulletBorderColor = "#FFFFFF";
                graph.lineColor = '#00FFFF';//
                graph.valueField = "c_msg_suc"; //纵轴显示内容
                graph.title = "消息量-suc";
