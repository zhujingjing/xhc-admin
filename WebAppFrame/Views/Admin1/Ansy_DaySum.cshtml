        function search() {
            var start = mini.get("datestart").getText();
            var end = mini.get("dateend").getText();

            var url = "/Admin1/Ansy_DaySum/@ViewData["id"]" + "?start=" + start + "&end=" + end;
            window.location.href = url;
        }

        function goto_sumDay() {
            mini.open({
                url: "/Admin1/Sum_Day",
                showMaxButton: false,
                title: "日统计",
                width: $(window).width() - 6,
                height: $(window).height() - 8,
            });
        }

    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">日总分析</a></li>
        </ul>
        <div class="btns">
            <input type="button" class="sys-btn" style="background-color:forestgreen" value="日统计" onclick="goto_sumDay()" />&nbsp;&nbsp;&nbsp;&nbsp;
        </div>
    </div>

    <form id="form1">
        <div style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc;">
            开始: <input id="datestart" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["start"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            截止: <input id="dateend" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["end"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" value="加载数据" class="sys-btn" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;<br />
        </div>
        <div id="divContainer1" style="width: 100%; height:400px; border: solid 1px #dcdcdc"></div>
        <div id="divContainer2" style="width: 100%; height: 500px; border: solid 1px #dcdcdc"></div>
        <div id="divContainer3" style="width: 100%; height: 400px; border: solid 1px #dcdcdc"></div>
           
</form>
</body>
</html>


