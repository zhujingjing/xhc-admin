

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=6"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .txt {
            height: 22px;
            line-height: 22px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding-left: 5px;
            width: 160px;
        }

        .txt1 {
            margin-left: 6px;
            font-weight: bold;
            font-size: 18px;
        }

        .lb {
            color: #666;
            margin-left: 20px;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 14px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }
    </style>

    <script type="text/javascript">

        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            search();
            drawCell();

            init();
            sum_peopleCounts();
        })
        var sum_people = {
            "v_10": 0,
            "v_59": 0
        }

        function sum_peopleCounts() {
            mini.get("datagrid1").on("load", function (e) {
                var records = e.data; // 获取加载完成的数据
                sum_people.v_10 = 0;
                sum_people.v_59 = 0;

                var fields = ["chat_count0", "chat_count1", "chat_count2", "chat_count3", "chat_count4", "chat_count5", "chat_count6", "chat_count7"];

                for (var record of records) {
                    var count_tag10 = false;
                    var count_tag59 = false;

                    for (var field of fields) {
                        if (record[field] >= 10) {
                            count_tag10 = true;
                        }
                        if (record[field] >= 5 && record[field] < 10) {
                            count_tag59 = true;
                        }

                        if (count_tag10 && count_tag59) {
                            break;
                        }
                    }

                    if (count_tag10) {
                        sum_people.v_10 += 1;
                    }
                    if (count_tag59) {
                        sum_people.v_59 += 1;
                    }
                }

                $("#count10").html(sum_people.v_10);
                $("#count59").html(sum_people.v_59);
            });
            
        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid + '\')"><img src="' + photo + '" class="photo-img" /></a>';
                }
                if (column.field == "least_time") {
                    var least_time = record.least_time;
                    least_time = least_time.replace(" ", "<br/>");
                    e.cellHtml = '<span>' + least_time + '</span>';
                }

                //时间差
                if (column.name == "time_diff") {
                    var dtm = record.least_time;
                    var dtm_now = new Date();
                    var diff_time = "";
                    if (dtm == null) {
                        diff_time = "";
                    } else {
                        dtm = new Date(dtm).getTime();
                        dtm_now = dtm_now.getTime();
                        diff_time = dtm_now - dtm;
                        var audit_cycle_days = Math.floor(diff_time / (1000 * 60));
                        if (audit_cycle_days < 1) {
                            var second = Math.floor(diff_time / 1000);
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span class="blue">' + second + '秒</span>';
                        }
                        if (audit_cycle_days >= 1 && audit_cycle_days < 60) {
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="font-size: 14px;color:blue;">' + audit_cycle_days + '分钟</span>';
                        }
                        if (audit_cycle_days >= 60 && audit_cycle_days < 60 * 24) {
                            audit_cycle_days = Math.floor(diff_time / (1000 * 60 * 60));
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="color:red;font-size:14px;">' + audit_cycle_days + '小时</span>';
                        }
                        if (audit_cycle_days >= 60 * 24) {
                            audit_cycle_days = Math.floor(diff_time / (1000 * 60 * 60 * 24));
                            e.cellStyle = "text-align:center";
                            e.cellHtml = '<span style="color:red;font-size:14px;font-weight: bold;">' + audit_cycle_days + '天</span>';
                        }
                    }

                }

                //注册时间
                if (column.field == "create_time") {
                    var day = 24 * 60 * 60 * 1000;
                    var dtm = Math.floor((Date.now() - new Date(record.create_time).getTime()) / day);

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span>' + dtm + '天</span>';
                }

                if (["chat_count0", "chat_count1", "chat_count2", "chat_count3", "chat_count4", "chat_count5", "chat_count6", "chat_count7"].includes(column.field)) {
                    var chat_count = record[column.field];
                    e.cellStyle = setCellStyle(chat_count);
                }
                
                function setCellStyle(chat_count) {
                    if (chat_count >= 10) {
                        return 'background-color:#458B00;';//2ac106
                    }
                    if (chat_count >= 5 && chat_count < 10) {
                        return 'background-color:#00FF66;';
                    }
                    if (chat_count >= 1 && chat_count < 5) {
                        return 'background-color:#CCFFCC;';
                    }
                 
                    if (chat_count == 0) {
                        return 'background-color:#CCFFFF;';
                    }
                    return '';
                }
            });
        }
    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#datagrid1").height(parentHeight - 70);
        }

        function search() {
            var days = $("#days").val();
            var srot = $("#srot").val();
            grid.load({
                "days": days,
                "sort": srot
            });
        }

    </script>
</head>
<body>
    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            上线时间:
            <select id="days" style="height:24px;">
                <option value="3" selected="selected">最近3天</option>
                <option value="5">最近5天</option>
                <option value="7">最近7天</option>
                <option value="15">最近15天</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;
            排序:
            <select id="srot" style="height:24px;">
                <option value="" selected="selected">默认</option>
                <option value="chat_count desc">总聊天次数</option>
                <option value="chat_count0 desc">今日</option>
                <option value="chat_count1 desc">昨日</option>
                <option value="chat_count2 desc">前天</option>
                <option value="create_time desc">注册时间</option>
                <option value="least_time desc">最近上线</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;
            <span class="lb">10次及以上人数:</span><span class="txt1" id="count10" style="color:blue">0</span>
            <span class="lb">5-9次人数:</span><span class="txt1" id="count59" style="color:blue">0</span>
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Admin1/GetChatScoreAnylysData" idfield="id" allowresize="true" multiselect="true"
             showsummaryrow="true"
             sizelist="[300,500,1000]" pagesize="300">
            <div property="columns">
                <div field="xh" width="10" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="least_time" width="20" headeralign="center" align="center" allowsort="false">最近上线</div>
                <div name="time_diff" width="10" headeralign="center" align="center" allowsort="false">时间差</div>
                <div name="photo" width="15" renderer="onGenderRenderer" align="center" headeralign="center">头像</div>
                <div field="nick" width="10" headeralign="center" align="left" allowsort="false">昵称</div>
                <div field="sex" width="10" headeralign="center" align="center" allowsort="false">性别</div>
                <div field="create_time" width="15" headeralign="center" align="center" allowsort="false">注册时间</div>
                <div field="remark" width="20" headeralign="center" align="left" allowsort="false">备注</div>
                <div field="chat_count" width="10" headeralign="center" align="center" allowsort="false">总聊天次数</div>
                <div field="chat_count0" width="10" headeralign="center" align="center" allowsort="false">今天</div>
                <div field="chat_count1" width="10" headeralign="center" align="center" allowsort="false">昨天</div>
                <div field="chat_count2" width="10" headeralign="center" align="center" allowsort="false">前天</div>
                <div field="chat_count3" width="10" headeralign="center" align="center" allowsort="false">往前三天</div>
                <div field="chat_count4" width="10" headeralign="center" align="center" allowsort="false">往前四天</div>
                <div field="chat_count5" width="10" headeralign="center" align="center" allowsort="false">往前五天</div>
                <div field="chat_count6" width="10" headeralign="center" align="center" allowsort="false">往前六天</div>
                <div field="chat_count7" width="10" headeralign="center" align="center" allowsort="false">往前七天</div>

                <div field="" width="50" headeralign="center" align="center" allowsort="false">--</div>
            </div>
        </div>
    </form>
</body>
</html>
