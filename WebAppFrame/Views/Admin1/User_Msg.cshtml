<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>

    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/public.css" rel="stylesheet" />

    <style>
        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 30px;
            height: 30px;
            border-radius: 50%;
        }

        .gray {
            color: #808080;
        }

        .mny {
            display: inline-block;
            min-width: 120px;
            height: 40px;
            line-height: 40px;
            font-size: 16px;
            text-align: center;
            margin-left: 8px;
        }

        .blue {
            color: blue;
        }

        .red {
            color: red;
        }

        .bold {
            font-size: 18px;
            font-weight: bold;
        }

        .txt1 {
            margin-left: 6px;
            font-weight: bold;
            font-size: 18px;
        }

        .lb {
            color: #666;
            margin-left: 20px;
        }
        .alert_json {
            display: none;
            position: fixed;
            margin: auto;
            left: 0;
            right: 0;
            top: 0;
            bottom: 0;
            width: 550px;
            height: 700px;
            background-color: #E3E6E8;
            border: 1px solid #999999;
            z-index: 99;
        }

        .close {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 10px;
            height: 30px;
        }

            .close span {
                font-size: 14px;
            }
    </style>

    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var grid;

        var left_count = 0;
        var left_vip_count = 0;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#datagrid1").height(parentHeight - 100);

            mini.parse();

            grid = mini.get("datagrid1");

            search();

            drawCell();

            init();

        })

        function init() {

        }

        var lastTime = "";
        var total_time = 0;
        var time_txt = "";
        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                
                if (column.name == "txt") {
                    var txt = record.txt;
                    var msg_type = record.type;
                    if (msg_type == "text") {
                        txt = "<span style='font-size:22px; font-weight: bold; color:#f33;'>" + txt + "</span>";
                    }
                    if (msg_type == "gift") {
                        txt = "<img src='" + txt + "' style='width:100px;' />";
                    }
                    if (msg_type == "pic") {
                        txt = "<span style='color: blue;' onclick='show_pic(\"" + txt + "\")'>【图片】-详情</span>";
                    }
                    if (msg_type == "emoji") {
                        txt = "<span>【emoji】</span>";
                    }
                    if (msg_type == "voice") {
                        var msg = JSON.parse(txt);
                        txt = "<span style='color: blue;' onclick='show_vouce(" + JSON.stringify(msg) + ")'>【语音】" + msg.time + "''-" + msg.coin + "金币-详情</span>";
                    }
                    e.cellHtml = txt;
                }

                if (column.name == "state") {
                    var state = record.state;
                    var txt = '成功';
                    var cls = 'blue';
                    if (state == "success") {
                        txt = '成功';
                        cls = 'blue';
                    } else if (state == "fail") {
                        txt = '失败';
                        cls = 'red';
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';
                }

                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }

                if (column.field == "dtm") {
                    var currentTime = new Date(record.dtm).getTime();

                    if (lastTime !== "") {
                        var diff_second = (lastTime - currentTime) / 1000;
                        if (diff_second <= 60 * 3) {
                            total_time += diff_second;
                        }
                    }

                    lastTime = currentTime;

                    var online_time = Math.floor(total_time / 60);

                    if (online_time < 60) {
                        time_txt = online_time + "分钟";
                    } else {
                        var hour = Math.floor(online_time / 60);
                        var min = online_time - hour * 60;
                        time_txt = hour + "小时" + min + "分钟";
                    }
                    $("#online_time").html(time_txt);
                }
            });

            
        }


        function search() {
            lastTime = "";
            total_time = 0;
            var dtm = mini.get("dtm_chart").getText();
            grid.load({
                "dtm": dtm
            });
        }

        function jump_date(num) {
            var d = new Date(mini.get("dtm_chart").getText());

            d.setDate(d.getDate() + num);
            var dtm = formatTime(d);


            mini.get("dtm_chart").setValue(dtm);

            search();
        }

        function formatTime(date) {
            var year = date.getFullYear();
            var month = date.getMonth() + 1, month = month < 10 ? '0' + month : month;
            var day = date.getDate(), day = day < 10 ? '0' + day : day;
            return year + '-' + month + '-' + day;
        }

        function show_pic(url) {
            document.getElementById("img-album").src = url;
            document.getElementById("popup").style.display = 'flex';
        }
        function closePopup() {
            document.getElementById("popup").style.display = 'none';
            document.getElementById("alert_json").style.display = 'none';
        }

        function show_vouce(json_data) {
            json_data = JSON.stringify(json_data);
            document.getElementById("alert_json").style.display = 'flex';
            document.getElementById("alert_json").style.flexDirection = 'column';
            document.getElementById("alert_json").style.justifyContent = 'center';
            $("#json_data").html(json_data);
        }

    </script>

</head>
<body>
    <div id="popup" class="ub ub-pc ub-ac" style="display: none; justify-content:center; align-items:center; position: fixed; top: 0; right: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.9); z-index: 99;" onclick="closePopup()">
        <img id="img-album" style="width: auto; height: 80%;" src="" />
    </div>

    <div id="alert_json" class="alert_json">
        <div class="close">
            <span>json数据</span>
            <span style="font-size: 16px;" onclick="closePopup()">关闭</span>
        </div>
        <textarea id="json_data" style="height: 95%; background: white; resize: none;padding:3px;"></textarea>
    </div>

    <form id="form1">
        <div style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc;">
            <input id="dtm_chart" format="yyyy-MM-dd" class="mini-datepicker" style="width:110px;" value="@ViewData["dtm"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" class="sys-btn" value="查找" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" class="sys-btn" style="background-color:forestgreen" value="前一天" onclick="jump_date(-1)" />&nbsp;&nbsp;&nbsp;&nbsp;
            <input type="button" class="sys-btn" style="background-color:orange" value="后一天" onclick="jump_date(1)" />&nbsp;&nbsp;&nbsp;&nbsp;
            <span class="lb">在线时长:</span><span class="txt1" id="online_time" style="color:blue">0</span>
        </div>
        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px;"
             url="/Admin1/GetUserMsgDtl/@ViewData["id"]" idfield="id" allowresize="true"
             sizelist="[20,50,100,1000]" pagesize="1000">
            <div property="columns">

                <div field="xh" width="30" headeralign="center" align="center" allowsort="false">序号</div>

                <div field="dtm" width="100" headeralign="center" align="center" allowsort="false">时间</div>
                <div name="txt" width="400" headeralign="center" align="left" allowsort="false">消息</div>

                <div name="state" width="60" headeralign="center" align="left" allowsort="false">状态</div>

                <div name="photo" width="90" headeralign="center" align="center" allowsort="false">对方头像</div>
                <div field="nick" width="60" headeralign="center" align="center" allowsort="false">昵称</div>
                <div field="sex" width="40" headeralign="center" align="center" allowsort="false">性别</div>

                <div name="dtl" width="200" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>


