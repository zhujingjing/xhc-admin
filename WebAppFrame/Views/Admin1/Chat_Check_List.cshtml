﻿<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>聊天审核列表</title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js?id=1"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=7"></script>

    <style>
        select {
            width: 120px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .txt {
            height: 22px;
            line-height: 22px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding-left: 5px;
            width: 160px;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 14px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }
    </style>

    <script type="text/javascript">

        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 125);
            mini.parse();
            grid = mini.get("datagrid1");
            init();
            search();
            drawCell();
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;
                if (column.name == "from_photo") {
                    var photo = servUrl_AppData + '/photo/' + record.from_photo;
                    var name = record.from_remark || record.from_nick || '';
                    var sex = record.from_sex || '';
                    var displayText = name + '(' + sex + ')';

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid_from + '\')" style="display:block; text-align:center;"><img src="' + photo + '" class="photo-img" /><div style="margin-top:5px;">' + displayText + '</div></a>';
                }

                if (column.name == "to_photo") {
                    var photo = servUrl_AppData + '/photo/' + record.to_photo;
                    var name = record.to_remark || record.to_nick || '';
                    var sex = record.to_sex || '';
                    var displayText = name + '(' + sex + ')';

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid_to + '\')" style="display:block; text-align:center;"><img src="' + photo + '" class="photo-img" /><div style="margin-top:5px;">' + displayText + '</div></a>';
                }

                if (column.name == "dtm_chat" || column.field == "create_time") {
                    var dtm = record[column.field];
                    if (dtm == null) { dtm = ''; }
                    else { dtm = dtm.replace(' ', '<br/>'); }

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span>' + dtm + '</span>';
                }

                if (column.field == "coin_used") {
                    var coin = record.coin_used || 0;
                    var score = record.score_earned || 0;
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span style="color: red;">' + coin + '</span>-<span style="color: blue;">' + score + '</span>';
                }

                if (column.field == "send_count") {
                    var send = record.send_count || 0;
                    var receive = record.receive_count || 0;
                    e.cellHtml = send + '-' + receive;
                }

                if (column.name == "action") {
                    e.cellHtml = '<a style="font-size:14px;color:green;margin-right:10px;" href="javascript:ChartAB(\'' + record.dtm_chat + '\',\'' + record.uid_from + '\',\'' + record.uid_to + '\')">详情</a>';
                    e.cellHtml += '<a style="font-size:14px;color:blue;margin-right:10px;" href="javascript:editRecord(\'' + record.id + '\')">编辑</a>';
                    e.cellHtml += '<a style="font-size:14px;color:red;" href="javascript:deleteRecord(\'' + record.id + '\')">删除</a>';
                }

                if (column.field == "evaluation") {
                    var color = '';
                    if (value == "很好" || value == "好") {
                        color = "blue";
                    } else if (value == "一般") {
                        color = "black";
                    } else if (value == "差" || value == "很差") {
                        color = "red";
                    }
                    e.cellHtml = '<span style="color: ' + color + ';">' + (value || '') + '</span>';
                }

                if (column.field == "brief") {
                    var briefText = getBriefText(value);
                    e.cellHtml = '<span>' + (briefText || '') + '</span>';
                }

                if (column.field == "details") {
                    var detailsText = value || '';
                    if (detailsText.length > 50) {
                        var shortText = detailsText.substring(0, 50) + '...';
                        e.cellHtml = '<span title="' + detailsText + '">' + shortText + '</span>';
                    } else {
                        e.cellHtml = '<span>' + detailsText + '</span>';
                    }
                }
            });
        }
    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var briefOptions = [];
        function init() {
            // 使用后端设置的默认时间
            var startDate = "@ViewData["startDate"]";
            var endDate = "@ViewData["endDate"]";
            
            if (startDate && startDate != "") {
                mini.get("startDate").setValue(new Date(startDate));
            }
            if (endDate && endDate != "") {
                mini.get("endDate").setValue(new Date(endDate));
            }
            
            // 加载来源下拉框
            loadDropdownOptions("chat_check_list_source", "source");
            
            // 加载简述下拉框配置，用于显示转换
            loadDropdownOptions("chat_check_add_brife", "brief_temp", true, function(options) {
                briefOptions = options;
            });
        }
        
        // 根据key获取对应的value
        function getBriefText(key) {
            for (var i = 0; i < briefOptions.length; i++) {
                if (briefOptions[i].key == key) {
                    return briefOptions[i].value;
                }
            }
            return key;
        }

        function search() {
            var uidFrom = $("#uidFrom").val();
            var uidTo = $("#uidTo").val();
            var startDate = mini.get("startDate").getValue();
            var endDate = mini.get("endDate").getValue();
            var source = $("#source").val();
            
            // 格式化日期为字符串
            if (startDate) {
                startDate = mini.formatDate(startDate, "yyyy-MM-dd HH:mm:ss");
            }
            if (endDate) {
                endDate = mini.formatDate(endDate, "yyyy-MM-dd HH:mm:ss");
            }
            
            grid.load({
                "uidFrom": uidFrom,
                "uidTo": uidTo,
                "startDate": startDate,
                "endDate": endDate,
                "source": source
            });
        }

        function editRecord(id) {
            var url = "/Admin1/Chat_Check_Add?id=" + id;
            mini.open({
                url: url,
                showMaxButton: false,
                title: "编辑聊天审核记录",
                width: 800,
                height: 600,
                onload: function () {
                    var iframe = this.getIFrameEl();
                },
                ondestroy: function (action) {
                    if (action == "ok") {
                        search();
                    }
                }
            });
        }

        function deleteRecord(id) {
            if (confirm('确定要删除这条记录吗？')) {
                $.ajax({
                    url: "/Admin1/DeleteChatCheck",
                    type: "POST",
                    data: { id: id },
                    dataType: "json",
                    success: function (result) {
                        try {
                            // 同时支持大写和小写字段名
                            var state = result.state || result.State;
                            var msg = result.msg || result.Msg || "未知错误";

                            if (state == "1" || state == 1) {
                                alert("删除成功");
                                search();
                            } else {
                                alert("删除失败: " + msg);
                            }
                        } catch (e) {
                            alert("解析返回结果失败: " + e.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        alert("请求错误: " + error);
                    }
                });
            }
        }

        function onDrawSummaryCell(e) {
            var result = e.result;
            var grid = e.sender;

            //客户端汇总计算
            if (e.field == "coin_used") {
                var coinSum = result.coin_used || 0;
                var scoreSum = result.score_earned || 0;
                e.cellStyle = "text-align:center";
                e.cellHtml = '<span style="display:inline-block;margin:10px 0; font-size:18px; font-weight:bold;"><span style="color: red;">' + coinSum + '</span>-<span style="color: blue;">' + scoreSum + '</span></span>';
            }

            if (e.field == "send_count") {
                var sendSum = result.send_count || 0;
                var receiveSum = result.receive_count || 0;
                e.cellStyle = "text-align:center";
                e.cellHtml = '<span style="display:inline-block;margin:10px 0; color:#00f; font-size:18px; font-weight:bold;">' + sendSum + '-' + receiveSum + '</span>';
            }
        }

    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">会话审核管理</a></li>
        </ul>
    </div>
    <form id="form1">

        <div style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc; display:flex; align-items: center;">
            <div style="margin-right: 20px;">
                <span>起始时间：</span>
                <input id="startDate" class="mini-datepicker" format="yyyy-MM-dd" style="width:120px;" value="@ViewData["startDate"]" />
            </div>
            <div style="margin-right: 20px;">
                <span>截止时间：</span>
                <input id="endDate" class="mini-datepicker" format="yyyy-MM-dd HH:mm:ss" style="width:180px;" value="@ViewData["endDate"]" />
            </div>
            <div style="margin-right: 20px;">
                <span>来源：</span>
                <select id="source" style="width:120px; height: 28px; border: 1px solid #ccc; border-radius: 4px; padding: 4px 8px;">
                    <option value="">全部</option>
                </select>
            </div>
            <div style="margin-right: 20px;">
                <span>发送方ID：</span>
                <input id="uidFrom" class="txt" />
            </div>
            <div style="margin-right: 20px;">
                <span>接收方ID：</span>
                <input id="uidTo" class="txt" />
            </div>
            <input id="btn_search" type="button" class="sys-btn" value="查询" onclick="search()" style="background-color: #E3F2FD; color: #1976D2;" />
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:700px; margin-top:5px;"
             url="/Admin1/GetChatCheckList" idfield="id" allowresize="true" multiselect="true"
             showsummaryrow="true" ondrawsummarycell="onDrawSummaryCell"
             sizelist="[100,200]" pagesize="100" autoLoad="false">
            <div property="columns">
                <div field="xh" width="30" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="create_time" width="100" headeralign="center" align="center">审核时间</div>
                <div name="from_photo" width="120" headeralign="center" align="center">发送方</div>
                <div name="to_photo" width="120" headeralign="center" align="center">接收方</div>
                <div name="dtm_chat" field="dtm_chat" width="100" headeralign="center" align="center">聊天日期</div>
                <div field="coin_used" width="80" headeralign="center" align="right" summarytype="sum">金币-积分</div>
                <div field="send_count" width="80" headeralign="center" align="right" summarytype="sum">发送-接收</div>
                <div field="chat_depth" width="60" headeralign="center" align="right">聊天深度</div>
                <div field="evaluation" width="60" headeralign="center" align="center">评价</div>
                <div field="brief" width="100" headeralign="center" align="left">简述</div>
                <div field="details" width="200" headeralign="center" align="left">详情</div>
                <div field="source" width="100" headeralign="center" align="left">来源</div>
                
                <div field="operator_name" width="80" headeralign="center" align="left">操作人</div>
                <div name="action" width="200" headeralign="center" align="left" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>