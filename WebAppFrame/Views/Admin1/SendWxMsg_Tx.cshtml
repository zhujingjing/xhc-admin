
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/demo.css" rel="stylesheet" type="text/css" />
    <style>
          .ub {
            display: flex;
        }

        .ub-ver {
            flex-direction: column;
        }

        .ub-as {
            justify-content: flex-start;
        }

        .ub-ac {
            justify-content: center;
        }

        .ub-ac1 {
            justify-content: space-around;
        }

        .ub-ac2 {
            justify-content: space-between;
        }

        .ub-ac3 {
            justify-content: space-evenly;
        }

        .ub-ae {
            justify-content: flex-end;
        }

        .ub-ps {
            align-items: flex-start;
        }

        .ub-pc {
            align-items: center;
        }


        .ok {
            background-color: RGB(62,175,224);
        }

        .no {
            background-color: #f00;
        }

        .main {
            margin-top:50px;
            display: flex;
            justify-content: center;
        }
        
        .main2{
            border:1px solid #dfdfdf;
            padding:15px;
        }
        .block{
            margin-top:20px;
        }
        .item{
            margin-top:10px;
        }
        .item .sp1{
            color:#888;
        }
         .item .sp2{
            color:#191552;
        }
         .btn_send{
             background-color:#e92162;
             color:#fff;
             padding:8px 0;
         }
    </style>
</head>
<body>
    <div class="main">
        <form id="form1">
           <div class="main2">
               <div class="ub ub-ver" style="margin-bottom:10px;">
                   <span style="margin-bottom:10px;font-size:19px; font-weight:bold;">提现到账通知</span>
                   <span style="color:#888">尊敬的用户您好，您申请的积分提现已到账，请注意查收！</span>
               </div>
               <div class="block">
                   <div class="item">
                       <span class="sp1">到账时间：</span>
                       <span class="sp2" id="keyword1">2017年7月15日</span>
                   </div>
                   <div class="item">
                       <span class="sp1">提现积分：</span>
                       <span class="sp2" id="keyword2">1000积分</span>
                   </div>
                   <div class="item">
                       <span class="sp1">到账金额：</span>
                       <span class="sp2" id="keyword3">0.8元</span>
                   </div>
                   <div class="item">
                       <span class="sp1">账户余额：</span>
                       <span class="sp2" id="keyword4">300元</span>
                   </div>
               </div>
           </div>
            <div id="btn_send" class="btn_send ub ub-pc ub-ac">发送</div>
        </form>
    </div>
</body>
</html>

<script src="~/Scripts/jquery-1.8.2.min.js"></script>

<script type="text/javascript">
    $(function () {
        var data = '@Html.Raw(ViewData["data"])';
        data = JSON.parse(data);
        var uid = data.uid;
        var tag = "3";
        var keyword1 = data.dtm;
        var keyword2 = data.score_tx + "积分";
        var keyword3 = data.mny + "元";
        var keyword4 = data.score_left + "积分";
        $("#keyword1").html(keyword1);
        $("#keyword2").html(keyword2);
        $("#keyword3").html(keyword3);
        $("#keyword4").html(keyword4);


        $("#btn_send").bind("click", function () {
            $("#btn_send").html("发送中···");
            $("#btn_send").unbind();
            doSendWxMsg();

        });



    });

    function doSendWxMsg() {
        var data = '@Html.Raw(ViewData["data"])';
        data = JSON.parse(data);
        var uid = data.uid;
        var id = data.id;
        var tag = "3";
        var keyword1 = data.dtm;
        var keyword2 = data.score_tx + "积分";
        var keyword3 = data.mny + "元";
        var keyword4 = data.score_left + "积分";
        var send = {
            "keyword1": keyword1,
            "keyword2": keyword2,
            "keyword3": keyword3,
            "keyword4": keyword4
        };
        var strData = JSON.stringify(send);
        $.ajax({
            type: "POST",
            url: "/Admin1/DoSendWxMsg",
            data: { "id": id, "uid": uid, "tag": tag, "strData": strData },
            success: function (data) {
                $("#btn_send").html("发送成功");
                alert(data);
                CloseWindow("ok");
            }
        });
    }

    function CloseWindow(action) {
        if (window.CloseOwnerWindow) return window.CloseOwnerWindow(action);
        else window.close();
    }
</script>