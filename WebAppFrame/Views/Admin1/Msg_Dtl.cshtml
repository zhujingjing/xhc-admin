

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=6"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 30px;
            height: 30px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 12px;
            color: #f00;
        }

        .blue {
            font-size: 12px;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }

        
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            //grid.load();
            search();
            drawCell();

            init();
            bindEvent();
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml += '<a style="color:blue;" href="javascript:UserAllInfo(\'' + record.uid + '\')">全貌</a>';
                }

                if (column.name == "txt") {
                    var txt = record.txt;
                    var sex = record.sex;
                    var msg_type = record.type;
                    if (msg_type == "text") {
                        if (sex == '男生') {
                            txt = "<span style='font-size:22px; font-weight: bold; color:#333;'>" + txt + "</span>";
                        }
                        else if (sex == '女生') {
                            txt = "<span style='font-size:22px; font-weight: bold; color:#f33;'>" + txt + "</span>";
                        }
                        else {
                            txt = "<span style='font-size:22px; font-weight: bold; color:#666;'>" + txt + "</span>";
                        }
                        
                    }
                    if (msg_type == "pic" || msg_type == "gif" || msg_type == "emoji" || msg_type == "gift") {
                        txt = "<img src='" + txt + "' style='width:100px;' />";
                    }
                    e.cellHtml = txt;
                }

                if (column.name == "state") {
                    var state = record.state;
                    var txt = '成功';
                    var cls = 'blue';
                    if (state == "success") {
                        txt = '成功';
                        cls = 'blue';
                    }
                    else if (state == "fail") {
                        txt = '失败';
                        cls = 'red';
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';
                }

                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }

            });
        }
    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 110);
        }

        function bindEvent() {
        }

        function search() {
            var dtm = mini.get("dtm").getText();
            grid.load({
                "dtm": dtm
            });
        }

    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">消息详情</a></li>
        </ul>
    </div>
    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            日期: <input id="dtm" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["dtm"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
           
            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Admin1/GetMsgDtlData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[100,200,500]" pagesize="200">
            <div property="columns">
                <div field="xh" width="40" headeralign="center" align="center" allowsort="false">序号</div>
                <div name="photo" width="60" renderer="onGenderRenderer" align="center" headeralign="center">头像</div>
                <div field="nick" width="60" headeralign="center" align="left" allowsort="false">昵称</div>
                <div field="sex" width="50" headeralign="center" align="center" allowsort="false">性别</div>
                <div field="dtm" width="100" headeralign="center" align="center" allowsort="false">时间</div>
                <div name="state" width="60" headeralign="center" align="left" allowsort="false">状态</div>
                <div name="txt" width="500" headeralign="center" align="left" allowsort="false">内容</div>
                
                <div name="dtl" width="100" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>
