
<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <script src="~/Scripts/jquery-1.8.2.min.js?id=123"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/public.css" rel="stylesheet" />

    <style>
        .txt {
            margin: 5px;
            height: 28px;
            line-height: 28px;
            width: 400px;
            padding-left: 5px;
            border-radius: 3px;
            border: 1px solid #0026ff;
        }
    </style>

    <script type="text/javascript">

        $(function () {
            var data = '@Html.Raw(ViewData["data"])';
            data = data.replace(/[\r\n]/g, "");
            data = JSON.parse(data);
            for (var key in data) {
                $("#" + key).val(data[key]);
            }

            $("#btnOK").bind("click", function () {
                doSave();
            });

        })

        function doSave() {
            var id = $("#id").val();

            var s_other = $("#s_other").val();
            var s_other_note = $("#s_other_note").val();

            var s_sub = $("#s_sub").val();
            var s_sub_note = $("#s_sub_note").val();

            var send = {
                "s_other": s_other,
                "s_other_note": s_other_note,
                "s_sub": s_sub,
                "s_sub_note": s_sub_note
            };
            var strSend = JSON.stringify(send);

            //后台
            $.ajax({
                type: "POST",
                url: "/Admin1/UpdatePscore",
                data: { "id":id, "send": strSend },
                success: function (data) {
                    data = strToJson(data);
                    if (data.state == "1") {
                        CloseWindow("ok");
                    }
                    else {
                        alert(data.msg);
                    }
                }
            });
        }

        function CloseWindow(action) {
            if (window.CloseOwnerWindow) return window.CloseOwnerWindow(action);
            else window.close();
        }
    </script>
</head>
<body>
    <form id="form1">
        <div style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc;">
            <table>
                <tr>
                    <td class="lb">id</td>
                    <td class="ctxt">
                        <input class="txt" type="text" id="id" disabled />
                    </td>
                </tr>

                <tr>
                    <td class="lb">日期</td>
                    <td class="ctxt ">
                        <input class="txt" type="text" id="dtm" disabled />
                    </td>
                </tr>

                <tr>
                    <td class="lb">统计对象</td>
                    <td class="ctxt ">
                        <input class="txt" type="text" id="name" disabled />
                    </td>
                </tr>

                <tr>
                    <td class="lb">其他得分</td>
                    <td class="ctxt ">
                        <input class="txt" type="text" id="s_other" />
                    </td>
                </tr>

                <tr>
                    <td class="lb">其他得分-详情</td>
                    <td class="ctxt ">
                        <input class="txt" type="text" id="s_other_note" />
                    </td>
                </tr>

                <tr>
                    <td class="lb">扣分</td>
                    <td class="ctxt ">
                        <input class="txt" type="text" id="s_sub" />
                    </td>
                </tr>

                <tr>
                    <td class="lb">扣分-详情</td>
                    <td class="ctxt ">
                        <input class="txt" type="text" id="s_sub_note" />
                    </td>
                </tr>

                <tr>
                    <td class="lb"></td>
                    <td class="ctxt ">
                        <input class="sys-btn" type="button" id="btnOK" value="保存" />
                    </td>
                </tr>

            </table>
        </div>
    </form>
</body>
</html>
