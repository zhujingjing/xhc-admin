

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=6"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }
        .txt {
            height: 22px;
            line-height: 22px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding-left: 5px;
            width: 160px;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .txt1 {
            margin-left: 6px;
            font-weight: bold;
            font-size: 18px;
        }

        .lb {
            color: #666;
            margin-left: 20px;
        }

        .mny_red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }
    </style>

    <script type="text/javascript">

        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#datagrid1").height(parentHeight - 80);


            mini.parse();
            grid = mini.get("datagrid1");
            drawCell();
            search();
            init();
        })

        var uids = [];

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid + '\')"><img src="' + photo + '" class="photo-img" /></a>';
                }


                if (column.field == "create_time") {
                    var day = 24 * 60 * 60 * 1000;
                    var dtm = Math.floor((Date.now() - new Date(record.create_time).getTime()) / day);
                    e.cellHtml = '<span>' + dtm + '天</span>';
                }

                if (column.field == "least_time") {
                    var least_time = record.least_time;
                    least_time = formatTimestamp(least_time);
                    least_time = least_time.replace(' ', '<br/>');
                    e.cellHtml = '<span>' + least_time + '</span>';
                }

                if (column.field == "least_login") {
                    var least_time = record.least_time;
                    var dtm_now = new Date().getTime();
                    least_time = least_time.getTime();
                    var diffTime = dtm_now - least_time;
                    var days = Math.floor(diffTime / (1000 * 60 * 60 * 24));
                    var hours = Math.floor((diffTime % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    var minutes = Math.floor((diffTime % (1000 * 60 * 60)) / (1000 * 60));
                    if (days > 0) {
                        e.cellHtml = '<span>' + days + '天</span>';
                    } else if (hours > 0) {
                        e.cellHtml = '<span>' + hours + '小时</span>';
                    } else if (minutes > 0) {
                        e.cellHtml = '<span>' + minutes + '分钟</span>';
                    } else {
                        e.cellHtml = '<span>刚刚</span>';
                    }
                }

                if (column.field == "dtm_pay") {
                    var dtm_pay = record.dtm_pay;
                    dtm_pay = formatTimestamp(dtm_pay);
                    dtm_pay = dtm_pay.replace(' ', '<br/>');
                    e.cellHtml = '<span>' + dtm_pay + '</span>';
                }

                if (column.field == "vip_endtime") {
                    var vip_endtime = record.vip_endtime;
                    vip_endtime = formatTimestamp(vip_endtime);
                    vip_endtime = vip_endtime.replace(' ', '<br/>');
                    e.cellHtml = '<span>' + vip_endtime + '</span>';
                }

                if (column.field == "is_expire") {
                    var vip_endtime = record.vip_endtime;
                    var dtm_now = new Date().getTime();
                    vip_endtime = vip_endtime.getTime();
                    if (dtm_now < vip_endtime) {
                        e.cellHtml = '<span style="color:blue">未过期</span>';
                    } else {
                        e.cellHtml = '<span style="color:red">已过期</span>';
                    }
                }

                //过期时间
                if (column.field == "expire") {
                    var vip_endtime = record.vip_endtime;
                    var dtm_now = new Date().getTime();
                    vip_endtime = vip_endtime.getTime();
                    var diffTime = dtm_now - vip_endtime;
                    var days = Math.floor(diffTime / (1000 * 60 * 60 * 24));
                    var hours = Math.floor((diffTime % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    var minutes = Math.floor((diffTime % (1000 * 60 * 60)) / (1000 * 60));
                    if (days > 0) {
                        e.cellHtml = '<span>' + days + '天</span>';
                    } else if (hours > 0) {
                        e.cellHtml = '<span>' + hours + '小时</span>';
                    } else if (minutes > 0) {
                        e.cellHtml = '<span>' + minutes + '分钟</span>';
                    } else {
                        e.cellHtml = '<span></span>';
                    }
                }

                if (column.field == "expireYorN") {
                    var vip_endtime = record.vip_endtime;
                    var dtm_now = new Date().getTime();
                    vip_endtime = vip_endtime.getTime();

                    if (dtm_now < vip_endtime) {
                        //到期
                        var diffTime = vip_endtime - dtm_now;
                        var days = Math.floor(diffTime / (1000 * 60 * 60 * 24));
                        var hours = Math.floor((diffTime % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                        var minutes = Math.floor((diffTime % (1000 * 60 * 60)) / (1000 * 60));
                        if (days > 0) {
                            e.cellHtml = '<span style="color:blue">' + days + '天</span>';
                        } else if (hours > 0) {
                            e.cellHtml = '<span style="color:blue">' + hours + '小时</span>';
                        } else {
                            e.cellHtml = '<span style="color:blue">' + minutes + '分钟</span>';
                        }
                    } else {
                        //过期
                        var diffTime = dtm_now - vip_endtime;
                        var days = Math.floor(diffTime / (1000 * 60 * 60 * 24));
                        var hours = Math.floor((diffTime % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                        var minutes = Math.floor((diffTime % (1000 * 60 * 60)) / (1000 * 60));
                        if (days > 0) {
                            e.cellHtml = '<span style="color:red">' + days + '天</span>';
                        } else if (hours > 0) {
                            e.cellHtml = '<span style="color:red">' + hours + '小时</span>';
                        } else {
                            e.cellHtml = '<span style="color:red">' + minutes + '分钟</span>';
                        }
                    }
                }
            });
        }
    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
        }

        function search() {
            var dtmReg_start = mini.get("dtmReg_start").getText();
            var dtmReg_end = mini.get("dtmReg_end").getText();

            var dtmOnline_start = mini.get("dtmOnline_start").getText();
            var dtmOnline_end = mini.get("dtmOnline_end").getText();
            var sort = $("#sort").val();
            grid.load({
                "dtmReg_start": dtmReg_start,
                "dtmReg_end": dtmReg_end,
                "dtmOnline_start": dtmOnline_start,
                "dtmOnline_end": dtmOnline_end,
                "sort": sort
            });

        }

        function formatTimestamp(date) {
            var year = date.getFullYear();
            var month = String(date.getMonth() + 1).padStart(2, '0'); // 月份从0开始
            var day = String(date.getDate()).padStart(2, '0');
            var hours = String(date.getHours()).padStart(2, '0');
            var minutes = String(date.getMinutes()).padStart(2, '0');
            var seconds = String(date.getSeconds()).padStart(2, '0');

            return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;
        }

    </script>
</head>
<body>
    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            注册时间: <input id="dtmReg_start" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["start"]" /> <span>-</span>
            <input id="dtmReg_end" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["end"]" />&nbsp;&nbsp;&nbsp;&nbsp;

            最近上线: <input id="dtmOnline_start" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["start"]" /> <span>-</span>
            <input id="dtmOnline_end" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["end"]" />&nbsp;&nbsp;&nbsp;&nbsp;
            排序:
            <select id="sort" style="height:24px;">
                <option value="" selected="selected">全部</option>
                <option value="expire_7">过期7天</option>
                <option value="expire_730">过期7-30天</option>
                <option value="expire_30">过期30天</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;

            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:800px; margin-top: 5px;"
             url="/Admin1/GetVipAllData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[100,300,500,1000]" pagesize="100">
            <div property="columns">
                <div field="xh" width="10" headeralign="center" align="center" allowsort="false">序号</div>

                <div name="photo" width="10" renderer="onGenderRenderer" align="center" headeralign="center">头像</div>
                <div field="sex" width="10" headeralign="center" align="center" allowsort="false">性别</div>
                <div field="create_time" width="10" headeralign="center" align="center" allowsort="false">注册时间</div>
                <div field="least_time" width="10" headeralign="center" align="center" allowsort="false">最近时间</div>
                <div field="least_login" width="10" headeralign="center" align="center" allowsort="false">最近登录</div>
                <div field="dtm_pay" width="10" headeralign="center" align="center" allowsort="false">最近会员时间</div>
                <div field="vip_endtime" width="10" headeralign="center" align="center" allowsort="false">到期时间</div>
                <div field="is_expire" width="10" headeralign="center" align="center" allowsort="false">是否过期</div>
                <div field="expire" width="10" headeralign="center" align="center" allowsort="false">过期</div>
                <div field="expireYorN" width="10" headeralign="center" align="center" allowsort="false">过期/到期</div>

                <div field="coin_total" width="10" headeralign="center" align="right" allowsort="false">总金币</div>
                <div field="coin" width="10" headeralign="center" align="right" allowsort="false">金币</div>
                <div field="score_total" width="10" headeralign="center" align="right" allowsort="false">总积分</div>
                <div field="score" width="10" headeralign="center" align="right" allowsort="false">积分</div>
                <div field="" width="50" headeralign="center" align="right" allowsort="false">--</div>
            </div>
        </div>
    </form>
</body>
</html>
