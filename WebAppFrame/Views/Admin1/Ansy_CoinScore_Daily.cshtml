            chart.numberFormatter.precision = 0;
            chart.depth3D = 0; //3d效果程度  0 , 15, 35
            chart.angle = 0;
            chart.labelRadius = 30; //提示内容线条长度 10 , 100
            chart.innerRadius = 0; //内环大小  0， 20 ， 50
            legend = new AmCharts.AmLegend();
            legend.align = "center"; //图标 center, left , right
            legend.valueText = "";
            if (1 == 1) {//是否显示图标
                chart.addLegend(legend);
            }

            chart.write(divContainer);
        }

        //显示积分减少饼图
        function showPie_score_decrease(divContainer, data) {
            var arrColors = ["#2ac106", "#7ce962", "#ff00cc"];
            chart = new AmCharts.AmPieChart();
            chart.colors = arrColors; //饼图颜色集合
            chart.dataProvider = data;

            chart.titleField = "类别";//"类别"; //：之前的提示内容
            chart.valueField = "积分"; //"次数"/"积分"; //饼块的组成
            chart.outlineColor = "#FFFFFF";
            chart.outlineAlpha = 1;
            chart.outlineThickness = 2;
            var dtm = mini.get("dtm").getText();
            var sum = 0;
            for (var i = 0; i < data.length; i++) {
                sum += data[i].积分;
            }
            if (sum > 10000) {
                sum = (sum / 10000).toFixed(2) + "万";
            }
            var tit = dtm + "积分减少(" + sum + ")";
            chart.addTitle(tit);
            chart.labelText = "[[value]]";
            chart.balloonText = "[[title]]：<br><span style='font-size:14px'><b>[[value]]积分</b> ([[percents]]%)</span>"; //提示信息
            chart.numberFormatter.precision = 0;
            chart.depth3D = 0; //3d效果程度  0 , 15, 35
            chart.angle = 0;
            chart.labelRadius = 30; //提示内容线条长度 10 , 100
            chart.innerRadius = 0; //内环大小  0， 20 ， 50
            legend = new AmCharts.AmLegend();
            legend.align = "center"; //图标 center, left , right
            legend.valueText = "";
            if (1 == 1) {//是否显示图标
                chart.addLegend(legend);
            }

            chart.write(divContainer);
        }
    </script>
</head>
<body>
    <div class="search_day">
        <input id="dtm" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["dtm"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
        <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;
        <input type="button" class="sys-btn" style="background-color:forestgreen" value="前一天" onclick="jump_date(-1)" />&nbsp;&nbsp;&nbsp;&nbsp;
        <input type="button" class="sys-btn" style="background-color:orange" value="后一天" onclick="jump_date(1)" />&nbsp;&nbsp;&nbsp;&nbsp;
    </div>

    <div id="container" style="padding:0 8px; margin-top:5px;">
        <div class="item">
            <div id="divContainer" style="width: 100%; height:100%; max-height:455px; border: solid 1px #dcdcdc"></div>
            <span class="other"><span>其它=</span><span id="other_coin_add"></span> </span>
        </div>
        <div class="item">

            <div id="divContainer2" style="width: 100%; height: 100%; max-height: 455px; border: solid 1px #dcdcdc"></div>
            <span class="other"><span>其它=</span><span id="other_coin_decrease"></span> </span>
        </div>
        <div class="item">

            <div id="divContainer3" style="width: 100%; height: 100%; max-height: 455px; border: solid 1px #dcdcdc "></div>
            <span class="other"><span>其它=</span><span id="other_score_add"></span> </span>
        </div>
        <div class="item">

            <div id="divContainer4" style="width: 100%; height: 100%; max-height: 455px; border: solid 1px #dcdcdc "></div>
            <span class="other"><span>其它=</span><span id="other_score_decrease"></span> </span>
        </div>
    </div>

    <table style="width: 100%; margin-top: 5px; padding: 0 8px;">
        <tr>
            <td style="width: 49%; ">
                <div id="datagrid1" class="mini-datagrid" style="width: 100%; height: 660px;"
                     url="/Admin1/GetAnsy_CoinData" idfield="id" allowresize="true"
                     showsummaryrow="true"
                     sizelist="[50]" pagesize="50">
                    <div property="columns">
                        <div field="xh" width="20" headeralign="center" align="center" allowsort="false">序号</div>

                        <div field="dtm" width="30" renderer="onGenderRenderer" align="center" headeralign="center">时间</div>
                        <div field="type" width="60" renderer="onGenderRenderer" align="center" headeralign="center">类型</div>
                        <div field="type_dtl" width="60" renderer="onGenderRenderer" align="left" headeralign="center">类型详情</div>
                        <div field="c1" width="60" renderer="onGenderRenderer" align="right" headeralign="center">次数</div>
                        <div field="c2" width="60" renderer="onGenderRenderer" align="right" headeralign="center">金币</div>
                    </div>
                </div>
            </td>
            <td style="width: 2%;"></td>
            <td style="width: 49%;">
                <div id="datagrid2" class="mini-datagrid" style="width:100%; height:660px;"
                     url="/Admin1/GetAnsy_ScoreData" idfield="id" allowresize="true"
                     sizelist="[50]" pagesize="50">
                    <div property="columns">
                        <div field="xh" width="40" headeralign="center" align="center" allowsort="false">序号</div>

                        <div field="dtm" width="30" renderer="onGenderRenderer" align="center" headeralign="center">时间</div>
                        <div field="type" width="60" renderer="onGenderRenderer" align="center" headeralign="center">类型</div>
                        <div field="type_dtl" width="60" renderer="onGenderRenderer" align="left" headeralign="center">类型详情</div>
                        <div field="c1" width="60" renderer="onGenderRenderer" align="right" headeralign="center">次数</div>
                        <div field="c2" width="60" renderer="onGenderRenderer" align="right" headeralign="center">积分</div>
                    </div>
                </div>
            </td>
        </tr>
    </table>
</body>
</html>


