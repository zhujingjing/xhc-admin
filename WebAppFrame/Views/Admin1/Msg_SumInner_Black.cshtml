

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=5"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 14px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }

        .c1 {
            font-size:22px;
            line-height:28px;
            height:28px;
            color:blue;
            font-weight:bold;
        }

        .vip {
            color:red;
            font-weight:bold;
        }
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            //grid.load();
            search();
            drawCell();

            init();
            bindEvent();
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:user_dtl(\'' + record.uid + '\')">---</a>';
                }

                if (column.name == "photo_from") {
                    var photo = servUrl_AppData + '/photo/' + record.photo_from;
                    var nick = record.nick_from;
                   
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<img src="' + photo + '" class="photo-img" /><br/>';
                    e.cellHtml += nick;
                }
                if (column.name == "photo_to") {
                    var isdayvip = record.isdayvip;
                    var cls = '';
                    if (isdayvip > 0) {
                        cls = 'vip';
                    }
                    var photo = servUrl_AppData + '/photo/' + record.photo_to;
                    var nick = record.nick_to;
                  
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a style="color:blue;" href="javascript:UserAllInfo(\'' + record.uid_to + '\')"><img src="' + photo + '" class="photo-img" /><br/></a>';
                    e.cellHtml += '<span class="'+cls+'">' + nick + '</span>';
                }

                if (column.name == "c1") {
                    var dtm = mini.get("dtm").getText();
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a><span class="c1">' + record.c1 + '</span></a>';
                    //e.cellHtml = '<a href="javascript:ChartAB(\'' + dtm + '\',\'' + record.uid_from + '\',\'' + record.uid_to + '\')"><span class="c1">' + record.c1 + '</span></a>';
                }
            });
        }
    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 110);
        }

        function bindEvent() {
        }


        function search() {

            var name = $("#name").val();
            var dtm = mini.get("dtm").getText();

            

            grid.load({
                "dtm": dtm,
                "name": name
            });
        }

    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">消除黑圈</a></li>
        </ul>
    </div>
    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            日期: <input id="dtm" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["dtm"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            统计对象
            <select id="name" style="height:24px;">
                <option value="" selected="selected">全部</option>

                @{
                    List<string> list = ViewBag.listMan;
                    string tie_man = string.Empty;
                    for (int i = 0; i < list.Count; i++)
                    {
                        tie_man = list[i];
                        <option value="@tie_man">@tie_man</option>
                    }
                }

            </select>&nbsp;&nbsp;&nbsp;&nbsp;

            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Admin1/GetMsgSum_InnerBlack" idfield="id" allowresize="true" multiselect="true"
             sizelist="[50,100,300,500]" pagesize="300">
            <div property="columns">
                <div field="xh" width="40" headeralign="center" align="center" allowsort="false">序号</div>
                <div name="photo_from" width="100" renderer="onGenderRenderer" align="center" headeralign="center">用户</div>
                <div name="photo_to" width="100" renderer="onGenderRenderer" align="center" headeralign="center">对方</div>
                <div name="c1" width="90" headeralign="center" align="center" allowsort="false">成功量</div>
                <div name="dtl" width="500" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>
