
<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=5"></script>

    <style>
       
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 82-40);

            mini.parse();
            grid = mini.get("datagrid1");

            search();
            //grid.load();

            drawCell();

            init();
        })

        function init() {
        }

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;
                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '-';
                }
            });
        }

        function search() {
            var start = mini.get("datestart").getText();
            var end = mini.get("dateend").getText();
            grid.load({
                "start": start,
                "end": end
            });
        }
    </script>

</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">登录记录</a></li>
        </ul>
    </div>
    <form id="form1">
        <div style="padding: 15px; margin-bottom: 5px; border: solid 1px #dcdcdc;">
            开始日期: <input id="datestart" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["start"]" onvaluechanged="onValueChanged" /> &nbsp;&nbsp;
            截止日期: <input id="dateend" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["end"]" /> &nbsp;&nbsp;
            
            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;


        </div>
        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px;"
             url="/Admin1/Get_Login_info" idfield="id" allowresize="true" multiselect="true"
             sizelist="[50,100,500]" pagesize="100">
            <div property="columns">
                <div field="xh" width="18" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="name" width="40" headeralign="center" align="left" allowsort="false">姓名</div>
                <div field="user_name" width="60" headeralign="center" align="left" allowsort="false">账号</div>
                <div field="type" width="50" headeralign="center" align="left" allowsort="false">类型</div>
                <div field="ip" width="60" headeralign="center" align="center" allowsort="false">登录IP</div>
                <div field="login_time" width="70" headeralign="center" align="center" allowsort="false">登录时间</div>

                <div name="dtl" width="320" headeralign="center" align="center" allowsort="false">操作</div>

            </div>
        </div>
    </form>
</body>
</html>
