

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=5"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 14px;
            font-weight: bold;
            color: blue;
        }

        .yellow {
            font-size: 18px;
            font-weight: bold;
            color: yellow;
        }
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            //grid.load();

            search();

            drawCell();

            init();
            bindEvent();
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:user_dtl(\'' + record.uid + '\')">---</a>';
                }
            });
        }
    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight-110);
        }

        function bindEvent() {
        }



        function search() {

            var uids = $("#uids").val();
            var dtm = mini.get("dtm").getText();

            grid.load({
                "dtm": dtm,
                "uids": uids
            });
        }

    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">发帖统计</a></li>
        </ul>
    </div>
    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            日期: <input id="dtm" format="yyyy-MM-dd" class="mini-datepicker" style="width:120px;" value="@ViewData["dtm"]" /> &nbsp;&nbsp;&nbsp;&nbsp;
            统计对象
            <select id="uids" style="height:24px;">
                <option value="" selected="selected">全部</option>
                <option value="廖秀泉">廖秀泉</option>
                <option value="郑志强">郑志强</option>
                <option value="朱静静">朱静静</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;

            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Admin1/GetTieSum_Inner" idfield="id" allowresize="true" multiselect="true"
             sizelist="[20,50,100]" pagesize="50">
            <div property="columns">
                <div field="xh" width="30" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="f1" width="30" renderer="onGenderRenderer" align="center" headeralign="center">发帖对象</div>
                <div field="f2" width="30" renderer="onGenderRenderer" align="center" headeralign="center">发帖数</div>
                <div field="f3" width="30" headeralign="center" align="center" allowsort="false">留存数</div>
                <div field="f4" width="30" headeralign="center" align="center" allowsort="false">30+</div>
                <div field="f5" width="30" headeralign="center" align="center" allowsort="false">高回复贴</div>
                <div field="f6" width="30" headeralign="center" align="center" allowsort="false">发帖总分</div>
                <div field="f7" width="30" headeralign="center" align="center" allowsort="false">额外奖励</div>
                <div name="" width="300" headeralign="center" align="center" allowsort="false">-</div>
            </div>
        </div>
    </form>
</body>
</html>
