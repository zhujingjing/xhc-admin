

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=6"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }
        .txt {
            height: 22px;
            line-height: 22px;
            border: 1px solid #dfdfdf;
            border-radius: 5px;
            padding-left: 5px;
            width: 160px;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .txt1 {
            margin-left: 6px;
            font-weight: bold;
            font-size: 18px;
        }

        .lb {
            color: #666;
            margin-left: 20px;
        }

        .mny_red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }
    </style>

    <script type="text/javascript">
        var day_7 = 0;
        var day_730 = 0;
        var day_30 = 0;
        var first_num = 0;

        var grid;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#datagrid1").height(parentHeight - 80);


            mini.parse();
            grid = mini.get("datagrid1");
            drawCell();
            search();
            init();
        })

        var uids = [];

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid + '\')"><img src="' + photo + '" class="photo-img" /></a>';
                }

                if (column.field == "sex") {
                    var sex = record.sex;
                    if (sex == "女生") {
                        e.cellStyle = "text-align:center";
                        e.cellHtml = '<span style="color:red;font-weight: bold;">' + sex + '</span>';
                    } else {
                        e.cellStyle = "text-align:center";
                        e.cellHtml = '<span>' + sex + '</span>';
                    }
                }

                if (column.field == "create_time") {
                    var day = 24 * 60 * 60 * 1000;
                    var dtm = Math.floor((Date.now() - new Date(record.create_time).getTime()) / day);

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span>' + dtm + '天</span>';
                }

                if (column.field == "dtm_pay") {
                    var dtm_pay = record.dtm_pay;
                    dtm_pay = formatTimestamp(dtm_pay);
                    var pre_end_time = record.pre_end_time;
                    pre_end_time = formatTimestamp(pre_end_time);
                    if (pre_end_time.startsWith("1900-01-01")) {
                        first_num++;
                        pre_end_time = "-";
                    }
                    e.cellHtml = '<span style="color:blue; font-size: 12px;">' + dtm_pay + '</span>';
                    e.cellHtml += '<br/>';
                    e.cellHtml += '<span style="color:red; font-size: 12px;">' + pre_end_time + '</span>';

                    $("#first_num").html(first_num);
                }
                

                if (column.field == "pay_mny") {
                    var pay_mny = record.pay_mny;
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="mny_red">￥' + pay_mny + '</span>';
                }
                if (column.field == "to_next") {
                    e.cellHtml = '<span>--></span>';
                }
                

                

                if (column.field == "renewal_cycle") {
                    var dtm_pay = record.dtm_pay;
                    var pre_end_time = record.pre_end_time;
                    dtm_pay = dtm_pay.getTime();
                    pre_end_time = pre_end_time.getTime();

                    if (pre_end_time < 1) {
                        return false;
                    }

                    // 计算时间差（毫秒）
                    var diffTime = dtm_pay - pre_end_time;
                    var hours = Math.floor(diffTime / (1000 * 60 * 60));
                    if (hours <= -24) {
                        day_7++;
                        var days = Math.floor(hours / 24);
                        e.cellHtml = '<span style="color:#458B00;font-size:16px; font-weight: bold;">' + days + '天</span>';
                    }

                    if (hours > -24 && hours < 0) {
                        day_7++;
                        e.cellHtml = '<span style="color:#458B00;font-size:16px; font-weight: bold;">' + hours + '小时</span>';
                    }

                    if (hours >= 0 && hours < 24) {
                        day_7++;
                        e.cellHtml = '<span style="color:blue;font-size:16px; font-weight: bold;">' + hours + '小时</span>';
                    }

                    if (hours >= 24 && hours <= 24 * 7) {
                        day_7++;
                        var days = Math.floor(hours / 24);
                        e.cellHtml = '<span style="color:blue;font-size:16px; font-weight: bold;">' + days + '天</span>';
                    }

                    if (hours > 24 * 7 && hours <= 24 * 30) {
                        day_730++;
                        var days = Math.floor(hours / 24);
                        e.cellHtml = '<span style="color:#dd4110;font-size:16px;">' + days + '天</span>';
                    }

                    if (hours > 24 * 30) {
                        day_30++;
                        var days = Math.floor(hours / 24);
                        e.cellHtml = '<span style="color:red;font-size:16px;font-weight: bold;">' + days + '天</span>';
                    }

                    $("#day_7").html(day_7);
                    $("#day_730").html(day_730);
                    $("#day_30").html(day_30);
                    
                }
            });
        }
    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        function init() {
        }

        function search() {
            day_7 = 0;
            day_730 = 0;
            f = 0;
            first_num = 0;

            var start = mini.get("dtm_start").getText();
            var end = mini.get("dtm_end").getText();
            var sort = $("#sort").val();
            var uid = $("#uid").val().trim();

            grid.load({
                "start": start,
                "end": end,
                "uid": uid,
                "sort": sort
            });

        }

        function formatTimestamp(date) {
            var year = date.getFullYear();
            var month = String(date.getMonth() + 1).padStart(2, '0'); // 月份从0开始
            var day = String(date.getDate()).padStart(2, '0');
            var hours = String(date.getHours()).padStart(2, '0');
            var minutes = String(date.getMinutes()).padStart(2, '0');
            var seconds = String(date.getSeconds()).padStart(2, '0');

            return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;
        }

    </script>
</head>
<body>
    <form id="form1">

        <div class="sys-content-border" style="padding:8px 3px;">
            订单日期: <input id="dtm_start" format="yyyy-MM-dd" class="mini-datepicker" value="@ViewData["start"]" />
            - <input id="dtm_end" format="yyyy-MM-dd" class="mini-datepicker" value="@ViewData["end"]" /> &nbsp;&nbsp;&nbsp;&nbsp;

            uid:<input type="text" class="txt" id="uid" />&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;

            排序:
            <select id="sort" style="height:24px; width:120px">
                <option value="" selected="selected">默认</option>
                <option value="pay_mny desc">订单金额(大-小)</option>
                <option value="pay_mny asc">订单金额(小-大)</option>

                <option value="pre_end_time desc">到期时间</option>

            </select>&nbsp;&nbsp;&nbsp;&nbsp;


            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />&nbsp;&nbsp;&nbsp;&nbsp;

            <span class="lb">7天内:</span><span class="txt1" id="day_7" style="color:blue">0</span>
            <span class="lb">7-30天:</span><span class="txt1" id="day_730" style="color:blue">0</span>
            <span class="lb">大于30天:</span><span class="txt1" id="day_30" style="color:blue">0</span>
            <span class="lb">首次支付:</span><span class="txt1" id="first_num" style="color:red">0</span>
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top: 10px;"
             url="/Admin1/GetVIP_RenewalCyclerData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[100,300,500,1000]" pagesize="100">
            <div property="columns">
                <div field="xh" width="10" headeralign="center" align="center" allowsort="false">序号</div>
                <div field="uid" width="15" headeralign="center" align="center" allowsort="false">uid</div>
                <div name="photo" width="10" renderer="onGenderRenderer" align="center" headeralign="center">头像</div>
                <div field="nick" width="10" headeralign="center" align="left" allowsort="false">昵称</div>
                <div field="sex" width="10" headeralign="center" align="center" allowsort="false">性别</div>
                <div field="create_time" width="10" headeralign="center" align="center" allowsort="false">注册时间</div>

                
                <div field="pay_mny" width="15" headeralign="center" align="center" allowsort="false">支付金额</div>

               
                <div field="dtm_pay" width="15" headeralign="center" align="center" allowsort="false">当前/上次</div>

                <div field="renewal_cycle" width="10" headeralign="center" align="right" allowsort="false">续费周期</div>

                <div field="pre_order_name" width="10" headeralign="center" align="center" allowsort="false">上次会员</div>
                <div field="to_next" width="5" headeralign="center" align="center" allowsort="false">--></div>
                <div field="order_name" width="10" headeralign="center" align="center" allowsort="false">当前会员</div>

                <div field="coin_total" width="10" headeralign="center" align="right" allowsort="false">总金币</div>
                <div field="coin" width="10" headeralign="center" align="right" allowsort="false">金币</div>
                <div field="score_total" width="10" headeralign="center" align="right" allowsort="false">总积分</div>
                <div field="score" width="10" headeralign="center" align="right" allowsort="false">积分</div>

            </div>
        </div>
    </form>
</body>
</html>
