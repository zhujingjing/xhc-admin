

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>

    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>
    <link href="~/Styles/public.css" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=6"></script>
    <style>
        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
        }

        .gray {
            color: #808080;
        }

        .mny {
            display: inline-block;
            min-width: 120px;
            height: 40px;
            line-height: 40px;
            font-size: 16px;
            text-align: center;
            margin-left: 8px;
        }

        .blue {
            color: blue;
        }

        .red {
            color: red;
        }

        .bold {
            font-size: 18px;
            font-weight: bold;
        }
    </style>

    <script type="text/javascript">
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var id = '@ViewData["id"]';
        var grid, grid2;

        var left_count = 0;
        var left_vip_count = 0;
        $(function () {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#datagrid1,#datagrid2").height(parentHeight - 40);

            mini.parse();

            grid = mini.get("datagrid1");
            grid2 = mini.get("datagrid2");

            //grid.load();
            search();
            search2();

            drawCell();

            init();

            function drawCell() {
                grid.on("drawcell", function (e) {
                    var record = e.record,
                        column = e.column,
                        field = e.field,
                        value = e.value;

                    //详情
                    if (column.name == "dtl") {
                        e.cellStyle = "text-align:center";
                        e.cellHtml = '<a style="font-size:18px;color:blue;" href="javascript:ChartAB(\'' + record.dtm + '\',\'' + record.uid_from + '\',\'' + record.uid_to + '\')">' + "详情" + '</a>';
                    }

                  

                    if (column.name == "to_photo") {
                        var photo = servUrl_AppData + '/photo/' + record.to_photo;
                        var nick = record.to_nick;
                        var sex = record.to_sex;
                        var diff = record.to_diff;
                        var color = "";
                        if (sex == "男生") {
                            color = "blue";
                        } else {
                            color = "red";
                        }

                        e.cellStyle = "text-align:center";
                        e.cellHtml = '<img src="' + photo + '" class="photo-img" />';
                        e.cellHtml += "<br/>";
                        e.cellHtml += "<span style='color:" + color + "'>" + nick + "(" + sex + ")</span>";
                    }

                    if (column.name == "dtm") {
                        var dtm = record.dtm;
                        if (dtm == null) { dtm = ''; }
                        dtm = dtm.replace(' ', '<br/>');

                        e.cellStyle = "text-align:center";
                        e.cellHtml = '<span class="red">' + dtm + '</span>';
                    }
                });

                grid2.on("drawcell", function (e) {
                    var record = e.record,
                        column = e.column,
                        field = e.field,
                        value = e.value;

                    //详情
                    if (column.name == "dtl") {
                        e.cellStyle = "text-align:center";
                        e.cellHtml += '<a style="color:blue;" href="javascript:LookGiftTouSuDtl(\'' + record.gift_id + '\')">详情</a>';
                        e.cellHtml += '&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;';
                        e.cellHtml += '<a style="color:blue;" href="javascript:CheckGiftTouSu(\'' + record.id + '\')">审核</a>';
                    }
                   
                    if (column.name == "photo2") {
                        var photo = servUrl_AppData + '/photo/' + record.photo2;

                        var nick2 = record.nick2;
                        var sex2 = record.sex2;
                        var color = "";
                        if (sex2 == "男生") {
                            color = "blue";
                        } else {
                            color = "red";
                        }
                        e.cellStyle = "text-align:center";
                        e.cellHtml = '<a href="javascript:UserAllInfo(\'' + record.uid_to + '\')"><img src="' + photo + '" class="photo-img" />';
                        e.cellHtml += "<br/>";
                        e.cellHtml += "<span style='color:" + color + "'>" + nick2 + "(" + sex2 + ")" + "</span></a>";
                    }
                    if (column.name == "state") {
                        var state = record.state;
                        var txt = '待审核';
                        var cls = 'gray';
                        if (state == "通过") {
                            txt = '通过';
                            cls = 'blue';
                        }
                        else if (state == "失败") {
                            txt = '失败';
                            cls = 'red';
                        }
                        e.cellStyle = "text-align:center";
                        e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';

                    }
                    if (column.name == "gift_time") {
                        var dtm = record.gift_time;
                        if (dtm == null) { dtm = ''; }
                        else { dtm = dtm.replace(' ', '<br/>'); }

                        e.cellStyle = "text-align:center";
                        e.cellHtml = '<span class="blue">' + dtm + '</span>';
                    }
                    if (column.name == "dtm") {
                        var dtm = record.dtm;
                        if (dtm == null) { dtm = ''; }
                        else { dtm = dtm.replace(' ', '<br/>'); }

                        e.cellStyle = "text-align:center";
                        e.cellHtml = '<span style="color:#e77c10;">' + dtm + '</span>';
                    }


                });
            }
        })

        function init() {

        }

    </script>
    <script>

        function search() {
            grid.load({
                "start": "2019-10-01",
                "end": "",
                "c_type": "",
                "A":id
            });
        }
        
        function search2() {
            grid2.load({
                "A": id
            });
        }


        function Check111() {

            mini.open({
                url: "/Admin1/Check_FeedBack/" + uid,
                showMaxButton: false,
                title: "审核",
                width: 700,
                height: 400,
                ondestroy: function (action) {

                }
            });
        }

        function LookGiftTouSuDtl(id) {
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            var parentWidth = $(window.parent.document).find("#rightFrame").width();
            mini.open({
                url: "/Admin1/Gif_TouSuDtl/" + id,
                showMaxButton: false,
                title: "查看详情",
                width: 500,
                height: parentHeight - 5,
                ondestroy: function (action) {

                }
            });
        }
        function CheckGiftTouSu(id) {
            mini.open({
                url: "/Admin1/CheckGiftTouSu/" + id,
                showMaxButton: false,
                title: "审核",
                width: 600,
                height: 300,
                ondestroy: function (action) {
                    grid.reload();
                }
            });
        }

    </script>

</head>
<body>
    <form id="form1">
        <table>
            <tr>
                <td style="width:40%;height:600px;">

                    <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
                         url="/Admin1/GetComplainData" idfield="id" allowresize="true" multiselect="true"
                         sizelist="[20,50,100]" pagesize="50">
                        <div property="columns">
                            <div field="xh" width="20" headeralign="center" align="center" allowsort="false">序号</div>
                            <div name="dtm" width="60" headeralign="center" align="center" allowsort="false">投诉时间</div>
                            <div name="to_photo" width="90" renderer="onGenderRenderer" align="center" headeralign="center">被投诉者</div>
                            <div field="c_type" width="50" headeralign="center" align="center" allowsort="false">投诉类别</div>
                            <div field="c_type_dtl" width="50" headeralign="center" align="center" allowsort="false">投诉内容</div>
                            
                            <div name="dtl" width="100" headeralign="center" align="center" allowsort="false">操作</div>

                        </div>
                    </div>
                </td>

                <td style="width:60%;height:600px;">
                    <div id="datagrid2" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
                         url="/Admin1/GetGifTouSuData" idfield="id" allowresize="true" multiselect="true"
                         sizelist="[20,50,100]" pagesize="50">
                        <div property="columns">
                            <div field="xh" width="5" headeralign="center" align="center" allowsort="false">序号</div>
                            @*<div field="uid" width="17" renderer="onGenderRenderer" align="left" headeralign="center">uid</div>*@
                            <div name="dtm" width="15" renderer="onGenderRenderer" align="center" headeralign="center">投诉时间</div>
                            <div name="photo2" width="15" renderer="onGenderRenderer" align="left" headeralign="center">被投诉者</div>
                            <div name="gift_time" width="13" renderer="onGenderRenderer" align="center" headeralign="center">发送礼物时间</div>
                            <div field="comment" width="8" renderer="onGenderRenderer" align="center" headeralign="center">投诉礼物</div>
                            <div field="amount" width="8" renderer="onGenderRenderer" align="right" headeralign="center">消耗金币</div>
                           
                            <div field="brife" width="20" renderer="onGenderRenderer" align="left" headeralign="center">投诉详情</div>

                            <div field="state" name="state" width="8" renderer="onGenderRenderer" align="center" headeralign="center">审核状态</div>
                            <div field="dtm_check" width="15" renderer="onGenderRenderer" align="center" headeralign="center">审核时间</div>
                            <div field="rst_check" width="20" renderer="onGenderRenderer" align="left" headeralign="center">审核结果</div>

                            <div name="dtl" width="13" headeralign="center" align="center" allowsort="false">操作</div>
                        </div>
                    </div>
                </td>
            </tr>
        </table>
    </form>
</body>
</html>


