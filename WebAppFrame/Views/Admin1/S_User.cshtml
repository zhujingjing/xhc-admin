

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title></title>
    <link href="~/Styles/style2.css?id=0" rel="stylesheet" />
    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/miniui/boot.js" type="text/javascript"></script>
    <script src="~/Scripts/Global.js"></script>

    <link href="~/Styles/public.css?id=1" rel="stylesheet" />
    <script src="~/Scripts/public.js?id=9"></script>

    <style>
        select {
            width: 80px;
            border-radius: 5px;
            border: 1px solid #dfdfdf;
        }

        .sys-summary {
            display: inline-block;
            text-align: center;
            min-width: 20px;
            font-size: 18px;
            color: #ff6a00;
        }

        .photo-img {
            width: 40px;
            height: 40px;
            border: solid 1px #dcdcdc;
            border-radius: 50%;
        }

        .photo-img-big {
            width: 100px;
            height: 100px;
        }

        .red {
            font-size: 18px;
            font-weight: bold;
            color: #f00;
        }

        .blue {
            font-size: 18px;
            font-weight: bold;
            color: blue;
        }

       
    </style>

    <script type="text/javascript">
        var grid;
        $(function () {
            mini.parse();
            grid = mini.get("datagrid1");
            //grid.load();
            search();
            drawCell();

            init();
            bindEvent();
        })

        function drawCell() {
            grid.on("drawcell", function (e) {
                var record = e.record,
                    column = e.column,
                    field = e.field,
                    value = e.value;

                //详情
                if (column.name == "dtl") {
                    e.cellStyle = "text-align:center";
                    //e.cellHtml += '<a style="color:blue;" href="javascript:UserAllInfo(\'' + record.uid + '\')">全貌</a>';
                    if (fn_user_s == "1")
                    {
                        e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                        e.cellHtml += '<a style="color:blue;" href="javascript:Add(\'' + record.id + '\')">修改</a>';
                    }
                    
                }

                if (column.name == "photo") {
                    var photo = servUrl_AppData + '/photo/' + record.photo;

                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<img src="' + photo + '" class="photo-img" />';
                    e.cellHtml += "&nbsp;&nbsp;&nbsp;";
                }

                if (column.name == "name") {
                    var r = record.name;
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="blue">' + r + '</span>';
                }

                if (column.name == "totalscore") {
                    var r = record.totalscore;
                   
                    e.cellHtml = '<span class="red">' + r + '</span>';
                }

                if (column.name == "is_use") {
                    var r = record.is_use;
                    var cls = "blue";
                    var txt = "可用";
                    if (r == 0) {
                        cls = "red";
                        txt = "不可用";
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="'+ cls +'">' + txt + '</span>';
                }
                
                if (column.name == "is_use_outnet") {
                    var r = record.is_use_outnet;
                    var cls = "blue";
                    var txt = "可用";
                    if (r == 0) {
                        cls = "red";
                        txt = "不可用";
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';
                }
                if (column.name == "score_lv") {
                    var r = record.score_lv;
                    var cls = "blue";
                    var txt = r + "级";
                    if (r == 1) {
                        cls = "red";
                    }
                    e.cellStyle = "text-align:center";
                    e.cellHtml = '<span class="' + cls + '">' + txt + '</span>';
                }
                
            });
        }

    </script>

    <script>
        var servUrl_AppData = '@ViewData["servUrl_AppData"]';
        var fn_user_s = '@ViewData["fn_user_s"]';
        function init() {
            //设置表格的高度
            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            $("#datagrid1").height(parentHeight - 150);
        }

        function bindEvent() {
        }

        function search() {
           
            var name = $("#name").val();
            var is_use = $("#is_use").val();
            var is_use_outnet = $("#is_use_outnet").val();

            grid.load({
                "name": name,
                "is_use": is_use,
                "is_use_outnet": is_use_outnet
            });
        }

        function Add(id) {
            if (fn_user_s != "1") {
                alert("你没有此功能权限!");
                return false;
            }

            var parentHeight = $(window.parent.document).find("#rightFrame").height();
            var parentWidth = $(window.parent.document).find("#rightFrame").width();

            mini.open({
                url: "/Admin1/S_User_Add/" + id,
                showMaxButton: false,
                title: "添加签约用户",
                width: 600,
                height: 550,
                ondestroy: function (action) {
                    if (action == "ok") {
                        grid.reload();
                    }
                    else if (action == "cancel") {

                    }
                }
            });
        }

    </script>
</head>
<body>
    <div class="place">
        <span>位置：</span>
        <ul class="placeul">
            <li><a href="#">签约用户管理</a></li>
        </ul>
    </div>
    
    <form id="form1">

        <div class="tools">
            <ul class="toolbar">
                <li class="click" onclick="Add('')"><span><img src="/Images/frame/t01.png" /></span>添加</li>
            </ul>
        </div>

        <div class="sys-content-border" style="padding:8px 3px;">
            姓名:
            <select id="name" style="height:24px;">
                <option value="" selected="selected">全部</option>

                @{
                    List<string> list = ViewBag.listMan;
                    string man = string.Empty;
                    for (int i = 0; i < list.Count; i++)
                    {
                        man = list[i];
                        <option value="@man">@man</option>
                    }
                }
  
            </select>&nbsp;&nbsp;&nbsp;&nbsp;
            是否可用:
            <select id="is_use" style="height:24px;">
                <option value="" >全部</option>
                <option value="1" selected="selected">可用</option>
                <option value="0">不可用</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;
            外网可用:
            <select id="is_use_outnet" style="height:24px;">
                <option value="" selected="selected">全部</option>
                <option value="1">可用</option>
                <option value="0">不可用</option>
            </select>&nbsp;&nbsp;&nbsp;&nbsp;
            <input id="btn_search" type="button" class="sys-btn" value="查找" onclick="search()" />
        </div>

        <div id="datagrid1" class="mini-datagrid" style="width:100%;height:600px; margin-top:5px;"
             url="/Admin1/GetSUserData" idfield="id" allowresize="true" multiselect="true"
             sizelist="[20,50,100]" pagesize="50">
            <div property="columns">
                <div field="xh" width="20" headeralign="center" align="center" allowsort="false">序号</div>
                <div name="name" width="40" renderer="onGenderRenderer" align="left" headeralign="center">姓名</div>
                <div field="uid" width="80" renderer="onGenderRenderer" align="left" headeralign="center">uid</div>

                <div name="photo" width="60" renderer="onGenderRenderer" align="center" headeralign="center">头像</div>
                <div field="nick" width="60" headeralign="center" align="left" allowsort="false">昵称</div>
                <div field="sex" width="40" headeralign="center" align="center" allowsort="false">性别</div>
                <div name="totalscore" width="80" headeralign="center" align="left" allowsort="false">魅力值</div>
                <div name="is_use" width="60" headeralign="center" align="right" allowsort="false">是否可用</div>
                <div name="is_use_outnet" width="60" headeralign="center" align="right" allowsort="false">外网可用</div>
                <div name="score_lv" width="60" headeralign="center" align="center" allowsort="false">得分等级</div>
                <div name="dtl" width="120" headeralign="center" align="center" allowsort="false">操作</div>
            </div>
        </div>
    </form>
</body>
</html>
