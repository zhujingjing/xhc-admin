    <script type="text/javascript">


        $(function () {
            //设置表格的高度
            var parentHeight = $(window).height();
            $("#container").height(parentHeight - 20);
            init();
        })

        function init() {
            var coin_sum = '@Html.Raw(ViewData["coin_sum"])';
            var score_sum = '@Html.Raw(ViewData["score_sum"])';
            coin_sum = JSON.parse(coin_sum);
            score_sum = JSON.parse(score_sum);
            var item;
            for (var i = 0; i < coin_sum.length; i++) {
                item = coin_sum[i];
                item.coin_other = item.coin_add - (item.coin_add_buy + item.coin_add_vip + item.coin_add_sign + item.coin_add_task);
                item.coin_sub_other = item.coin_sub - (item.coin_sub_gift + item.coin_sub_msg + item.coin_sub_friend);
            }
            for (var i = 0; i < score_sum.length; i++) {
                item = score_sum[i];
                item.score_add_other = item.score_add - (item.score_add_gift + item.score_add_msg + item.score_add_friend + item.score_add_task);
                item.score_sub_other = item.score_sub - (item.score_sub_tx + item.score_sub_coin);
            }
            //线图
            showLineCoinAdd(coin_sum);
            showLineCoinSub(coin_sum);

            showLineScoreAdd(score_sum);
            showLineScoreSub(score_sum);

        }

    </script>
    <script>
        function showLineCoinAdd(data) {
