            }

            if (true) {
                graph = new AmCharts.AmGraph();
                graph.valueAxis = valueAxis;
                graph.bullet = "round";
                graph.bulletSize = 8;
                graph.bulletBorderColor = "#FFFFFF";
                graph.lineColor = "#0000FF";
                graph.valueField = "coin_add_vip"; //纵轴显示内容
                graph.title = "会员";
                graph.balloonText = "截止到[[category]]点累计会员<br><b><span style='font-size:14px;'>[[value]]</span></b>"; //提示信息
